# Copy to .env and set values before production deploy.

# Required — generate with: python -c "import secrets; print(secrets.token_urlsafe(60))"
SECRET_KEY=your-long-random-secret-key-here

# Set to False in production
DEBUG=False

# Comma-separated hostnames/IPs (include Docker service names if needed: web,nginx)
ALLOWED_HOSTS=localhost,127.0.0.1,nginx,web,yourdomain.com

# HTTPS origins for CSRF (Django 4+), comma-separated, include scheme
# Example: https://app.example.com,https://www.example.com
CSRF_TRUSTED_ORIGINS=

# Optional — default 80; set if another service uses 80 on the host
# HTTP_PORT=8080

# PostgreSQL (docker-compose defaults match POSTGRES_* below)
POSTGRES_DB=ntarque
POSTGRES_USER=ntarque
POSTGRES_PASSWORD=change-me-in-production

# DATABASE_URL is set automatically in docker-compose for the web service.
# For non-Docker Postgres, set e.g. postgres://user:pass@host:5432/dbname

# Optional: Asia/Kolkata, UTC, America/New_York, etc.
TIME_ZONE=UTC

# Optional Gunicorn worker count (default 3 in entrypoint.sh)
# GUNICORN_WORKERS=4
