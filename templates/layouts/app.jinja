<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="{{ csrf_token }}">
    <title>{% block title %}DCPMind{% endblock %}</title>
    <link rel="dns-prefetch" href="https://unpkg.com">
    <link rel="dns-prefetch" href="https://cdn.jsdelivr.net">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="{{ static('css/tailwind.css') }}">
    <script src="https://unpkg.com/htmx.org@1.9.10/dist/htmx.min.js"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.8/dist/cdn.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        [x-cloak] { display: none !important; }
        .htmx-settling, .htmx-swapping { opacity: 0; transition: opacity .12s ease; }
        #task-tree.htmx-settling,
        #task-tree.htmx-swapping {
            opacity: 1 !important;
            transition: none !important;
        }
        .htmx-indicator { opacity: 0; transition: opacity 0.12s ease; pointer-events: none; }
        .htmx-indicator.htmx-request { opacity: 1; }
        .mm-branch-btn.htmx-request { animation: mm-pulse 0.55s ease-in-out infinite; }
        @keyframes mm-pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.08); } }
        aside.sidebar-cream {
            background: linear-gradient(185deg, #faf7f0 0%, #f3ebe2 52%, #ebe4da 100%);
            color: #3d3832;
            border-right-color: #d9cfc3 !important;
            box-shadow: inset -1px 0 0 rgba(217, 207, 195, 0.65);
        }
        aside.sidebar-cream.sidebar-collapsed nav a,
        aside.sidebar-cream.sidebar-collapsed .sidebar-team-row > a {
            justify-content: center;
            gap: 0;
            padding-left: 0.375rem;
            padding-right: 0.375rem;
        }
        aside.sidebar-cream.sidebar-collapsed .sidebar-brand {
            justify-content: center;
        }
        .dark aside.sidebar-cream {
            background: linear-gradient(185deg, #eae4dc 0%, #e1d9d0 55%, #d9d2c8 100%);
            color: #2e2a26;
            border-right-color: #c9bfb5 !important;
            box-shadow: inset -1px 0 0 rgba(190, 180, 168, 0.55);
        }
        body { font-family: Inter, system-ui, sans-serif; }
        :root { --dark-accent: #93c5fd; }
        .dark body { background: #0f1722; color: #dbe3ee; }
        .dark .bg-white { background-color: #151f2c !important; }
        .dark .bg-slate-50 { background-color: #151f2c !important; }
        .dark .bg-slate-100 { background-color: #1c2836 !important; }
        .dark .text-slate-900 { color: #f3f7fb !important; }
        .dark .text-slate-800 { color: #e5edf6 !important; }
        .dark .text-slate-700 { color: #d2deea !important; }
        .dark .text-slate-600 { color: #b5c4d4 !important; }
        .dark .text-slate-500 { color: #97a9bc !important; }
        .dark .text-slate-400 { color: #7f94a8 !important; }
        .dark .border-slate-200,
        .dark .border-slate-200\/80,
        .dark .border-slate-100 { border-color: #2b3a4a !important; }
        .dark .bg-indigo-50,
        .dark .bg-indigo-50\/50,
        .dark .bg-indigo-50\/40,
        .dark .bg-violet-50,
        .dark .bg-violet-50\/50,
        .dark .bg-violet-50\/40,
        .dark .bg-emerald-50,
        .dark .bg-emerald-50\/50,
        .dark .bg-amber-50,
        .dark .bg-amber-50\/60,
        .dark .bg-amber-50\/70,
        .dark .bg-fuchsia-50\/50 { background-color: #213246 !important; }
        .dark .text-indigo-700,
        .dark .text-violet-700,
        .dark .text-emerald-700,
        .dark .text-amber-800,
        .dark .text-fuchsia-700 { color: var(--dark-accent) !important; }
        .dark .bg-indigo-600,
        .dark .bg-violet-600,
        .dark .bg-fuchsia-600 { background-color: #3b82f6 !important; color: #ecf5ff !important; }
        .dark .hover\:bg-indigo-700:hover,
        .dark .hover\:bg-violet-700:hover,
        .dark .hover\:bg-fuchsia-700:hover { background-color: #c69c90 !important; }
        .dark .hover\:text-indigo-600:hover,
        .dark .hover\:text-indigo-700:hover,
        .dark .hover\:text-violet-800:hover { color: var(--dark-accent) !important; }
        .dark .dark-accent-btn {
            background-color: #3b82f6 !important;
            color: #ecf5ff !important;
            border-color: #3b82f6 !important;
            box-shadow: none !important;
        }
        .dark .dark-accent-btn:hover { background-color: #4f8ef7 !important; border-color: #4f8ef7 !important; }
        .dark .dark-soft-btn {
            background-color: #1f2f40 !important;
            border-color: #314559 !important;
            color: #dde7f2 !important;
        }
        .dark .dark-soft-btn:hover {
            background-color: #27394d !important;
            border-color: #3d556c !important;
            color: #eef4fa !important;
        }
        .dark .ring-indigo-100,
        .dark .ring-indigo-300 { --tw-ring-color: rgba(147, 197, 253, 0.42) !important; }
        .dark .dark-topbar {
            background-color: rgba(20, 31, 44, 0.94) !important;
            border-color: #2f4256 !important;
        }
        .dark .dark-topbar-pill {
            background-color: #1d2b3b !important;
            border-color: #32475d !important;
            color: #dde9f5 !important;
        }
        .dark input,
        .dark select,
        .dark textarea { background-color: #132131 !important; color: #e9f1f8 !important; border-color: #31485e !important; }
        .dark input::placeholder,
        .dark textarea::placeholder { color: #9ca3af !important; }
        .dark .shadow-sm,
        .dark .shadow-md,
        .dark .shadow-lg,
        .dark .shadow-xl,
        .dark .shadow-2xl { box-shadow: 0 0 0 rgba(0, 0, 0, 0) !important; }
        #task-tree {
            background-color: #f1f5f9 !important;
            background-image: radial-gradient(circle at 1.5px 1.5px, #cbd5e1 1.5px, transparent 0) !important;
            background-size: 22px 22px !important;
        }
        .dark #task-tree {
            background-color: #142130 !important;
            background-image: radial-gradient(circle at 1.5px 1.5px, rgba(147, 197, 253, 0.18) 1.2px, transparent 0) !important;
            background-size: 24px 24px !important;
        }
        .dark #task-tree [data-task-id] {
            background-color: #1d2c3d !important;
            border-color: #375169 !important;
            box-shadow: 0 5px 16px rgba(0, 0, 0, 0.24) !important;
        }
        .dark #billing-page .team-control-panel {
            background-color: #182635 !important;
            border-color: #365168 !important;
        }
        .dark #billing-page .team-control-hint,
        .dark #billing-page .team-control-note,
        .dark #billing-page .team-invite-note {
            color: #c4d2df !important;
        }
        .dark #billing-page .team-members-table thead {
            background-color: #203246 !important;
            color: #c7d6e5 !important;
        }
        .dark #billing-page .team-members-table tbody {
            color: #d7e2ec !important;
        }
        .dark #billing-page .team-join-panel {
            background-color: #1b2d40 !important;
            border-color: #3b5c76 !important;
        }
        .dark #billing-page .recent-invites-list {
            border-color: #365168 !important;
        }
        .dark #billing-page .recent-invites-list li {
            border-color: #2e475d !important;
            color: #d7e2ec !important;
        }
        .dark #billing-page .recent-invites-list span.bg-emerald-100 {
            background-color: #14532d !important;
            color: #bbf7d0 !important;
        }
        .dark #billing-page .recent-invites-list span.bg-slate-200 {
            background-color: #334155 !important;
            color: #e2e8f0 !important;
        }
        .dark #billing-page .recent-invites-list span.bg-rose-100 {
            background-color: #7f1d1d !important;
            color: #fecdd3 !important;
        }
        .dark #billing-page .archived-mindmap-panel {
            background-color: #1b2d40 !important;
            border-color: #3b5c76 !important;
        }
        .team-pct-pop {
            animation: pct-pop 420ms ease-out;
        }
        @keyframes pct-pop {
            0% { transform: scale(1); }
            35% { transform: scale(1.12); }
            100% { transform: scale(1); }
        }
    </style>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            function focusTaskCard(taskId) {
                if (!taskId) return;
                var card = document.querySelector('[data-task-id="' + taskId + '"]');
                if (!card) return;
                card.scrollIntoView({ behavior: 'smooth', block: 'center', inline: 'center' });
                if (typeof card.focus === 'function') {
                    card.focus({ preventScroll: true });
                }
                card.classList.add('ring-2', 'ring-indigo-300', 'ring-offset-1');
                window.setTimeout(function () {
                    card.classList.remove('ring-2', 'ring-indigo-300', 'ring-offset-1');
                }, 1200);
            }

            var initialFocusTaskId = document.body.dataset.focusTaskId || '';
            if (initialFocusTaskId) {
                window.setTimeout(function () {
                    focusTaskCard(initialFocusTaskId);
                }, 120);
            }

            document.body.addEventListener('htmx:configRequest', function (e) {
                var meta = document.querySelector('meta[name=csrf-token]');
                if (meta && meta.content) e.detail.headers['X-CSRFToken'] = meta.content;
            });

            document.body.addEventListener('htmx:beforeRequest', function (e) {
                var source = e && e.detail ? e.detail.elt : null;
                if (!source || !source.closest) return;
                var method = ((e.detail && e.detail.requestConfig && e.detail.requestConfig.verb) || 'get').toLowerCase();
                if (method === 'get') return;
                if (source.hasAttribute && source.hasAttribute('data-hx-no-task-focus')) return;
                var card = source.closest('[data-task-id]');
                if (!card) return;
                document.body.dataset.pendingFocusTaskId = card.getAttribute('data-task-id') || '';
                document.body.dataset.pendingFocusEnabled = '1';
            });

            document.body.addEventListener('htmx:beforeSwap', function (e) {
                var target = e && e.detail ? e.detail.target : null;
                if (!target || target.id !== 'task-tree') return;
                var scroll = document.getElementById('mm-scroll-area');
                if (scroll) {
                    document.body.dataset.mmScrollTop = String(scroll.scrollTop || 0);
                    document.body.dataset.mmScrollLeft = String(scroll.scrollLeft || 0);
                }
            });

            document.body.addEventListener('htmx:afterSwap', function (e) {
                var target = e && e.detail ? e.detail.target : null;
                if (!target || target.id !== 'task-tree') return;
                var scroll = document.getElementById('mm-scroll-area');
                if (scroll && document.body.dataset.mmScrollTop !== undefined) {
                    scroll.scrollTop = parseInt(document.body.dataset.mmScrollTop, 10) || 0;
                    scroll.scrollLeft = parseInt(document.body.dataset.mmScrollLeft, 10) || 0;
                    delete document.body.dataset.mmScrollTop;
                    delete document.body.dataset.mmScrollLeft;
                }
                if (document.body.dataset.pendingFocusEnabled !== '1') return;
                var taskId = document.body.dataset.pendingFocusTaskId;
                if (!taskId) return;
                var card = document.querySelector('[data-task-id="' + taskId + '"]');
                if (card) {
                    card.scrollIntoView({ behavior: 'smooth', block: 'center', inline: 'center' });
                    if (typeof card.focus === 'function') {
                        card.focus({ preventScroll: true });
                    }
                    card.classList.add('ring-2', 'ring-indigo-300', 'ring-offset-1');
                    window.setTimeout(function () {
                        card.classList.remove('ring-2', 'ring-indigo-300', 'ring-offset-1');
                    }, 900);
                }
                delete document.body.dataset.pendingFocusTaskId;
                delete document.body.dataset.pendingFocusEnabled;
            });

            document.body.addEventListener('taskCreated', function (e) {
                var taskId = e && e.detail ? String(e.detail.taskId || '') : '';
                if (!taskId) return;
                document.body.dataset.pendingFocusTaskId = taskId;
                document.body.dataset.pendingFocusEnabled = '1';
                var card = document.querySelector('[data-task-id="' + taskId + '"]');
                if (!card) return;
                card.scrollIntoView({ behavior: 'smooth', block: 'center', inline: 'center' });
                if (typeof card.focus === 'function') {
                    card.focus({ preventScroll: true });
                }
                card.classList.add('ring-2', 'ring-indigo-300', 'ring-offset-1');
                window.setTimeout(function () {
                    card.classList.remove('ring-2', 'ring-indigo-300', 'ring-offset-1');
                }, 1100);
            });

            document.body.addEventListener('sidebarTeamPct', function (e) {
                var detail = e && e.detail ? e.detail : {};
                var teamId = String(detail.teamId || '');
                if (!teamId) return;
                var pct = Number(detail.pct || 0);
                if (!Number.isFinite(pct)) pct = 0;
                pct = Math.max(0, Math.min(100, Math.round(pct)));
                var badge = document.querySelector('[data-team-pct="' + teamId + '"]');
                if (!badge) return;
                var prevText = (badge.textContent || '').trim();
                badge.textContent = pct + '%';
                badge.classList.remove(
                    'border-emerald-200', 'bg-emerald-50', 'text-emerald-700',
                    'border-amber-200', 'bg-amber-50', 'text-amber-700',
                    'border-rose-200', 'bg-rose-50', 'text-rose-700',
                    'border-slate-200', 'bg-slate-50', 'text-slate-600'
                );
                if (pct >= 60) {
                    badge.classList.add('border-emerald-200', 'bg-emerald-50', 'text-emerald-700');
                } else if (pct < 30) {
                    badge.classList.add('border-rose-200', 'bg-rose-50', 'text-rose-700');
                } else if (pct < 50) {
                    badge.classList.add('border-amber-200', 'bg-amber-50', 'text-amber-700');
                } else {
                    badge.classList.add('border-slate-200', 'bg-slate-50', 'text-slate-600');
                }
                if (prevText !== (pct + '%')) {
                    badge.classList.remove('team-pct-pop');
                    void badge.offsetWidth;
                    badge.classList.add('team-pct-pop');
                }
            });
        });
    </script>
</head>
<body class="min-h-screen bg-slate-100 text-slate-900 antialiased transition-colors"
      data-focus-task-id="{{ focus_task_id|default('') }}"
      x-data="{
        addModalOpen: false,
        importModalOpen: false,
        teamModalOpen: false,
        inviteModalOpen: false,
        teamCreateError: '',
        parentIdForModal: '',
        taskStarter: '',
        sidebarOpen: false,
        taskDetailOpen: false,
        uiReady: false,
        isBoardView: {{ (task_layout is defined and task_layout in ['mindmap', 'tree', 'mini', 'idea'])|tojson }},
        isMindmap: {{ (task_layout|default('mindmap') in ['mindmap', 'mini', 'idea'])|tojson }},
        darkMode: false,
        toggleSidebar() {
          this.sidebarOpen = !this.sidebarOpen;
          localStorage.setItem('sidebarOpen', this.sidebarOpen ? '1' : '0');
        },
        initTheme() {
            const stored = localStorage.getItem('theme');
            this.darkMode = stored ? stored === 'dark' : window.matchMedia('(prefers-color-scheme: dark)').matches;
            document.documentElement.classList.toggle('dark', this.darkMode);
            const storedSidebar = localStorage.getItem('sidebarOpen');
            if (storedSidebar !== null) {
              this.sidebarOpen = storedSidebar === '1';
            }
            this.uiReady = true;
        },
        toggleTheme() {
            this.darkMode = !this.darkMode;
            localStorage.setItem('theme', this.darkMode ? 'dark' : 'light');
            document.documentElement.classList.toggle('dark', this.darkMode);
        }
      }"
      x-init="initTheme()"
      @keydown.window.ctrl.k.prevent="addModalOpen = true; parentIdForModal = ''"
      @keydown.window.meta.k.prevent="addModalOpen = true; parentIdForModal = ''">
<div class="flex min-h-screen">
    <!-- Sidebar -->
    <aside x-cloak
           :style="sidebarOpen ? 'width:16rem;min-width:16rem;max-width:16rem;' : 'width:3.5rem;min-width:3.5rem;max-width:3.5rem;'"
           class="sidebar-cream relative flex shrink-0 flex-col border-r border-[#d9cfc3] text-stone-800 transition-all duration-300 ease-out"
           :class="(!uiReady ? 'transition-none ' : '') + (!sidebarOpen ? 'sidebar-collapsed overflow-hidden' : '')">
        <div class="border-b border-[#d9cfc3]/90 bg-[#f7f2ea]/95 p-2">
            <div class="sidebar-brand flex min-w-0 items-center gap-2" :class="!sidebarOpen && 'flex-col gap-1'">
                <a href="{{ url('planner:board_personal') }}" class="flex min-w-0 items-center gap-2.5" :class="!sidebarOpen && 'justify-center'" title="DCPMind — Dream Conversion Process">
                    <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br from-teal-600 to-slate-800 text-[10px] font-black tracking-tight text-white shadow-md shadow-teal-800/20">
                        DCP
                    </div>
                    <div x-show="sidebarOpen" x-cloak class="min-w-0">
                        <p class="text-sm font-semibold tracking-tight text-stone-900">DCPMind</p>
                        <p class="text-[10px] text-stone-600">Dream Conversion · Mind Tool</p>
                    </div>
                </a>
                <button type="button"
                        data-sidebar-toggle
                        @click="toggleSidebar()"
                        class="inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-md border border-stone-300/80 bg-white/70 text-stone-600 transition hover:bg-white hover:text-indigo-700"
                        :title="sidebarOpen ? 'Collapse sidebar' : 'Expand sidebar'">
                    <svg class="h-3.5 w-3.5 transition-transform" :class="sidebarOpen ? '' : 'rotate-180'" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                </button>
            </div>
        </div>

        <nav class="flex-1 space-y-0.5 overflow-y-auto p-2.5">
            <div x-show="sidebarOpen"
                 x-cloak
                 x-data="{
                     open: localStorage.getItem('encryptionNoticeDismissed') !== '1',
                     dismiss() {
                         this.open = false;
                         localStorage.setItem('encryptionNoticeDismissed', '1');
                     }
                 }">
                <div x-show="open" x-cloak
                     class="mb-2 rounded-lg border border-emerald-700/20 bg-emerald-50/90 px-2.5 py-2 shadow-sm shadow-emerald-900/5">
                    <div class="flex items-start gap-2">
                        <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-md bg-emerald-600/15 text-emerald-800" aria-hidden="true">
                            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                        </span>
                        <div class="min-w-0 flex-1">
                            <p class="text-[10px] font-semibold uppercase tracking-wide text-emerald-900">Encrypted tasks</p>
                            <p class="mt-0.5 text-[10px] leading-snug text-emerald-950/80">Your task titles are encrypted at rest for privacy.</p>
                        </div>
                        <button type="button"
                                @click="dismiss()"
                                class="shrink-0 rounded p-0.5 text-emerald-800/70 transition hover:bg-emerald-600/10 hover:text-emerald-950"
                                title="Dismiss"
                                aria-label="Dismiss encryption notice">
                            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                        </button>
                    </div>
                </div>
            </div>

            <p x-show="sidebarOpen" x-cloak class="mb-1.5 px-2 text-[9px] font-semibold uppercase tracking-wider text-indigo-900/80">Workspace</p>
            <a href="{{ url('planner:board_personal') }}" title="Personal workspace"
               class="flex items-center gap-2 rounded-lg px-2 py-1.5 text-xs font-medium transition
                      {% if not current_team %}bg-indigo-500/20 text-indigo-950 ring-1 ring-indigo-400/55{% else %}text-stone-800 hover:bg-stone-400/30{% endif %}">
                <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-md bg-stone-400/45 text-xs font-semibold text-stone-900">Me</span>
                <span x-show="sidebarOpen" x-cloak>Personal</span>
            </a>

            <div x-show="sidebarOpen" x-cloak class="px-2 pt-2.5">
                <p class="text-[9px] font-semibold uppercase tracking-wider text-fuchsia-900/80">My tasks</p>
            </div>
            <div id="sidebar-my-tasks"
                 x-show="sidebarOpen"
                 x-cloak
                 class="space-y-0.5"
                 {% if sidebar_my_tasks_url is defined and sidebar_my_tasks_url %}
                 hx-get="{{ sidebar_my_tasks_url }}"
                 hx-trigger="refreshMyTasks from:body"
                 hx-swap="innerHTML swap:0ms settle:0ms"
                 {% endif %}>
            {% include 'partials/sidebar_my_tasks_list.jinja' %}
            </div>

            <div class="flex items-center justify-between px-2 pt-2.5">
                <p x-show="sidebarOpen" x-cloak class="text-[9px] font-semibold uppercase tracking-wider text-violet-900/80">My Team Mindmap</p>
                <button type="button" @click="teamModalOpen = true" title="Create team"
                        class="text-[10px] font-semibold text-indigo-800 hover:text-indigo-950"
                        :class="!sidebarOpen && 'mx-auto flex h-7 w-7 items-center justify-center rounded-md bg-indigo-500/15'">
                    <span x-show="sidebarOpen" x-cloak>+ New</span>
                    <span x-show="!sidebarOpen" x-cloak class="text-sm leading-none">+</span>
                </button>
            </div>

            {% for m in my_team_memberships %}
            <div class="sidebar-team-row group flex items-center gap-1 rounded-lg px-1.5 py-0.5 text-xs font-medium transition
                      {% if current_team and current_team.id == m.team.id %}bg-indigo-500/20 text-indigo-950 ring-1 ring-indigo-400/50{% else %}text-stone-800 hover:bg-stone-400/30{% endif %}">
            <a href="{{ url('planner:board_team', team_slug=m.team.slug) }}"
               title="{{ m.team.name }}"
               class="flex min-w-0 flex-1 items-center gap-1.5 rounded-lg px-1 py-0.5">
                <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-md text-[10px] font-bold
                    {% if m.team.sidebar_color == 'red' %}bg-red-100 text-red-600
                    {% elif m.team.sidebar_color == 'orange' %}bg-orange-100 text-orange-600
                    {% elif m.team.sidebar_color == 'green' %}bg-green-100 text-green-600
                    {% elif m.team.sidebar_color == 'purple' %}bg-purple-100 text-purple-600
                    {% else %}bg-blue-100 text-blue-600{% endif %}">{{ (m.team.name[0] if m.team.name else '?')|upper }}</span>
                <span data-team-pct="{{ m.team_id }}" x-show="sidebarOpen" x-cloak class="ml-1 shrink-0 rounded-full border px-1.5 py-0.5 text-[9px] font-bold
                    {% if m.done_pct >= 60 %}
                        border-emerald-200 bg-emerald-50 text-emerald-700
                    {% elif m.done_pct < 30 %}
                        border-rose-200 bg-rose-50 text-rose-700
                    {% elif m.done_pct < 50 %}
                        border-amber-200 bg-amber-50 text-amber-700
                    {% else %}
                        border-slate-200 bg-slate-50 text-slate-600
                    {% endif %}">{{ m.done_pct }}%</span>
                <span x-show="sidebarOpen" x-cloak class="truncate text-[11px]">{{ m.team.name }}</span>
                {% if m.is_pinned %}
                <span x-show="sidebarOpen" x-cloak class="ml-auto text-[10px] text-amber-600">📌</span>
                {% elif m.is_owner %}
                <span x-show="sidebarOpen" x-cloak class="ml-auto shrink-0 text-[9px] text-stone-600">Owner</span>
                {% endif %}
            </a>
                <div x-show="sidebarOpen" x-cloak class="flex items-center gap-1">
                    <form action="{{ url('planner:archive_team_mindmap', team_slug=m.team.slug) }}" method="post"
                          onsubmit="return window.confirm('Archive this team mindmap for focus mode?')">
                        <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
                        <button type="submit" class="text-xs leading-none text-stone-600 hover:text-amber-800" title="Archive team mindmap">🗂</button>
                    </form>
                    <form action="{{ url('teams:sidebar_settings', team_slug=m.team.slug) }}" method="post" class="flex items-center gap-1">
                    <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
                    <input type="hidden" name="sidebar_color"
                           value="{% if m.team.sidebar_color == 'green' %}red{% elif m.team.sidebar_color == 'red' %}blue{% else %}green{% endif %}">
                    <button type="submit"
                            class="h-3 w-3 rounded-full {% if m.team.sidebar_color == 'red' %}bg-red-500{% elif m.team.sidebar_color == 'blue' %}bg-blue-500{% else %}bg-green-500{% endif %}"
                            title="Toggle team color"></button>
                    </form>
                    <form action="{{ url('teams:sidebar_settings', team_slug=m.team.slug) }}" method="post">
                        <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
                        {% if m.is_pinned %}
                        <button type="submit" name="pin_action" value="unpin" class="text-xs leading-none" title="Unpin team">📌</button>
                        {% else %}
                        <button type="submit" name="pin_action" value="pin" class="text-xs leading-none text-stone-600 hover:text-stone-900" title="Pin team">📍</button>
                        {% endif %}
                    </form>
                </div>
            </div>
            {% else %}
            <p x-show="sidebarOpen" x-cloak class="px-2 text-xs text-stone-600">No owned teams yet — create one.</p>
            {% endfor %}

            <p x-show="sidebarOpen" x-cloak class="px-2 pt-2.5 text-[9px] font-semibold uppercase tracking-wider text-cyan-900/80">Others Team Mindmap</p>
            {% for m in other_team_memberships %}
            <div class="sidebar-team-row group flex items-center gap-1 rounded-lg px-1.5 py-0.5 text-xs font-medium transition
                      {% if current_team and current_team.id == m.team.id %}bg-indigo-500/20 text-indigo-950 ring-1 ring-indigo-400/50{% else %}text-stone-800 hover:bg-stone-400/30{% endif %}">
            <a href="{{ url('planner:board_team', team_slug=m.team.slug) }}"
               title="{{ m.team.name }}"
               class="flex min-w-0 flex-1 items-center gap-1.5 rounded-lg px-1 py-0.5">
                <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-md text-[10px] font-bold
                    {% if m.team.sidebar_color == 'red' %}bg-red-100 text-red-600
                    {% elif m.team.sidebar_color == 'orange' %}bg-orange-100 text-orange-600
                    {% elif m.team.sidebar_color == 'green' %}bg-green-100 text-green-600
                    {% elif m.team.sidebar_color == 'purple' %}bg-purple-100 text-purple-600
                    {% else %}bg-blue-100 text-blue-600{% endif %}">{{ (m.team.name[0] if m.team.name else '?')|upper }}</span>
                <span data-team-pct="{{ m.team_id }}" x-show="sidebarOpen" x-cloak class="ml-1 shrink-0 rounded-full border px-1.5 py-0.5 text-[9px] font-bold
                    {% if m.done_pct >= 60 %}
                        border-emerald-200 bg-emerald-50 text-emerald-700
                    {% elif m.done_pct < 30 %}
                        border-rose-200 bg-rose-50 text-rose-700
                    {% elif m.done_pct < 50 %}
                        border-amber-200 bg-amber-50 text-amber-700
                    {% else %}
                        border-slate-200 bg-slate-50 text-slate-600
                    {% endif %}">{{ m.done_pct }}%</span>
                <span x-show="sidebarOpen" x-cloak class="truncate text-[11px]">{{ m.team.name }}</span>
            </a>
                <div x-show="sidebarOpen" x-cloak class="flex items-center gap-1">
                    <form action="{{ url('planner:archive_team_mindmap', team_slug=m.team.slug) }}" method="post"
                          onsubmit="return window.confirm('Archive this team mindmap for focus mode?')">
                        <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
                        <button type="submit" class="text-xs leading-none text-stone-600 hover:text-amber-800" title="Archive team mindmap">🗂</button>
                    </form>
                    <form action="{{ url('teams:sidebar_settings', team_slug=m.team.slug) }}" method="post" class="flex items-center gap-1">
                    <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
                    <input type="hidden" name="sidebar_color"
                           value="{% if m.team.sidebar_color == 'green' %}red{% elif m.team.sidebar_color == 'red' %}blue{% else %}green{% endif %}">
                    <button type="submit"
                            class="h-3 w-3 rounded-full {% if m.team.sidebar_color == 'red' %}bg-red-500{% elif m.team.sidebar_color == 'blue' %}bg-blue-500{% else %}bg-green-500{% endif %}"
                            title="Toggle team color"></button>
                    </form>
                    <form action="{{ url('teams:sidebar_settings', team_slug=m.team.slug) }}" method="post">
                        <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
                        {% if m.is_pinned %}
                        <button type="submit" name="pin_action" value="unpin" class="text-xs leading-none" title="Unpin team">📌</button>
                        {% else %}
                        <button type="submit" name="pin_action" value="pin" class="text-xs leading-none text-stone-600 hover:text-stone-900" title="Pin team">📍</button>
                        {% endif %}
                    </form>
                </div>
            </div>
            {% else %}
            <p x-show="sidebarOpen" x-cloak class="px-2 text-xs text-stone-600">No shared teams yet.</p>
            {% endfor %}

            {% if ui.sidebar.projects or ui.sidebar.archived_projects or ui.sidebar.gantt or ui.sidebar.milestones or ui.sidebar.calendar or ui.sidebar.time_tracking or ui.sidebar.reports or ui.sidebar.resources %}
            <p x-show="sidebarOpen" x-cloak class="mb-1.5 px-2 pt-3 text-[9px] font-semibold uppercase tracking-wider text-teal-900/80">Projects</p>
            {% if ui.sidebar.projects %}
            <a href="{{ url('projects:list') }}" title="All Projects"
               class="flex items-center gap-2 rounded-lg px-2 py-1.5 text-xs font-medium transition
                      {% if request.path.startswith('/projects/') and not request.path.startswith('/projects/archived') %}bg-indigo-500/20 text-indigo-950 ring-1 ring-indigo-400/55{% else %}text-stone-800 hover:bg-stone-400/30{% endif %}">
                <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-md bg-teal-500/20 text-xs font-bold text-teal-800">P</span>
                <span x-show="sidebarOpen" x-cloak>All Projects</span>
            </a>
            {% endif %}
            {% if ui.sidebar.archived_projects %}
            <a href="{{ url('projects:archived') }}" title="Archived Projects"
               class="flex items-center gap-2 rounded-lg px-2 py-1.5 text-xs font-medium transition
                      {% if request.path.startswith('/projects/archived') %}bg-indigo-500/20 text-indigo-950 ring-1 ring-indigo-400/55{% else %}text-stone-800 hover:bg-stone-400/30{% endif %}">
                <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-md bg-slate-400/20 text-xs font-bold text-slate-600">🗂</span>
                <span x-show="sidebarOpen" x-cloak>Archived</span>
            </a>
            {% endif %}
            {% if ui.sidebar.gantt %}
            <a href="{{ url('gantt:project_list') }}" title="Gantt Charts"
               class="flex items-center gap-2 rounded-lg px-2 py-1.5 text-xs font-medium transition
                      {% if request.path.startswith('/gantt/') %}bg-indigo-500/20 text-indigo-950 ring-1 ring-indigo-400/55{% else %}text-stone-800 hover:bg-stone-400/30{% endif %}">
                <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-md bg-orange-500/15 text-xs font-bold text-orange-800">G</span>
                <span x-show="sidebarOpen" x-cloak>Gantt Charts</span>
            </a>
            {% endif %}
            {% if ui.sidebar.milestones %}
            <a href="{{ url('milestones:all') }}" title="Milestones"
               class="flex items-center gap-2 rounded-lg px-2 py-1.5 text-xs font-medium transition
                      {% if request.path.startswith('/milestones/') %}bg-indigo-500/20 text-indigo-950 ring-1 ring-indigo-400/55{% else %}text-stone-800 hover:bg-stone-400/30{% endif %}">
                <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-md bg-purple-500/15 text-xs font-bold text-purple-800">◆</span>
                <span x-show="sidebarOpen" x-cloak>Milestones</span>
            </a>
            {% endif %}
            {% if ui.sidebar.calendar %}
            <a href="{{ url('calendar_app:month') }}" title="Calendar"
               class="flex items-center gap-2 rounded-lg px-2 py-1.5 text-xs font-medium transition
                      {% if request.path.startswith('/calendar/') %}bg-indigo-500/20 text-indigo-950 ring-1 ring-indigo-400/55{% else %}text-stone-800 hover:bg-stone-400/30{% endif %}">
                <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-md bg-sky-500/15 text-xs font-bold text-sky-800">📅</span>
                <span x-show="sidebarOpen" x-cloak>Calendar</span>
            </a>
            {% endif %}
            {% if ui.sidebar.time_tracking %}
            <a href="{{ url('timetracking:index') }}" title="Time Tracking"
               class="flex items-center gap-2 rounded-lg px-2 py-1.5 text-xs font-medium transition
                      {% if request.path.startswith('/time/') %}bg-indigo-500/20 text-indigo-950 ring-1 ring-indigo-400/55{% else %}text-stone-800 hover:bg-stone-400/30{% endif %}">
                <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-md bg-green-500/15 text-xs font-bold text-green-800">⏱</span>
                <span x-show="sidebarOpen" x-cloak>Time Tracking</span>
            </a>
            {% endif %}
            {% if ui.sidebar.reports %}
            <a href="{{ url('reports:dashboard') }}" title="Reports"
               class="flex items-center gap-2 rounded-lg px-2 py-1.5 text-xs font-medium transition
                      {% if request.path.startswith('/reports/') %}bg-indigo-500/20 text-indigo-950 ring-1 ring-indigo-400/55{% else %}text-stone-800 hover:bg-stone-400/30{% endif %}">
                <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-md bg-rose-500/15 text-xs font-bold text-rose-800">📊</span>
                <span x-show="sidebarOpen" x-cloak>Reports</span>
            </a>
            {% endif %}
            {% if ui.sidebar.resources %}
            <a href="{{ url('resources:dashboard') }}" title="Resources"
               class="flex items-center gap-2 rounded-lg px-2 py-1.5 text-xs font-medium transition
                      {% if request.path.startswith('/resources/') %}bg-indigo-500/20 text-indigo-950 ring-1 ring-indigo-400/55{% else %}text-stone-800 hover:bg-stone-400/30{% endif %}">
                <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-md bg-violet-500/15 text-xs font-bold text-violet-800">👥</span>
                <span x-show="sidebarOpen" x-cloak>Resources</span>
            </a>
            {% endif %}
            {% endif %}

            <p x-show="sidebarOpen" x-cloak class="mb-1.5 px-2 pt-3 text-[9px] font-semibold uppercase tracking-wider text-emerald-900/80">Account</p>
            <a href="{{ url('billing:overview') }}" title="Billing"
               class="flex items-center gap-2 rounded-lg px-2 py-1.5 text-xs font-medium text-stone-800 transition hover:bg-stone-400/30">
                <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-md bg-emerald-600/15 text-xs font-bold text-emerald-900">$</span>
                <span x-show="sidebarOpen" x-cloak>Billing</span>
                {% if account_profile and account_profile.trial_active %}
                <span x-show="sidebarOpen" x-cloak class="ml-auto rounded-full bg-amber-500/25 px-2 py-0.5 text-[9px] font-bold text-amber-900">Trial</span>
                {% endif %}
            </a>
        </nav>

        <div class="space-y-2 border-t border-[#d9cfc3]/90 bg-[#efe8df]/90 p-2">
            <div class="flex items-center gap-2 rounded-lg bg-white/55 px-2 py-2 ring-1 ring-stone-400/35" :class="!sidebarOpen && 'justify-center'">
                <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-indigo-100 text-xs font-bold uppercase text-indigo-800" title="{{ user.username }}">{{ user.username[0] }}</div>
                <div x-show="sidebarOpen" x-cloak class="min-w-0 flex-1">
                    <p class="truncate text-xs font-medium text-stone-900">{{ user.username }}</p>
                    <form action="{{ url('users:logout') }}" method="post" class="inline">
                        <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
                        <button type="submit" class="text-[10px] text-rose-700 hover:underline">Log out</button>
                    </form>
                </div>
            </div>
        </div>
    </aside>

    <!-- Main -->
    <div class="flex min-w-0 flex-1 flex-col">
        {% block main %}{% endblock %}
    </div>
</div>

{% block modals %}{% endblock %}

<!-- Task Detail Slide Panel -->
<div x-cloak x-show="taskDetailOpen" @click="taskDetailOpen = false"
     x-transition:enter="transition-opacity ease-out duration-200"
     x-transition:enter-start="opacity-0"
     x-transition:enter-end="opacity-100"
     x-transition:leave="transition-opacity ease-in duration-150"
     x-transition:leave-start="opacity-100"
     x-transition:leave-end="opacity-0"
     class="fixed inset-0 z-40 bg-black/30 backdrop-blur-[1px]"></div>

<div x-cloak x-show="taskDetailOpen"
     x-transition:enter="transition ease-out duration-300"
     x-transition:enter-start="translate-x-full"
     x-transition:enter-end="translate-x-0"
     x-transition:leave="transition ease-in duration-200"
     x-transition:leave-start="translate-x-0"
     x-transition:leave-end="translate-x-full"
     class="fixed inset-y-0 right-0 z-50 flex w-[480px] max-w-[95vw] flex-col bg-white shadow-2xl border-l border-slate-200">
    <div id="task-detail-content" class="flex flex-col flex-1 min-h-0 overflow-hidden">
        <div class="flex items-center justify-between px-5 py-4 border-b border-slate-200">
            <p class="text-sm font-semibold text-slate-500">Task Details</p>
            <button type="button" @click="taskDetailOpen = false"
                    class="rounded-md p-1 text-slate-400 hover:bg-slate-100 hover:text-slate-600 transition">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>
    </div>
</div>
</body>
</html>
