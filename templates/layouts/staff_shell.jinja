<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="{{ csrf_token }}">
    <title>{% block title %}Operations{% endblock %} · nTarque</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Inter', 'system-ui', 'sans-serif'] },
                },
            },
        };
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>body { font-family: Inter, system-ui, sans-serif; }</style>
</head>
<body class="min-h-screen bg-slate-950 text-slate-100 antialiased">
<div class="flex min-h-screen">
    <aside class="flex w-56 shrink-0 flex-col border-r border-slate-800 bg-slate-900/80">
        <div class="border-b border-slate-800 p-4">
            <p class="text-[10px] font-semibold uppercase tracking-widest text-indigo-400">nTarque</p>
            <p class="text-sm font-bold text-white">Operations</p>
        </div>
        <nav class="flex flex-1 flex-col gap-0.5 p-2">
            <a href="{{ url('staff_dashboard:dashboard') }}"
               class="rounded-lg px-3 py-2 text-sm font-medium text-white bg-slate-800 ring-1 ring-slate-700">Dashboard</a>
            <a href="{{ url('admin:index') }}" target="_blank" rel="noopener"
               class="rounded-lg px-3 py-2 text-sm font-medium text-slate-400 transition hover:bg-slate-800 hover:text-white">Classic admin (/sd/) ↗</a>
            <a href="{{ url('planner:board_personal') }}"
               class="rounded-lg px-3 py-2 text-sm font-medium text-slate-400 transition hover:bg-slate-800 hover:text-white">App home</a>
        </nav>
        <div class="border-t border-slate-800 p-3 text-xs text-slate-500">
            <p class="truncate font-medium text-slate-400">{{ user.username }}</p>
            <form action="{{ url('users:logout') }}" method="post" class="mt-2">
                <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
                <button type="submit" class="text-rose-400 hover:underline">Log out</button>
            </form>
        </div>
    </aside>
    <div class="min-w-0 flex-1 overflow-auto">
        {% block main %}{% endblock %}
    </div>
</div>
</body>
</html>
