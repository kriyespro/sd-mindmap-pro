<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="{{ csrf_token }}">
    <title>{% block title %}Mission Control{% endblock %} · DCPMind</title>
    <link rel="stylesheet" href="{{ static('css/tailwind.css') }}">
    <script src="https://unpkg.com/htmx.org@1.9.10/dist/htmx.min.js"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.8/dist/cdn.min.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --mc-cream: #f3efe6;
            --mc-paper: #faf7f0;
            --mc-ink: #1c2421;
            --mc-muted: #5c675f;
            --mc-line: #d9d2c4;
            --mc-accent: #0d5c4d;
            --mc-accent-soft: #e2efe9;
            --mc-warn: #8a5a12;
            --mc-warn-soft: #f5ebd4;
            --mc-danger: #8b3a32;
            --mc-danger-soft: #f3e4e1;
            --mc-money: #146b4a;
        }
        body { font-family: "IBM Plex Sans", system-ui, sans-serif; background: var(--mc-cream); color: var(--mc-ink); }
        [x-cloak] { display: none !important; }
        .mc-shell { background:
            radial-gradient(ellipse 80% 50% at 0% 0%, rgba(13,92,77,.06), transparent 50%),
            linear-gradient(180deg, #f7f3ea 0%, var(--mc-cream) 40%, #efe9dc 100%); }
        .mc-aside { background: var(--mc-paper); border-color: var(--mc-line); }
        .mc-nav-a { color: var(--mc-muted); }
        .mc-nav-a:hover { background: #efe9dc; color: var(--mc-ink); }
        .mc-nav-on { background: var(--mc-accent-soft); color: var(--mc-accent); font-weight: 600; }
        .mc-card { background: var(--mc-paper); border: 1px solid var(--mc-line); border-radius: 0.5rem; }
        .mc-kpi { background: var(--mc-paper); border: 1px solid var(--mc-line); border-radius: 0.375rem; padding: 0.5rem 0.65rem; }
        .mc-kpi-money { border-color: #b7d4c6; background: #f0f7f3; }
        .mc-kpi-warn { border-color: #e2cfa3; background: var(--mc-warn-soft); }
        .mc-btn { border-radius: 0.375rem; font-size: 0.6875rem; font-weight: 600; padding: 0.3rem 0.55rem; }
        .mc-btn-primary { background: var(--mc-accent); color: #fff; }
        .mc-btn-primary:hover { background: #0a4a3e; }
        .mc-btn-ghost { border: 1px solid var(--mc-line); background: var(--mc-paper); color: var(--mc-ink); }
        .mc-btn-ghost:hover { background: #efe9dc; }
        .mc-btn-money { background: var(--mc-money); color: #fff; }
        .mc-btn-money:hover { background: #0f573c; }
        .mc-input { border: 1px solid var(--mc-line); background: #fff; color: var(--mc-ink); border-radius: 0.375rem; font-size: 0.75rem; padding: 0.35rem 0.5rem; }
        .mc-input:focus { outline: none; border-color: var(--mc-accent); box-shadow: 0 0 0 2px rgba(13,92,77,.15); }
        .mc-chip { border: 1px solid var(--mc-line); background: var(--mc-paper); color: var(--mc-muted); border-radius: 0.375rem; font-size: 0.6875rem; font-weight: 600; padding: 0.25rem 0.5rem; }
        .mc-chip-on { background: var(--mc-accent); border-color: var(--mc-accent); color: #fff; }
        .mc-table th { color: var(--mc-muted); font-size: 0.625rem; letter-spacing: .04em; text-transform: uppercase; }
        .mc-table td { border-color: var(--mc-line); }
        .mc-link { color: var(--mc-accent); font-weight: 600; }
        .mc-link:hover { text-decoration: underline; }
        .mc-bar-track { background: #e8e1d4; height: 0.35rem; border-radius: 999px; overflow: hidden; }
        .mc-msg { background: var(--mc-warn-soft); border-bottom: 1px solid #e2cfa3; color: var(--mc-warn); }
        .mc-attn {
            display: grid;
            grid-template-columns: 1fr;
            gap: 0.75rem;
        }
        @media (min-width: 640px) {
            .mc-attn { grid-template-columns: 1fr 1fr; }
        }
        .mc-attn-col {
            min-width: 0;
            display: flex;
            flex-direction: column;
            gap: 0.35rem;
        }
        .mc-attn-head {
            display: flex;
            align-items: baseline;
            justify-content: space-between;
            gap: 0.5rem;
            margin: 0;
        }
        .mc-attn-list {
            list-style: none;
            margin: 0;
            padding: 0;
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
        }
        .mc-attn-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.5rem;
            min-width: 0;
            border: 1px solid var(--mc-line);
            background: var(--mc-paper);
            border-radius: 0.25rem;
            padding: 0.3rem 0.45rem;
            font-size: 11px;
            text-decoration: none;
            color: inherit;
        }
        .mc-attn-row:hover { opacity: 0.92; }
        .mc-attn-row.danger {
            border-color: #e0b8b2;
            background: var(--mc-danger-soft);
        }
        .mc-attn-name {
            min-width: 0;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            font-weight: 600;
        }
        .mc-attn-meta {
            flex-shrink: 0;
            font-variant-numeric: tabular-nums;
            color: var(--mc-muted);
        }
        .mc-sparks {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.5rem;
            margin-top: 0.75rem;
            min-width: 0;
        }
        .mc-spark-col { min-width: 0; }
        .mc-main-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 0.75rem;
        }
        @media (min-width: 1024px) {
            .mc-main-grid { grid-template-columns: minmax(0, 5fr) minmax(0, 7fr); }
        }
        .mc-main-grid > * { min-width: 0; }
        .mc-pulse-line {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            gap: 0.35rem;
            font-size: 11px;
            line-height: 1.2;
        }
        .mc-pulse-label {
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: var(--mc-muted);
            margin-right: 0.15rem;
        }
        .mc-pulse-chip {
            display: inline-flex;
            align-items: baseline;
            gap: 0.28rem;
            flex-wrap: nowrap;
            white-space: nowrap;
            border: 1px solid var(--mc-line);
            background: var(--mc-paper);
            border-radius: 0.25rem;
            padding: 0.2rem 0.45rem;
            color: var(--mc-ink);
        }
        .mc-pulse-chip b { font-weight: 700; }
        .mc-pulse-chip i {
            font-style: normal;
            color: var(--mc-muted);
            font-size: 10px;
        }
        .mc-pulse-chip.money {
            border-color: #b7d4c6;
            background: #f0f7f3;
            color: var(--mc-money);
        }
        .mc-pulse-chip.money i { color: #3d7a5f; }
        .mc-pulse-chip.warn {
            border-color: #e2cfa3;
            background: var(--mc-warn-soft);
            color: var(--mc-warn);
        }
        .mc-pulse-chip.warn i { color: #8a6a2e; }
    </style>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.body.addEventListener('htmx:configRequest', function (e) {
                var meta = document.querySelector('meta[name=csrf-token]');
                if (meta && meta.content) e.detail.headers['X-CSRFToken'] = meta.content;
            });
        });
    </script>
</head>
<body class="mc-shell min-h-screen antialiased">
<div class="flex min-h-screen">
    <aside class="mc-aside flex w-44 shrink-0 flex-col border-r">
        <div class="border-b px-3 py-2.5" style="border-color: var(--mc-line)">
            <p class="text-[9px] font-semibold uppercase tracking-[0.14em]" style="color: var(--mc-accent)">DCPMind</p>
            <p class="text-[13px] font-bold leading-tight" style="color: var(--mc-ink)">Mission Control</p>
        </div>
        <nav class="flex flex-1 flex-col gap-0.5 p-1.5 text-[12px]">
            <a href="{{ url('staff_dashboard:dashboard') }}"
               class="mc-nav-a rounded px-2 py-1.5 {% if nav_active == 'dashboard' %}mc-nav-on{% endif %}">Command</a>
            <a href="{{ url('staff_dashboard:users') }}"
               class="mc-nav-a rounded px-2 py-1.5 {% if nav_active == 'users' %}mc-nav-on{% endif %}">People</a>
            <div class="my-1.5 border-t" style="border-color: var(--mc-line)"></div>
            <a href="{{ url('admin:billing_payment_add') }}" class="mc-nav-a rounded px-2 py-1.5" style="color: var(--mc-money)">+ Payment</a>
            <a href="{{ url('admin:index') }}" target="_blank" rel="noopener" class="mc-nav-a rounded px-2 py-1.5">/sd/ admin ↗</a>
            <a href="{{ url('planner:board_personal') }}" class="mc-nav-a rounded px-2 py-1.5">Product</a>
        </nav>
        <div class="border-t px-2.5 py-2 text-[11px]" style="border-color: var(--mc-line); color: var(--mc-muted)">
            <p class="truncate font-medium" style="color: var(--mc-ink)">{{ user.username }}</p>
            <form action="{{ url('users:logout') }}" method="post" class="mt-1">
                <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
                <button type="submit" class="hover:underline" style="color: var(--mc-danger)">Log out</button>
            </form>
        </div>
    </aside>
    <div class="min-w-0 flex-1 overflow-auto">
        {% if messages %}
        <div class="mc-msg px-4 py-1.5 text-[11px]">
            {% for message in messages %}<p>{{ message }}</p>{% endfor %}
        </div>
        {% endif %}
        {% block main %}{% endblock %}
    </div>
</div>
</body>
</html>
