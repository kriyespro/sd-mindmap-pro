{# Full task detail panel content – loaded via HTMX into #task-detail-content #}
{% set priority_colors = {
    'critical': 'bg-red-100 text-red-700 border-red-200',
    'high':     'bg-orange-100 text-orange-700 border-orange-200',
    'medium':   'bg-indigo-50 text-indigo-700 border-indigo-200',
    'low':      'bg-slate-100 text-slate-600 border-slate-200',
} %}
{% set status_colors = {
    'todo':        'bg-slate-100 text-slate-600',
    'in_progress': 'bg-blue-100 text-blue-700',
    'review':      'bg-purple-100 text-purple-700',
    'testing':     'bg-orange-100 text-orange-700',
    'done':        'bg-green-100 text-green-700',
} %}

<!-- Header -->
<div class="flex items-start justify-between gap-3 border-b border-slate-200 px-5 py-4">
    <div class="min-w-0 flex-1">
        <p class="text-[10px] font-semibold uppercase tracking-wider text-slate-400 mb-1">
            {% if task.project %}{{ task.project.name }}{% else %}Personal Task{% endif %}
        </p>
        <h2 class="text-base font-bold leading-snug text-slate-900 break-words">{{ task.title_plain }}</h2>
    </div>
    <button type="button" @click="taskDetailOpen = false"
            class="shrink-0 rounded-md p-1 text-slate-400 hover:bg-slate-100 hover:text-slate-600 transition">
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
    </button>
</div>

<!-- Meta row -->
<div class="flex flex-wrap gap-2 border-b border-slate-100 px-5 py-3">
    <span class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-[11px] font-semibold {{ priority_colors.get(task.priority, 'bg-slate-100 text-slate-600 border-slate-200') }}">
        {{ task.priority|title }}
    </span>
    <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-[11px] font-semibold {{ status_colors.get(task.status, 'bg-slate-100 text-slate-600') }}">
        {{ task.status.replace('_', ' ')|title }}
    </span>
    {% if task.due_date %}
    <span class="inline-flex items-center gap-1 rounded-full bg-amber-50 px-2.5 py-0.5 text-[11px] font-semibold text-amber-700">
        <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        {{ task.due_date.strftime('%b %d, %Y') }}
    </span>
    {% endif %}
    {% if task.assignee %}
    <span class="inline-flex items-center gap-1 rounded-full bg-teal-50 px-2.5 py-0.5 text-[11px] font-semibold text-teal-700">
        <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
        </svg>
        {{ task.assignee.username }}
    </span>
    {% endif %}
    {% if task.estimated_hours %}
    <span class="inline-flex items-center gap-1 rounded-full bg-violet-50 px-2.5 py-0.5 text-[11px] font-semibold text-violet-700">
        <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        {{ task.estimated_hours }}h est.
    </span>
    {% endif %}
</div>

<!-- Tabs -->
<div x-data="{ tab: 'detail' }" class="flex flex-col flex-1 min-h-0">
    <div class="flex border-b border-slate-200 px-5">
        <button type="button" @click="tab='detail'"
                :class="tab==='detail' ? 'border-b-2 border-indigo-600 text-indigo-700 font-semibold' : 'text-slate-500 hover:text-slate-700'"
                class="mr-5 py-2.5 text-xs transition">Details</button>
        <button type="button" @click="tab='checklist'"
                :class="tab==='checklist' ? 'border-b-2 border-indigo-600 text-indigo-700 font-semibold' : 'text-slate-500 hover:text-slate-700'"
                class="mr-5 py-2.5 text-xs transition">
            Checklist
            {% if total_count > 0 %}
            <span class="ml-1 rounded-full bg-slate-200 px-1.5 py-0.5 text-[10px] font-bold text-slate-700">{{ done_count }}/{{ total_count }}</span>
            {% endif %}
        </button>
        <button type="button" @click="tab='comments'"
                :class="tab==='comments' ? 'border-b-2 border-indigo-600 text-indigo-700 font-semibold' : 'text-slate-500 hover:text-slate-700'"
                class="mr-5 py-2.5 text-xs transition">
            Comments
            {% if comments|length > 0 %}
            <span class="ml-1 rounded-full bg-slate-200 px-1.5 py-0.5 text-[10px] font-bold text-slate-700">{{ comments|length }}</span>
            {% endif %}
        </button>
    </div>

    <!-- Detail tab -->
    <div x-show="tab==='detail'" class="flex-1 overflow-y-auto p-5 space-y-4">
        {% if task.description %}
        <div>
            <p class="mb-1.5 text-[10px] font-semibold uppercase tracking-wider text-slate-400">Description</p>
            <p class="text-sm text-slate-700 leading-relaxed whitespace-pre-wrap">{{ task.description }}</p>
        </div>
        {% else %}
        <p class="text-xs text-slate-400 italic">No description.</p>
        {% endif %}

        {% if task.tags_list %}
        <div>
            <p class="mb-1.5 text-[10px] font-semibold uppercase tracking-wider text-slate-400">Tags</p>
            <div class="flex flex-wrap gap-1.5">
                {% for tag in task.tags_list %}
                <span class="rounded-md bg-indigo-50 px-2 py-0.5 text-[11px] font-medium text-indigo-700 border border-indigo-100">{{ tag }}</span>
                {% endfor %}
            </div>
        </div>
        {% endif %}

        <div class="grid grid-cols-2 gap-4 pt-2">
            {% if task.start_date %}
            <div>
                <p class="text-[10px] font-semibold uppercase tracking-wider text-slate-400">Start Date</p>
                <p class="mt-0.5 text-sm font-medium text-slate-700">{{ task.start_date.strftime('%b %d, %Y') }}</p>
            </div>
            {% endif %}
            {% if task.due_date %}
            <div>
                <p class="text-[10px] font-semibold uppercase tracking-wider text-slate-400">Due Date</p>
                <p class="mt-0.5 text-sm font-medium text-slate-700">{{ task.due_date.strftime('%b %d, %Y') }}</p>
            </div>
            {% endif %}
            <div>
                <p class="text-[10px] font-semibold uppercase tracking-wider text-slate-400">Created</p>
                <p class="mt-0.5 text-sm font-medium text-slate-700">{{ task.created_at.strftime('%b %d, %Y') }}</p>
            </div>
            <div>
                <p class="text-[10px] font-semibold uppercase tracking-wider text-slate-400">Author</p>
                <p class="mt-0.5 text-sm font-medium text-slate-700">{{ task.author.username }}</p>
            </div>
        </div>

        {% if task.is_completed %}
        <div class="flex items-center gap-2 rounded-lg bg-green-50 border border-green-200 px-3 py-2">
            <svg class="h-4 w-4 text-green-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            <span class="text-xs font-semibold text-green-700">Task completed</span>
        </div>
        {% endif %}
    </div>

    <!-- Checklist tab -->
    <div x-show="tab==='checklist'" x-cloak class="flex-1 overflow-y-auto p-5">
        <div id="task-checklist-{{ task.id }}">
            {% include 'partials/_task_checklist.jinja' %}
        </div>
    </div>

    <!-- Comments tab -->
    <div x-show="tab==='comments'" x-cloak class="flex flex-col flex-1 overflow-hidden p-5 gap-3">
        <div id="task-comments-{{ task.id }}" class="flex-1 overflow-y-auto">
            {% include 'partials/_task_comments.jinja' %}
        </div>

        <form hx-post="{{ url('planner:task_comment_create', task_id=task.id) }}"
              hx-target="#task-comments-{{ task.id }}"
              hx-swap="innerHTML"
              hx-on::after-request="this.reset()"
              class="shrink-0 flex gap-2">
            {{ csrf_input }}
            <input type="text" name="body" placeholder="Add a comment…" required
                   class="flex-1 rounded-lg border border-slate-200 px-3 py-2 text-xs focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500">
            <button type="submit"
                    class="rounded-lg bg-indigo-600 px-3 py-2 text-xs font-semibold text-white hover:bg-indigo-700 transition">
                Post
            </button>
        </form>
    </div>
</div>
