{# CEO KPI strip — also HTMX-refreshed #}
<section>
    <h2 class="mb-3 text-xs font-semibold uppercase tracking-wider text-slate-500">Executive pulse</h2>
    <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
        <div class="rounded-xl border border-emerald-900/50 bg-emerald-950/30 p-4 ring-1 ring-emerald-500/10">
            <p class="text-[11px] font-medium text-emerald-400/80">Cash collected</p>
            <p class="mt-1 text-2xl font-bold tabular-nums text-emerald-300">${{ payment_total_display }}</p>
            <p class="mt-1 text-[11px] text-slate-500">Month ${{ revenue_month_display }} · Week ${{ revenue_week_display }} · {{ payment_count }} txn</p>
        </div>
        <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">
            <p class="text-[11px] font-medium text-slate-500">Est. MRR</p>
            <p class="mt-1 text-2xl font-bold tabular-nums text-white">₹{{ mrr_inr }}</p>
            <p class="mt-1 text-[11px] text-slate-500">{{ paid_users }} paid · {{ plan_counts.solo }} starter</p>
        </div>
        <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">
            <p class="text-[11px] font-medium text-slate-500">Growth</p>
            <p class="mt-1 text-2xl font-bold tabular-nums text-indigo-300">+{{ signups_today }} <span class="text-base text-slate-500">today</span></p>
            <p class="mt-1 text-[11px] text-slate-500">Week {{ signups_week }} · Month {{ signups_month }} · {{ user_count }} active</p>
        </div>
        <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">
            <p class="text-[11px] font-medium text-slate-500">Pipeline · trials</p>
            <p class="mt-1 text-2xl font-bold tabular-nums text-amber-300">{{ trials_active }}</p>
            <p class="mt-1 text-[11px] text-slate-500">{{ trials_expired_flag }} expired flag · {{ open_invites }} open invites</p>
        </div>
    </div>
    <div class="mt-3 grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
        <div class="rounded-lg border border-slate-800 bg-slate-900/40 px-4 py-3">
            <p class="text-[10px] uppercase tracking-wide text-slate-500">Teams / seats</p>
            <p class="mt-0.5 text-lg font-bold tabular-nums text-white">{{ teams_total }} <span class="text-sm text-slate-500">/</span> {{ seats_filled }}</p>
        </div>
        <div class="rounded-lg border border-slate-800 bg-slate-900/40 px-4 py-3">
            <p class="text-[10px] uppercase tracking-wide text-slate-500">Open / done tasks</p>
            <p class="mt-0.5 text-lg font-bold tabular-nums text-white">{{ tasks_open }} <span class="text-sm text-slate-500">/</span> {{ tasks_done }}</p>
        </div>
        <div class="rounded-lg border border-slate-800 bg-slate-900/40 px-4 py-3">
            <p class="text-[10px] uppercase tracking-wide text-slate-500">Active projects</p>
            <p class="mt-0.5 text-lg font-bold tabular-nums text-white">{{ projects_active }}</p>
        </div>
        <div class="rounded-lg border border-slate-800 bg-slate-900/40 px-4 py-3">
            <p class="text-[10px] uppercase tracking-wide text-slate-500">Activity (7d notices)</p>
            <p class="mt-0.5 text-lg font-bold tabular-nums text-white">{{ activity_week }}</p>
        </div>
    </div>
</section>
