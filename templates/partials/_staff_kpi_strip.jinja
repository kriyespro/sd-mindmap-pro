{# Pulse — single-line compact chips #}
<section class="mc-pulse">
    <div class="mc-pulse-line">
        <span class="mc-pulse-label">Pulse</span>
        <span class="mc-pulse-chip money"><b>Cash</b> ${{ payment_total_display }} <i>Mo ${{ revenue_month_display }} · Wk ${{ revenue_week_display }}</i></span>
        <span class="mc-pulse-chip"><b>MRR</b> ₹{{ mrr_inr }} <i>{{ paid_users }} paid · ARPU ${{ arpu_month_display }}</i></span>
        <span class="mc-pulse-chip"><b>Convert</b> {{ conversion_pct }}% <i>{{ paid_users }}/{{ paid_users + trials_active }}</i></span>
        <span class="mc-pulse-chip"><b>Growth</b> +{{ signups_today }} today <i>Wk {{ signups_week }} ({% if signups_wow > 0 %}+{% endif %}{{ signups_wow }})</i></span>
        <span class="mc-pulse-chip warn"><b>Trials</b> {{ trials_active }} <i>{{ trials_expired_flag }} exp · {{ open_invites }} inv</i></span>
        <span class="mc-pulse-chip"><b>Accounts</b> {{ user_count }} <i>{{ user_total }} tot · {{ staff_count }} staff</i></span>
        <span class="mc-pulse-chip"><b>Teams</b> {{ teams_total }}/{{ seats_filled }}</span>
        <span class="mc-pulse-chip"><b>Tasks</b> {{ tasks_open }}/{{ tasks_done }}</span>
        <span class="mc-pulse-chip"><b>Projects</b> {{ projects_active }}</span>
        <span class="mc-pulse-chip"><b>Act 7d</b> {{ activity_week }}</span>
    </div>
</section>
