{# Compact cream KPI strip #}
<section>
    <div class="mb-1.5 flex items-baseline justify-between">
        <h2 class="text-[10px] font-semibold uppercase tracking-wider" style="color: var(--mc-muted)">Pulse</h2>
    </div>
    <div class="grid grid-cols-2 gap-1.5 md:grid-cols-3 xl:grid-cols-6">
        <div class="mc-kpi mc-kpi-money">
            <p class="text-[10px] font-medium" style="color: var(--mc-money)">Cash</p>
            <p class="text-lg font-bold leading-tight tabular-nums" style="color: var(--mc-money)">${{ payment_total_display }}</p>
            <p class="text-[10px]" style="color: var(--mc-muted)">Mo ${{ revenue_month_display }} · Wk ${{ revenue_week_display }}</p>
        </div>
        <div class="mc-kpi">
            <p class="text-[10px] font-medium" style="color: var(--mc-muted)">MRR</p>
            <p class="text-lg font-bold leading-tight tabular-nums">₹{{ mrr_inr }}</p>
            <p class="text-[10px]" style="color: var(--mc-muted)">{{ paid_users }} paid · ARPU ${{ arpu_month_display }}</p>
        </div>
        <div class="mc-kpi">
            <p class="text-[10px] font-medium" style="color: var(--mc-muted)">Convert</p>
            <p class="text-lg font-bold leading-tight tabular-nums" style="color: var(--mc-accent)">{{ conversion_pct }}%</p>
            <p class="text-[10px]" style="color: var(--mc-muted)">{{ paid_users }}/{{ paid_users + trials_active }} pipeline</p>
        </div>
        <div class="mc-kpi">
            <p class="text-[10px] font-medium" style="color: var(--mc-muted)">Growth</p>
            <p class="text-lg font-bold leading-tight tabular-nums">+{{ signups_today }} <span class="text-xs font-medium" style="color: var(--mc-muted)">today</span></p>
            <p class="text-[10px]" style="color: var(--mc-muted)">
                Wk {{ signups_week }}
                <span style="color: {% if signups_wow > 0 %}var(--mc-money){% elif signups_wow < 0 %}var(--mc-danger){% else %}var(--mc-muted){% endif %}">
                    ({% if signups_wow > 0 %}+{% endif %}{{ signups_wow }})
                </span>
            </p>
        </div>
        <div class="mc-kpi mc-kpi-warn">
            <p class="text-[10px] font-medium" style="color: var(--mc-warn)">Trials</p>
            <p class="text-lg font-bold leading-tight tabular-nums" style="color: var(--mc-warn)">{{ trials_active }}</p>
            <p class="text-[10px]" style="color: var(--mc-muted)">{{ trials_expired_flag }} expired · {{ open_invites }} invites</p>
        </div>
        <div class="mc-kpi">
            <p class="text-[10px] font-medium" style="color: var(--mc-muted)">Accounts</p>
            <p class="text-lg font-bold leading-tight tabular-nums">{{ user_count }}</p>
            <p class="text-[10px]" style="color: var(--mc-muted)">{{ user_total }} tot · {{ staff_count }} staff</p>
        </div>
    </div>
    <div class="mt-1.5 grid grid-cols-2 gap-1.5 sm:grid-cols-4">
        <div class="mc-kpi !py-1.5">
            <p class="text-[9px] uppercase tracking-wide" style="color: var(--mc-muted)">Teams / seats</p>
            <p class="text-sm font-bold tabular-nums">{{ teams_total }} / {{ seats_filled }}</p>
        </div>
        <div class="mc-kpi !py-1.5">
            <p class="text-[9px] uppercase tracking-wide" style="color: var(--mc-muted)">Open / done</p>
            <p class="text-sm font-bold tabular-nums">{{ tasks_open }} / {{ tasks_done }}</p>
        </div>
        <div class="mc-kpi !py-1.5">
            <p class="text-[9px] uppercase tracking-wide" style="color: var(--mc-muted)">Projects</p>
            <p class="text-sm font-bold tabular-nums">{{ projects_active }}</p>
        </div>
        <div class="mc-kpi !py-1.5">
            <p class="text-[9px] uppercase tracking-wide" style="color: var(--mc-muted)">Activity 7d</p>
            <p class="text-sm font-bold tabular-nums">{{ activity_week }}</p>
        </div>
    </div>
</section>
