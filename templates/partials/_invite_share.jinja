{# Easy-copy invite share card — expects invite_share = {label, url} #}
{% if invite_share and invite_share.url %}
<div class="border-b border-emerald-200 bg-emerald-50 px-4 py-3"
     x-data="{ copied: false }">
    <div class="mx-auto flex max-w-3xl flex-col gap-2 sm:flex-row sm:items-center">
        <div class="min-w-0 flex-1">
            <p class="text-xs font-semibold text-emerald-900">
                Invite ready{% if invite_share.label %} for {{ invite_share.label }}{% endif %}
            </p>
            <p class="mt-0.5 text-[11px] text-emerald-800">Copy and share this join link:</p>
        </div>
        <div class="flex min-w-0 flex-1 gap-2">
            <input type="text"
                   readonly
                   value="{{ invite_share.url }}"
                   class="min-w-0 flex-1 rounded-lg border border-emerald-200 bg-white px-2.5 py-1.5 text-[11px] text-slate-800"
                   id="invite-share-url"
                   onclick="this.select()">
            <button type="button"
                    class="shrink-0 rounded-lg bg-emerald-700 px-3 py-1.5 text-[11px] font-semibold text-white hover:bg-emerald-800"
                    @click="navigator.clipboard.writeText(document.getElementById('invite-share-url').value); copied = true; setTimeout(() => copied = false, 1600)"
                    x-text="copied ? 'Copied!' : 'Copy link'"></button>
        </div>
    </div>
</div>
{% endif %}
