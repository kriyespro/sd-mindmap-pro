{# Comments list – swapped via HTMX after add/delete #}
{% if comments %}
<div class="space-y-3">
    {% for comment in comments %}
    <div class="group flex gap-2.5">
        <div class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-indigo-100 text-[10px] font-bold uppercase text-indigo-700">
            {{ comment.author.username[0] }}
        </div>
        <div class="flex-1 min-w-0">
            <div class="flex items-baseline gap-2">
                <span class="text-xs font-semibold text-slate-800">{{ comment.author.username }}</span>
                <span class="text-[10px] text-slate-400">{{ comment.created_at.strftime('%b %d, %H:%M') }}</span>
            </div>
            <p class="mt-0.5 text-xs text-slate-700 leading-relaxed whitespace-pre-wrap break-words">{{ comment.body }}</p>
        </div>
        <form hx-post="{{ url('planner:task_comment_delete', task_id=comment.task_id, comment_id=comment.id) }}"
              hx-target="#task-comments-{{ comment.task_id }}"
              hx-swap="innerHTML"
              class="shrink-0 opacity-0 group-hover:opacity-100 transition">
            {{ csrf_input }}
            <button type="submit" class="rounded p-1 text-slate-300 hover:text-red-500 hover:bg-red-50 transition">
                <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                </svg>
            </button>
        </form>
    </div>
    {% endfor %}
</div>
{% else %}
<p class="text-center text-xs text-slate-400 py-6">No comments yet. Be the first!</p>
{% endif %}
