{% macro node_card(task, depth=0, layout_mode='tree', mindmap_collapsed_ids=None, has_children_branch=None) %}
{% if depth == 0 %}
  {% set bar = '#ea580c' %}
  {% set tag_bg = '#ffedd5' %}
  {% set tag_txt = '#9a3412' %}
  {% set tag_bdr = '#fdba74' %}
  {% set lbl = 'CO' %}
{% elif depth == 1 %}
  {% set bar = '#0891b2' %}
  {% set tag_bg = '#ecfeff' %}
  {% set tag_txt = '#155e75' %}
  {% set tag_bdr = '#67e8f9' %}
  {% set lbl = 'DO' %}
{% elif depth == 2 %}
  {% set bar = '#db2777' %}
  {% set tag_bg = '#fce7f3' %}
  {% set tag_txt = '#9d174d' %}
  {% set tag_bdr = '#f9a8d4' %}
  {% set lbl = 'IO' %}
{% else %}
  {% set bar = '#65a30d' %}
  {% set tag_bg = '#ecfccb' %}
  {% set tag_txt = '#3f6212' %}
  {% set tag_bdr = '#bef264' %}
  {% set lbl = 'ST' %}
{% endif %}
{% if has_children_branch is not none %}
  {% set _branch = has_children_branch %}
{% else %}
  {% set _branch = task.children|length > 0 %}
{% endif %}
{% set _mc = mindmap_collapsed_ids if mindmap_collapsed_ids is not none else [] %}

<div id="task-card-{{ task.id }}"
     data-task-id="{{ task.id }}"
     tabindex="-1"
     class="group relative {% if layout_mode == 'idea' %}overflow-visible z-[1] hover:z-[30]{% else %}overflow-hidden{% endif %} rounded-xl border border-slate-200/90 bg-white shadow-sm transition hover:shadow-md {% if layout_mode == 'tree' %}min-w-[230px] max-w-[290px] hover:-translate-y-0.5{% else %}w-full{% endif %} {% if layout_mode == 'mini' %}max-h-[30px] hover:max-h-[180px] ring-1 ring-indigo-100/70 hover:ring-indigo-200{% endif %} {% if layout_mode == 'idea' %}max-h-[28px] rounded-lg border-slate-200/95 shadow-none hover:shadow-lg hover:ring-1 hover:ring-slate-300/80{% endif %}"
     x-data="{ editingTitle:false, editingDue:false, editingAssignee:false, titleDraft:'', dueDraft:'', assigneeDraft:'' }">
    <div class="{% if layout_mode in ['mindmap', 'mini'] %}h-[2px]{% elif layout_mode == 'idea' %}h-0{% else %}h-[3px]{% endif %}" style="background:{{ bar }}"></div>
    <div class="{% if layout_mode == 'mindmap' %}space-y-0.5 px-2 py-1{% elif layout_mode == 'mini' %}space-y-0.5 px-1.5 py-0.5{% elif layout_mode == 'idea' %}space-y-0.5 px-2 py-0.5{% else %}space-y-1 px-2.5 py-1.5{% endif %}">
        <div class="flex min-w-0 items-center gap-1.5">
            <span class="inline-flex shrink-0 select-none items-center rounded-md border px-2 py-0.5 text-[9px] font-extrabold tracking-wide {% if layout_mode in ['mindmap', 'mini'] %}scale-95{% endif %} {% if layout_mode in ['mini', 'idea'] %}hidden group-hover:inline-flex{% endif %}"
                  style="background:{{ tag_bg }};color:{{ tag_txt }};border-color:{{ tag_bdr }}">{{ lbl }}</span>
            <div class="min-w-0 flex-1">
                <button type="button" x-show="!editingTitle"
                        @click='editingTitle=true; titleDraft={{ task.title|tojson }}; $nextTick(()=>$refs.titleInput.focus())'
                        class="block w-full text-left {% if layout_mode in ['mindmap', 'mini', 'idea'] %}text-[12px]{% else %}text-[13px]{% endif %} font-bold leading-snug transition {% if task.is_completed %}text-slate-400 line-through{% else %}text-slate-900 hover:text-indigo-600{% endif %} {% if layout_mode == 'mini' %}truncate group-hover:whitespace-normal{% else %}break-words{% endif %}">
                    {{ task.title }}
                </button>
                <form x-show="editingTitle" x-cloak class="mt-0.5"
                      hx-post="{{ u.title(task.id) }}" hx-target="#task-tree" hx-swap="innerHTML"
                      @click.outside="editingTitle=false" @keydown.escape.prevent="editingTitle=false">
                    <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
                    <input x-ref="titleInput" x-model="titleDraft" name="title" required
                           class="w-full rounded-md border border-slate-200 px-2 py-1 text-xs font-semibold focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500"
                           @change="$el.form.requestSubmit()">
                </form>
            </div>
            <button type="button"
                    hx-post="{{ u.toggle(task.id) }}" hx-target="#task-tree" hx-swap="innerHTML"
                    class="flex shrink-0 items-center justify-center transition active:scale-90 {% if layout_mode in ['mini', 'idea'] %}h-2.5 w-2.5 rounded-full border-0{% else %}h-3.5 w-3.5 rounded border{% endif %}
                           {% if task.is_completed %}
                               {% if layout_mode in ['mini', 'idea'] %}bg-emerald-500 shadow-[0_0_0_2px_rgba(16,185,129,0.2)]{% else %}border-emerald-500 bg-emerald-500 text-white{% endif %}
                           {% else %}
                               {% if layout_mode in ['mini', 'idea'] %}bg-slate-300 group-hover:bg-indigo-400{% else %}border-slate-300 text-transparent hover:border-indigo-400{% endif %}
                           {% endif %}">
                {% if layout_mode not in ['mini', 'idea'] %}
                <svg class="h-2 w-2 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                {% endif %}
            </button>
            <button type="button" hx-delete="{{ u.delete(task.id) }}" hx-target="#task-tree" hx-swap="innerHTML"
                    hx-confirm="Delete this task and all subtasks?"
                    class="relative z-10 flex h-5 w-5 shrink-0 cursor-pointer items-center justify-center rounded text-slate-300 opacity-0 transition hover:bg-rose-50 hover:text-rose-600 group-hover:opacity-100">
                <svg class="pointer-events-none h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6M4 7h16"/></svg>
            </button>
            {% if layout_mode in ['mindmap', 'mini'] and _branch %}
            <button type="button"
                    hx-post="{{ u.mindmap_collapse(task.id) }}"
                    hx-target="#task-tree" hx-swap="innerHTML"
                    class="relative z-20 flex h-6 w-6 shrink-0 items-center justify-center rounded-full border-2 border-white bg-slate-100 text-[11px] font-bold leading-none text-slate-600 shadow-md ring-1 ring-slate-200/80 transition hover:bg-white hover:text-indigo-600 {% if layout_mode == 'mini' %}opacity-0 group-hover:opacity-100{% endif %}"
                    title="{% if task.id in _mc %}Expand subtasks{% else %}Hide subtasks{% endif %}">
                {% if task.id in _mc %}+{% else %}−{% endif %}
            </button>
            {% endif %}
            {% if layout_mode == 'idea' and _branch %}
            <button type="button"
                    hx-post="{{ u.mindmap_collapse(task.id) }}"
                    hx-target="#task-tree" hx-swap="innerHTML"
                    class="relative z-20 flex h-4 w-4 shrink-0 items-center justify-center rounded-full bg-slate-200 text-[10px] font-bold leading-none text-slate-600 opacity-0 transition group-hover:opacity-100 hover:bg-slate-300"
                    title="{% if task.id in _mc %}Expand subtasks{% else %}Hide subtasks{% endif %}">
                {% if task.id in _mc %}+{% else %}−{% endif %}
            </button>
            {% endif %}
        </div>
        <div class="{% if layout_mode == 'idea' %}absolute left-1/2 top-[calc(100%-1px)] z-40 min-w-full w-max max-w-[320px] -translate-x-1/2 rounded-xl border border-slate-200/90 bg-white/95 px-1.5 py-1 shadow-[0_10px_24px_rgba(15,23,42,0.16)] backdrop-blur-[1px] flex items-center flex-nowrap overflow-x-auto no-scrollbar{% elif layout_mode == 'mindmap' %}flex min-w-0 flex-nowrap items-center{% else %}flex min-w-0 flex-wrap items-center{% endif %} {% if layout_mode in ['mindmap', 'mini', 'idea'] %}gap-0.5{% else %}gap-1{% endif %} {% if layout_mode == 'mini' %}max-h-0 overflow-hidden opacity-0 transition-all duration-200 group-hover:max-h-24 group-hover:opacity-100{% elif layout_mode == 'idea' %}pointer-events-none opacity-0 translate-y-1 scale-[0.96] transition-all duration-180 ease-out [transition-delay:120ms] group-hover:pointer-events-auto group-hover:opacity-100 group-hover:translate-y-0 group-hover:scale-100 group-hover:[transition-delay:0ms]{% endif %}">
            <div class="shrink-0">
                <button type="button" x-show="!editingDue"
                        @click='editingDue=true; dueDraft={{ (task.due_date.isoformat() if task.due_date else "")|tojson }}; assigneeDraft={{ (task.assignee or "")|tojson }}; $nextTick(()=>$refs.dueInput.focus())'
                        class="inline-flex items-center gap-0.5 rounded border {% if layout_mode == 'idea' %}px-1 py-0.5 text-[9px]{% else %}px-1.5 py-0.5 text-[10px]{% endif %} font-semibold whitespace-nowrap
                               {% if task.due_state == 'overdue' %}border-rose-200 bg-rose-50 text-rose-700
                               {% elif task.due_state == 'today' %}border-amber-200 bg-amber-50 text-amber-800
                               {% elif task.due_state == 'upcoming' %}border-indigo-200 bg-indigo-50 text-indigo-700
                               {% else %}border-slate-200 bg-slate-50 text-slate-400{% endif %}">
                    <svg class="h-2 w-2 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                    {{ task.due_date or 'Date' }}
                </button>
                <form x-show="editingDue" x-cloak
                      hx-post="{{ u.meta(task.id) }}" hx-target="#task-tree" hx-swap="innerHTML"
                      @click.outside="editingDue=false" @keydown.escape.prevent="editingDue=false">
                    <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
                    <input x-ref="dueInput" x-model="dueDraft" type="date" name="due_date"
                           class="rounded border border-slate-200 px-1 py-0.5 text-[10px] font-medium w-[104px]"
                           @change="$el.form.requestSubmit()">
                    <input type="hidden" name="assignee_username" :value="assigneeDraft">
                </form>
            </div>
            <div class="min-w-0 shrink-0">
                <button type="button" x-show="!editingAssignee"
                        @click='editingAssignee=true; assigneeDraft={{ (task.assignee or "")|tojson }}; dueDraft={{ (task.due_date.isoformat() if task.due_date else "")|tojson }}; $nextTick(()=>$refs.assigneeInput.focus())'
                        class="inline-flex {% if layout_mode == 'idea' %}max-w-[50px]{% else %}max-w-[72px]{% endif %} items-center gap-0.5 truncate rounded border border-slate-200 bg-slate-50 px-1 py-0.5 text-[10px] font-semibold text-slate-700">
                    <svg class="h-2 w-2 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                    {{ task.assignee or 'Assign' }}
                </button>
                <form x-show="editingAssignee" x-cloak
                      hx-post="{{ u.meta(task.id) }}" hx-target="#task-tree" hx-swap="innerHTML"
                      @click.outside="editingAssignee=false" @keydown.escape.prevent="editingAssignee=false">
                    <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
                    <input x-ref="assigneeInput" x-model="assigneeDraft" name="assignee_username" maxlength="150" placeholder="User"
                           {% if team_assignee_usernames %}list="team-assignee-options-{{ task.id }}"{% endif %}
                           class="w-[80px] rounded border border-slate-200 px-1 py-0.5 text-[10px] font-medium"
                           @change="$el.form.requestSubmit()">
                    {% if team_assignee_usernames %}
                    <datalist id="team-assignee-options-{{ task.id }}">
                        {% for uname in team_assignee_usernames %}
                        <option value="{{ uname }}"></option>
                        {% endfor %}
                    </datalist>
                    {% endif %}
                    <input type="hidden" name="due_date" :value="dueDraft">
                </form>
            </div>
            <div class="flex min-w-0 {% if layout_mode == 'idea' %}w-[68px] shrink-0{% elif layout_mode == 'mindmap' %}w-[56px] shrink-0{% else %}flex-1{% endif %} items-center gap-1">
                <div class="h-[3px] flex-1 overflow-hidden rounded-full bg-slate-200">
                    <div class="h-full rounded-full transition-all duration-500" style="width:{{ task.percent }}%;background:{% if task.percent==100 %}#10b981{% else %}{{ bar }}{% endif %}"></div>
                </div>
                <span class="shrink-0 text-[10px] font-extrabold tabular-nums {% if task.percent == 100 %}text-emerald-600{% else %}text-slate-700{% endif %}">{{ task.percent }}%</span>
            </div>
            <button type="button" @click="addModalOpen=true; parentIdForModal='{{ task.id }}'"
                    title="Add subtask"
                    class="shrink-0 whitespace-nowrap rounded-md {% if layout_mode == 'mindmap' %}inline-flex h-5 w-5 items-center justify-center px-0 py-0 text-[12px]{% elif layout_mode == 'idea' %}px-1 py-0.5 text-[10px]{% else %}px-1.5 py-0.5 text-[11px]{% endif %} font-extrabold text-slate-600 transition hover:bg-indigo-50 hover:text-indigo-700">{% if layout_mode in ['idea', 'mindmap'] %}+{% else %}+ Child{% endif %}</button>
            {% if layout_mode == 'tree' and task.children %}
            <button type="button" @click="collapsed = !collapsed"
                    class="shrink-0 rounded border border-slate-200 px-1.5 py-0.5 text-[10px] font-bold text-slate-600 hover:text-slate-800">
                <span x-text="collapsed ? '▸' : '▾'"></span>
            </button>
            {% endif %}
        </div>
    </div>
</div>
{% endmacro %}

{% macro render_task(task, depth=0) %}
<div class="relative" id="task-node-{{ task.id }}" x-data="{ collapsed: false }">
    {{ node_card(task, depth) }}
    {% if task.children %}
    <div x-show="!collapsed" x-transition.duration.150ms class="relative mt-1.5 ml-7 space-y-1.5 border-l border-slate-200 pl-3.5">
        {% for child in task.children %}
        <div class="relative">
            <div class="absolute -left-3.5 top-5 h-px w-3.5 bg-slate-200"></div>
            {{ render_task(child, depth + 1) }}
        </div>
        {% endfor %}
    </div>
    {% endif %}
</div>
{% endmacro %}

<div class="flex flex-wrap items-start gap-4 py-1">
{% if task_tree %}
    <div class="mb-2 w-full rounded-xl border border-slate-200 bg-white/90 px-3 py-2 text-[11px] font-semibold text-slate-600 shadow-sm">
        <span class="font-bold text-slate-500">Depth:</span>
        <span class="ml-1 rounded-md border px-2 py-0.5 text-[9px] font-extrabold" style="background:#ffedd5;color:#9a3412;border-color:#fdba74">CO</span>
        <span class="text-slate-300">→</span>
        <span class="rounded-md border px-2 py-0.5 text-[9px] font-extrabold" style="background:#ecfeff;color:#155e75;border-color:#67e8f9">DO</span>
        <span class="text-slate-300">→</span>
        <span class="rounded-md border px-2 py-0.5 text-[9px] font-extrabold" style="background:#fce7f3;color:#9d174d;border-color:#f9a8d4">IO</span>
        <span class="text-slate-300">→</span>
        <span class="rounded-md border px-2 py-0.5 text-[9px] font-extrabold" style="background:#ecfccb;color:#3f6212;border-color:#bef264">ST</span>
    </div>
    {% for task in task_tree %}
    <div class="relative shrink-0">
        <div class="absolute -left-1 top-5 h-2 w-2 rounded-full bg-orange-500 shadow-[0_0_8px_rgba(234,88,12,0.45)]"></div>
        {{ render_task(task) }}
    </div>
    {% endfor %}
{% else %}
    <div class="flex w-full flex-col items-center py-20 text-center">
        <div class="mb-3 flex h-14 w-14 items-center justify-center rounded-2xl border border-slate-200 bg-white shadow-sm">
            <svg class="h-7 w-7 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 13h6m-3-3v6m-9 1V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
        </div>
        <p class="text-sm font-semibold text-slate-600">No tasks yet</p>
        <p class="mt-1 max-w-xs text-[11px] text-slate-400">Use <span class="font-semibold text-indigo-600">New task</span> or <kbd class="rounded border border-slate-200 bg-white px-1.5 py-0.5 text-[10px]">⌘K</kbd></p>
    </div>
{% endif %}
</div>
