{% for u in users_list %}
<tr class="border-t {% if not u.is_active %}opacity-50{% endif %}" style="border-color: var(--mc-line)">
    <td class="px-2.5 py-1.5">
        <a href="{{ url('staff_dashboard:user_detail', user_id=u.id) }}" class="block">
            <p class="font-medium leading-tight" style="color: var(--mc-ink)">@{{ u.username }}{% if u.is_staff %} <span class="text-[9px]" style="color: var(--mc-accent)">staff</span>{% endif %}</p>
            <p class="text-[10px] truncate max-w-[10rem]" style="color: var(--mc-muted)">{{ u.email or '—' }}</p>
        </a>
    </td>
    <td class="px-2.5 py-1.5 text-[11px]">
        {% if u.profile %}
        <span class="font-semibold">{{ u.profile.plan }}</span>
        {% if u.profile.trial_active %}<span style="color: var(--mc-warn)"> →{{ u.profile.trial_ends }}</span>{% endif %}
        {% if u.profile.plan in ['team', 'team_20'] and u.payment_count == 0 %}<span style="color: var(--mc-danger)"> ·no$</span>{% endif %}
        {% else %}—{% endif %}
    </td>
    <td class="px-2.5 py-1.5 tabular-nums text-[11px]">{{ u.team_count }}</td>
    <td class="px-2.5 py-1.5 tabular-nums text-[11px]">{{ u.payment_count }}</td>
    <td class="px-2.5 py-1.5 font-mono text-[10px]" style="color: var(--mc-muted)">
        {{ u.last_login.strftime('%m/%d') if u.last_login else '—' }}
    </td>
    <td class="px-2.5 py-1.5">
        <div class="flex flex-wrap items-center justify-end gap-1">
            <a href="{{ url('staff_dashboard:user_detail', user_id=u.id) }}" class="mc-btn mc-btn-ghost">Open</a>
            <form action="{{ url('staff_dashboard:user_plan', user_id=u.id) }}" method="post" class="inline-flex items-center gap-0.5">
                <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
                <input type="hidden" name="next" value="{{ request.get_full_path() }}">
                <select name="plan" class="mc-input !py-0.5 !text-[10px]">
                    {% for value, label in plan_choices %}
                    <option value="{{ value }}" {% if u.profile and u.profile.plan == value %}selected{% endif %}>{{ value }}</option>
                    {% endfor %}
                </select>
                <button type="submit" class="mc-btn mc-btn-primary">Set</button>
            </form>
            {% if not u.is_superuser %}
            <form action="{{ url('staff_dashboard:user_active', user_id=u.id) }}" method="post">
                <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
                <input type="hidden" name="next" value="{{ request.get_full_path() }}">
                <input type="hidden" name="is_active" value="{{ 'false' if u.is_active else 'true' }}">
                <button type="submit" class="mc-btn mc-btn-ghost" style="color: {% if u.is_active %}var(--mc-danger){% else %}var(--mc-money){% endif %}">
                    {% if u.is_active %}Off{% else %}On{% endif %}
                </button>
            </form>
            {% endif %}
        </div>
    </td>
</tr>
{% else %}
<tr>
    <td colspan="6" class="px-2.5 py-6 text-center text-[11px]" style="color: var(--mc-muted)">No matches</td>
</tr>
{% endfor %}
