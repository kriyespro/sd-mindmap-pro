{% extends 'layouts/app.jinja' %}
{% block title %}Resource Management{% endblock %}

{% block main %}
<div class="flex min-h-full flex-col">
    <header class="sticky top-0 z-20 flex items-center gap-3 border-b border-slate-200/80 bg-white/90 px-6 py-3 backdrop-blur-md">
        <button type="button" @click="sidebarOpen = !sidebarOpen"
                class="inline-flex h-7 w-7 items-center justify-center rounded-md border border-slate-200 text-slate-500 transition hover:text-indigo-600">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
        <h1 class="text-sm font-semibold text-slate-900">Resource Management</h1>
        <span class="rounded-full bg-violet-100 px-2 py-0.5 text-[10px] font-bold text-violet-700">4-week view</span>
    </header>

    <div class="flex-1 overflow-auto p-6 space-y-6">

        <!-- Workload Heatmap -->
        <div class="rounded-xl border border-slate-200 bg-white shadow-sm overflow-hidden">
            <div class="border-b border-slate-100 px-5 py-3 flex items-center justify-between">
                <h3 class="text-xs font-semibold uppercase tracking-wider text-slate-500">Team Workload (Hours Allocated / 40h capacity)</h3>
                <div class="flex items-center gap-3 text-[10px] text-slate-500">
                    <span class="flex items-center gap-1"><span class="inline-block h-3 w-3 rounded-sm bg-green-200"></span> Under 80%</span>
                    <span class="flex items-center gap-1"><span class="inline-block h-3 w-3 rounded-sm bg-amber-300"></span> 80-100%</span>
                    <span class="flex items-center gap-1"><span class="inline-block h-3 w-3 rounded-sm bg-red-400"></span> Over 100%</span>
                </div>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-xs">
                    <thead>
                        <tr class="border-b border-slate-100 bg-slate-50">
                            <th class="py-2 pl-5 pr-3 text-left font-semibold text-slate-500 w-40">Member</th>
                            {% for ws in workload.week_starts %}
                            <th class="px-3 py-2 text-center font-semibold text-slate-500">
                                W{{ loop.index }}<br>
                                <span class="font-normal text-slate-400">{{ ws.strftime('%b %d') }}</span>
                            </th>
                            {% endfor %}
                            <th class="px-3 py-2 text-right font-semibold text-slate-500 pr-5">Total</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-50">
                        {% for row in workload.users %}
                        <tr class="hover:bg-slate-50/50 transition">
                            <td class="py-2.5 pl-5 pr-3">
                                <div class="flex items-center gap-2">
                                    <div class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-indigo-100 text-[10px] font-bold uppercase text-indigo-700">
                                        {{ row.user.username[0] }}
                                    </div>
                                    <span class="font-medium text-slate-800 truncate max-w-[80px]">{{ row.user.username }}</span>
                                </div>
                            </td>
                            {% for w in row.weeks %}
                            <td class="px-3 py-2 text-center">
                                {% if w.allocated > 0 %}
                                <div class="inline-flex flex-col items-center gap-0.5">
                                    <span class="rounded-md px-2 py-0.5 font-semibold
                                        {% if w.over %}bg-red-100 text-red-700{% elif w.pct >= 80 %}bg-amber-100 text-amber-700{% else %}bg-green-100 text-green-700{% endif %}">
                                        {{ w.allocated }}h
                                    </span>
                                    <div class="h-1 w-12 overflow-hidden rounded-full bg-slate-100">
                                        <div class="h-full rounded-full transition-all
                                            {% if w.over %}bg-red-500{% elif w.pct >= 80 %}bg-amber-400{% else %}bg-green-400{% endif %}"
                                             style="width: {{ [w.pct, 100]|min }}%;"></div>
                                    </div>
                                    {% if w.logged > 0 %}
                                    <span class="text-[9px] text-slate-400">{{ w.logged }}h logged</span>
                                    {% endif %}
                                </div>
                                {% else %}
                                <span class="text-slate-300">—</span>
                                {% endif %}
                            </td>
                            {% endfor %}
                            <td class="px-3 py-2 text-right pr-5">
                                <span class="font-bold text-slate-700">{{ row.total_alloc }}h</span>
                            </td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="{{ workload.week_starts|length + 2 }}" class="py-8 text-center text-slate-400">
                                No team members found. Add projects and invite members first.
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Allocations + Add Form -->
        <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">

            <!-- Add allocation form -->
            <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm" x-data="{ open: true }">
                <button type="button" @click="open = !open"
                        class="flex w-full items-center justify-between text-xs font-semibold uppercase tracking-wider text-slate-500 mb-3">
                    <span>Add Allocation</span>
                    <svg class="h-4 w-4 transition" :class="open ? 'rotate-180' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                    </svg>
                </button>
                <form x-show="open"
                      hx-post="{{ url('resources:allocation_create') }}"
                      hx-target="#allocation-rows"
                      hx-swap="innerHTML"
                      hx-on::after-request="this.reset()"
                      class="space-y-3">
                    {{ csrf_input }}
                    <div>
                        <label class="block text-[10px] font-semibold uppercase tracking-wide text-slate-500 mb-1">Member (username)</label>
                        <input type="text" name="user_id" placeholder="User ID or leave blank for yourself"
                               class="w-full rounded-lg border border-slate-200 px-3 py-2 text-xs focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500">
                        <p class="mt-0.5 text-[10px] text-slate-400">Enter user's numeric ID (from DB).</p>
                    </div>
                    <div>
                        <label class="block text-[10px] font-semibold uppercase tracking-wide text-slate-500 mb-1">Project</label>
                        <select name="project_id" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-xs focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500">
                            <option value="">No project</option>
                            {% for p in projects %}
                            <option value="{{ p.id }}">{{ p.name }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="grid grid-cols-2 gap-2">
                        <div>
                            <label class="block text-[10px] font-semibold uppercase tracking-wide text-slate-500 mb-1">Role</label>
                            <select name="role" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-xs focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500">
                                <option value="dev">Developer</option>
                                <option value="pm">Project Manager</option>
                                <option value="design">Designer</option>
                                <option value="qa">QA</option>
                                <option value="devops">DevOps</option>
                                <option value="analyst">Analyst</option>
                                <option value="other">Other</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-[10px] font-semibold uppercase tracking-wide text-slate-500 mb-1">Hrs/Day</label>
                            <input type="number" name="hours_per_day" value="8" min="0.5" max="16" step="0.5"
                                   class="w-full rounded-lg border border-slate-200 px-3 py-2 text-xs focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500">
                        </div>
                    </div>
                    <div class="grid grid-cols-2 gap-2">
                        <div>
                            <label class="block text-[10px] font-semibold uppercase tracking-wide text-slate-500 mb-1">Start Date</label>
                            <input type="date" name="start_date" required value="{{ today.isoformat() }}"
                                   class="w-full rounded-lg border border-slate-200 px-3 py-2 text-xs focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500">
                        </div>
                        <div>
                            <label class="block text-[10px] font-semibold uppercase tracking-wide text-slate-500 mb-1">End Date</label>
                            <input type="date" name="end_date" required
                                   class="w-full rounded-lg border border-slate-200 px-3 py-2 text-xs focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500">
                        </div>
                    </div>
                    <div>
                        <label class="block text-[10px] font-semibold uppercase tracking-wide text-slate-500 mb-1">Notes</label>
                        <textarea name="notes" rows="2" placeholder="Optional notes…"
                                  class="w-full rounded-lg border border-slate-200 px-3 py-2 text-xs resize-none focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500"></textarea>
                    </div>
                    <button type="submit"
                            class="w-full rounded-lg bg-indigo-600 py-2 text-xs font-semibold text-white hover:bg-indigo-700 transition">
                        Add Allocation
                    </button>
                </form>
            </div>

            <!-- Allocation list -->
            <div class="lg:col-span-2 rounded-xl border border-slate-200 bg-white shadow-sm overflow-hidden">
                <div class="border-b border-slate-100 px-5 py-3">
                    <h3 class="text-xs font-semibold uppercase tracking-wider text-slate-500">Current Allocations</h3>
                </div>
                <div id="allocation-rows" class="divide-y divide-slate-50 max-h-96 overflow-y-auto">
                    {% include 'resources/_allocation_rows.jinja' %}
                </div>
            </div>

        </div>

    </div>
</div>
{% endblock %}
