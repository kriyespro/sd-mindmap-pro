{# Allocation rows – swapped via HTMX after create/delete #}
{% if allocations %}
{% for a in allocations %}
<div class="flex items-center gap-3 px-5 py-3 hover:bg-slate-50/50 transition">
    <div class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-indigo-100 text-[10px] font-bold uppercase text-indigo-700">
        {{ a.user.username[0] }}
    </div>
    <div class="flex-1 min-w-0">
        <div class="flex items-center gap-2">
            <span class="text-xs font-semibold text-slate-800">{{ a.user.username }}</span>
            <span class="rounded-md bg-slate-100 px-1.5 py-0.5 text-[10px] font-medium text-slate-600">{{ a.get_role_display() }}</span>
            {% if a.project %}
            <span class="rounded-md px-1.5 py-0.5 text-[10px] font-medium text-white" style="background-color: {{ a.project.color }};">{{ a.project.name }}</span>
            {% endif %}
        </div>
        <div class="mt-0.5 flex items-center gap-3 text-[10px] text-slate-400">
            <span>{{ a.hours_per_day }}h/day</span>
            <span>{{ a.start_date.strftime('%b %d') }} → {{ a.end_date.strftime('%b %d, %Y') }}</span>
            <span class="font-semibold text-slate-600">{{ a.total_hours|int }}h total</span>
        </div>
        {% if a.notes %}
        <p class="mt-0.5 truncate text-[10px] text-slate-400 italic">{{ a.notes }}</p>
        {% endif %}
    </div>
    <form hx-post="{{ url('resources:allocation_delete', pk=a.id) }}"
          hx-target="#allocation-rows"
          hx-swap="innerHTML">
        {{ csrf_input }}
        <button type="submit" class="rounded p-1 text-slate-300 hover:text-red-500 hover:bg-red-50 transition">
            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
            </svg>
        </button>
    </form>
</div>
{% endfor %}
{% else %}
<p class="px-5 py-8 text-center text-xs text-slate-400">No allocations yet. Add one using the form.</p>
{% endif %}
