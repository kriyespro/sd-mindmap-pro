<div id="milestone-{{ ms.id }}"
     class="flex items-center gap-3 rounded-lg border border-slate-200 bg-white px-4 py-3 shadow-sm transition hover:shadow-md">
    <!-- Diamond icon -->
    <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg
        {% if ms.status == 'completed' %}bg-green-100 text-green-600
        {% elif ms.status == 'missed' %}bg-red-100 text-red-600
        {% elif ms.status == 'in_progress' %}bg-blue-100 text-blue-600
        {% else %}bg-slate-100 text-slate-500{% endif %}">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L2 12l10 10 10-10z"/></svg>
    </div>

    <div class="flex-1 min-w-0">
        <p class="text-sm font-semibold text-slate-800 {% if ms.status == 'completed' %}line-through text-slate-400{% endif %}">
            {{ ms.name }}
        </p>
        {% if ms.description %}
        <p class="text-[10px] text-slate-500 truncate">{{ ms.description }}</p>
        {% endif %}
    </div>

    <div class="flex items-center gap-3 shrink-0">
        <!-- Progress -->
        <div class="hidden items-center gap-1.5 sm:flex">
            <div class="h-1.5 w-20 overflow-hidden rounded-full bg-slate-100">
                <div class="h-full rounded-full bg-indigo-500 transition-all" style="width: {{ ms.progress }}%;"></div>
            </div>
            <span class="text-[10px] font-semibold text-slate-600">{{ ms.progress }}%</span>
        </div>

        <!-- Due date -->
        <span class="text-[10px] {% if ms.is_overdue %}font-semibold text-red-500{% else %}text-slate-500{% endif %}">
            {{ ms.due_date.strftime('%b %d, %Y') }}
            {% if ms.is_overdue %} · Overdue{% endif %}
        </span>

        <!-- Status badge -->
        <span class="rounded-full px-2 py-0.5 text-[10px] font-semibold
            {% if ms.status == 'completed' %}bg-green-100 text-green-700
            {% elif ms.status == 'in_progress' %}bg-blue-100 text-blue-700
            {% elif ms.status == 'missed' %}bg-red-100 text-red-700
            {% else %}bg-slate-100 text-slate-600{% endif %}">
            {{ ms.get_status_display() }}
        </span>

        {% if can_manage %}
        <form hx-post="{{ url('milestones:delete', slug=ms.project.slug, pk=ms.id) }}"
              hx-target="#milestone-{{ ms.id }}"
              hx-swap="outerHTML"
              hx-confirm="Delete this milestone?">
            {{ csrf_input }}
            <button type="submit" class="rounded p-1 text-slate-400 hover:bg-red-50 hover:text-red-500 transition">
                <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </form>
        {% endif %}
    </div>
</div>
