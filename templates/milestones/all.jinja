{% extends 'layouts/app.jinja' %}
{% block title %}All Milestones{% endblock %}

{% block main %}
<div class="flex min-h-full flex-col">
    <header class="sticky top-0 z-20 flex items-center gap-3 border-b border-slate-200/80 bg-white/90 px-6 py-3 backdrop-blur-md">
        <button type="button" @click="sidebarOpen = !sidebarOpen"
                class="inline-flex h-7 w-7 items-center justify-center rounded-md border border-slate-200 text-slate-500 transition hover:text-indigo-600">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
        <h1 class="text-sm font-semibold text-slate-900">All Milestones</h1>
        <span class="rounded-full bg-slate-100 px-2 py-0.5 text-[10px] font-semibold text-slate-600">{{ milestones|length }}</span>
    </header>

    <div class="flex-1 p-6">
        {% if milestones %}
        <div class="space-y-2">
            {% set current_project = namespace(id=None) %}
            {% for ms in milestones %}
            {% if ms.project_id != current_project.id %}
            {% set current_project.id = ms.project_id %}
            <div class="mb-1 mt-4 first:mt-0 flex items-center gap-2">
                <div class="h-3 w-3 rounded-sm shrink-0" style="background-color: {{ ms.project.color }};"></div>
                <a href="{{ url('milestones:list', slug=ms.project.slug) }}"
                   class="text-xs font-semibold text-slate-700 hover:text-indigo-600 transition">
                    {{ ms.project.name }}
                </a>
            </div>
            {% endif %}
            {% include 'milestones/_milestone_row.jinja' with context %}
            {% endfor %}
        </div>
        {% else %}
        <div class="flex flex-col items-center justify-center py-20 text-center">
            <p class="text-sm text-slate-500">No milestones yet. <a href="{{ url('projects:list') }}" class="text-indigo-600 hover:underline">Go to projects →</a></p>
        </div>
        {% endif %}
    </div>
</div>
{% endblock %}
