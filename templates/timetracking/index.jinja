{% extends 'layouts/app.jinja' %}
{% block title %}Time Tracking{% endblock %}

{% block main %}
<div class="flex min-h-full flex-col">
    <header class="sticky top-0 z-20 flex items-center gap-3 border-b border-slate-200/80 bg-white/90 px-6 py-3 backdrop-blur-md">
        <button type="button" @click="sidebarOpen = !sidebarOpen"
                class="inline-flex h-7 w-7 items-center justify-center rounded-md border border-slate-200 text-slate-500 transition hover:text-indigo-600">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
        <h1 class="text-sm font-semibold text-slate-900">Time Tracking</h1>
    </header>

    <div class="flex-1 p-6 space-y-6">

        <!-- Timer widget -->
        {% include 'timetracking/_timer_widget.jinja' %}

        <!-- Stats -->
        <div class="grid grid-cols-2 gap-4 sm:grid-cols-4">
            <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm text-center">
                <p class="text-xl font-bold text-slate-900">{{ today_formatted }}</p>
                <p class="text-[10px] font-medium uppercase tracking-wider text-slate-500">Today</p>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm text-center">
                <p class="text-xl font-bold text-slate-900">{{ week_formatted }}</p>
                <p class="text-[10px] font-medium uppercase tracking-wider text-slate-500">This Week</p>
            </div>
            <div class="rounded-xl border border-indigo-100 bg-indigo-50 p-4 shadow-sm text-center sm:col-span-2">
                <p class="text-sm font-semibold text-indigo-700">Manual Log</p>
                <form hx-post="{{ url('timetracking:manual') }}"
                      hx-target="#entry-list"
                      hx-swap="afterbegin"
                      class="mt-2 flex items-center gap-2">
                    {{ csrf_input }}
                    <input type="text" name="description" placeholder="Description"
                           class="flex-1 rounded-lg border border-slate-300 px-2 py-1 text-xs focus:outline-none">
                    <input type="number" name="hours" placeholder="h" min="0" max="23"
                           class="w-12 rounded-lg border border-slate-300 px-2 py-1 text-xs text-center focus:outline-none">
                    <input type="number" name="minutes" placeholder="m" min="0" max="59"
                           class="w-12 rounded-lg border border-slate-300 px-2 py-1 text-xs text-center focus:outline-none">
                    <button type="submit"
                            class="rounded-lg bg-indigo-600 px-3 py-1 text-xs font-semibold text-white hover:bg-indigo-700 transition">
                        Add
                    </button>
                </form>
            </div>
        </div>

        <!-- Entry list -->
        <div class="rounded-xl border border-slate-200 bg-white shadow-sm overflow-hidden">
            <div class="border-b border-slate-100 px-5 py-3 flex items-center justify-between">
                <h3 class="text-xs font-semibold text-slate-700">Recent Entries</h3>
                <span class="text-[10px] text-slate-400">{{ entries|length }} entries</span>
            </div>
            <div id="entry-list" class="divide-y divide-slate-50 max-h-[60vh] overflow-y-auto">
                {% for entry in entries %}
                {% include 'timetracking/_entry_row.jinja' %}
                {% else %}
                <p class="px-5 py-8 text-center text-sm text-slate-400">No time logged yet. Start a timer above.</p>
                {% endfor %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
