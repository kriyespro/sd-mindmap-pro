{% extends 'layouts/app.jinja' %}
{% block title %}{% if current_project %}{{ current_project.name }} · Board{% elif current_team %}{{ current_team.name }} · DCPMind{% else %}Personal · DCPMind{% endif %}{% endblock %}

{% block main %}
<header class="dark-topbar sticky top-0 z-20 flex items-center justify-between gap-3 border-b border-slate-200/80 bg-white/90 px-4 py-2 backdrop-blur-md">
    <div class="flex min-w-0 items-center gap-2.5">
        <button type="button"
                @click="toggleSidebar()"
                data-sidebar-toggle
                class="dark-topbar-pill inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-md border border-slate-200 text-slate-500 transition hover:text-indigo-600"
                title="Toggle sidebar">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
        <h1 class="truncate text-sm font-semibold text-slate-900">
            {% if current_project %}{{ current_project.name }}{% elif current_team %}{{ current_team.name }}{% else %}Personal workspace{% endif %}
        </h1>
        {% if current_project %}
        <a href="{{ url('projects:detail', slug=current_project.slug) }}"
           class="hidden rounded-md border border-slate-200 px-2 py-0.5 text-[10px] font-medium text-slate-600 transition hover:border-indigo-200 hover:text-indigo-700 sm:inline-flex">
            Project →
        </a>
        {% endif %}
        {% if current_team and team_roster|length > 0 %}
        <div class="hidden items-center gap-1.5 xl:flex">
            <span class="text-[10px] font-medium text-slate-500">Members:</span>
            {% for rm in team_roster %}
            <span class="inline-flex items-center gap-0.5 rounded-md bg-slate-100 px-1.5 py-0.5 text-[10px] text-slate-600">{{ rm.user.username }}{% if rm.is_owner %}<span class="text-[9px] text-slate-400">·owner</span>{% endif %}</span>
            {% endfor %}
        </div>
        {% endif %}
    </div>
    <div class="flex items-center gap-1.5">
        <div id="stats-container"
             hx-get="{{ u.stats }}"
             hx-trigger="updateStats from:body"
             hx-swap="innerHTML">
            {% include 'partials/stats.jinja' %}
        </div>

        <div class="hidden h-4 w-px bg-slate-200 lg:block"></div>

        <div class="dark-topbar-pill flex rounded-md border border-slate-200 bg-slate-100/90 p-0.5 text-[10px] font-semibold shadow-sm">
            {% if 'tree' in ui.layouts %}
            <a href="{{ request.path }}?layout=tree"
               class="rounded px-1.5 py-0.5 transition {% if task_layout == 'tree' %}bg-white text-slate-900 shadow-sm{% else %}text-slate-500 hover:text-slate-700{% endif %}">Tree</a>
            {% endif %}
            {% if 'mindmap' in ui.layouts %}
            <a href="{{ request.path }}?layout=mindmap"
               class="rounded px-1.5 py-0.5 transition {% if task_layout == 'mindmap' %}bg-white text-slate-900 shadow-sm{% else %}text-slate-500 hover:text-slate-700{% endif %}">Map</a>
            {% endif %}
            {% if 'cmap' in ui.layouts %}
            <a href="{{ request.path }}?layout=cmap"
               class="rounded px-1.5 py-0.5 transition {% if task_layout == 'cmap' %}bg-white text-slate-900 shadow-sm{% else %}text-slate-500 hover:text-slate-700{% endif %}"
               title="Compact map — denser cards for large trees">CMap</a>
            {% endif %}
            {% if 'mini' in ui.layouts %}
            <a href="{{ request.path }}?layout=mini"
               class="rounded px-1.5 py-0.5 transition {% if task_layout == 'mini' %}bg-white text-slate-900 shadow-sm{% else %}text-slate-500 hover:text-slate-700{% endif %}">Mini</a>
            {% endif %}
            {% if 'idea' in ui.layouts %}
            <a href="{{ request.path }}?layout=idea"
               class="rounded px-1.5 py-0.5 transition {% if task_layout == 'idea' %}bg-white text-slate-900 shadow-sm{% else %}text-slate-500 hover:text-slate-700{% endif %}">Idea</a>
            {% endif %}
            {% if 'kanban' in ui.layouts %}
            <a href="{{ request.path }}?layout=kanban"
               class="rounded px-1.5 py-0.5 transition {% if task_layout == 'kanban' %}bg-white text-slate-900 shadow-sm{% else %}text-slate-500 hover:text-slate-700{% endif %}">Kanban</a>
            {% endif %}
        </div>
        {% if task_layout in ['mindmap', 'cmap', 'tree', 'mini', 'idea'] %}
        <div class="board-zoom-bar dark-topbar-pill inline-flex items-center gap-0.5 rounded-md border border-slate-200 bg-white p-0.5 text-[10px] font-semibold shadow-sm"
             title="Zoom · Ctrl/⌘ + scroll · Ctrl/⌘ 0 reset">
            <button type="button" @click="zoomOut()" :disabled="boardZoom <= boardZoomMin"
                    class="inline-flex h-6 w-6 items-center justify-center rounded text-slate-600 hover:bg-slate-100" aria-label="Zoom out">−</button>
            <button type="button" @click="zoomReset()"
                    class="min-w-[2.6rem] rounded px-1 py-0.5 tabular-nums text-slate-700 hover:bg-slate-100"
                    x-text="Math.round(boardZoom * 100) + '%'"></button>
            <button type="button" @click="zoomIn()" :disabled="boardZoom >= boardZoomMax"
                    class="inline-flex h-6 w-6 items-center justify-center rounded text-slate-600 hover:bg-slate-100" aria-label="Zoom in">+</button>
        </div>
        {% endif %}
        {% if ui.top.gantt %}
        {% if current_project %}
        <a href="{{ url('gantt:gantt', slug=current_project.slug) }}"
           class="dark-topbar-pill inline-flex items-center gap-1 rounded-md border border-orange-200 bg-orange-50 px-2 py-1 text-[10px] font-semibold text-orange-700 transition hover:bg-orange-100"
           title="Gantt chart for this project">
            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2"/>
            </svg>
            Gantt
        </a>
        {% else %}
        <a href="{{ url('gantt:project_list') }}"
           class="dark-topbar-pill inline-flex items-center gap-1 rounded-md border border-orange-200 bg-orange-50 px-2 py-1 text-[10px] font-semibold text-orange-700 transition hover:bg-orange-100"
           title="Gantt Charts">
            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2"/>
            </svg>
            Gantt
        </a>
        {% endif %}
        {% endif %}
        <div class="relative" x-data="{ open: false }">
            <button type="button" @click="open = !open" class="dark-topbar-pill relative rounded-md border border-transparent p-1 text-slate-400 transition hover:bg-slate-100 hover:text-indigo-600">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
                {% if notifications|length > 0 %}
                <span class="absolute right-1 top-1 flex h-2 w-2">
                    <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-rose-400 opacity-75"></span>
                    <span class="relative inline-flex h-2 w-2 rounded-full bg-rose-500"></span>
                </span>
                {% endif %}
            </button>
            <div x-show="open" x-cloak @click.outside="open = false"
                 class="absolute right-0 z-50 mt-2 w-80 overflow-hidden rounded-xl border border-slate-200 bg-white shadow-xl">
                <div class="border-b border-slate-100 bg-slate-50 px-3 py-2">
                    <h3 class="text-xs font-semibold text-slate-800">Notifications</h3>
                </div>
                <div class="max-h-72 overflow-y-auto">
                    {% if notifications %}
                    {% for notif in notifications %}
                    <div class="border-b border-slate-100 px-3 py-2.5 last:border-0 hover:bg-slate-50" id="notif-{{ notif.id }}">
                        <p class="text-[11px] leading-relaxed text-slate-800">{{ notif.message }}</p>
                        <div class="mt-1 flex items-center justify-between">
                            <span class="text-[9px] text-slate-400">{{ notif.created_at.strftime('%Y-%m-%d') }}</span>
                            <button type="button" class="text-[9px] font-medium text-indigo-600 hover:underline"
                                    hx-post="{{ url('planner:notification_read', n_id=notif.id) }}"
                                    hx-target="#notif-{{ notif.id }}" hx-swap="outerHTML">
                                Mark read
                            </button>
                        </div>
                    </div>
                    {% endfor %}
                    {% else %}
                    <p class="px-4 py-6 text-center text-[11px] text-slate-400">No new notifications</p>
                    {% endif %}
                </div>
            </div>
        </div>
        <button type="button"
                @click="toggleTheme()"
                class="dark-topbar-pill inline-flex h-7 w-7 items-center justify-center rounded-md border border-slate-200 text-slate-500 transition hover:text-indigo-600"
                :title="darkMode ? 'Switch to light mode' : 'Switch to dark mode'">
            <svg x-show="!darkMode" x-cloak class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v2m0 14v2m7-9h2M3 12H5m12.364 6.364l1.414 1.414M5.222 5.222l1.414 1.414m0 10.728l-1.414 1.414m12.728-12.728l-1.414 1.414M12 8a4 4 0 100 8 4 4 0 000-8z"/></svg>
            <svg x-show="darkMode" x-cloak class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
        </button>

        {% if current_project and project_can_invite %}
        <button type="button" @click="inviteModalOpen = true"
                class="dark-soft-btn inline-flex items-center gap-1 rounded-md border border-slate-200 bg-white px-2 py-1 text-[10px] font-semibold text-slate-700 shadow-sm transition hover:border-violet-300 hover:bg-violet-50 hover:text-violet-800">
            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/></svg>
            Add member
        </button>
        {% elif current_team and team_can_invite %}
        <button type="button" @click="inviteModalOpen = true"
                class="dark-soft-btn inline-flex items-center gap-1 rounded-md border border-slate-200 bg-white px-2 py-1 text-[10px] font-semibold text-slate-700 shadow-sm transition hover:border-violet-300 hover:bg-violet-50 hover:text-violet-800">
            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/></svg>
            Add member
        </button>
        {% endif %}
        {% if current_team and team_can_archive %}
        <form method="post" action="{{ url('planner:archive_team_mindmap', team_slug=current_team.slug) }}"
              onsubmit="return window.confirm('Archive all tasks in this team mindmap? You can keep data safe but it will be hidden from board view.')">
            <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
            <button type="submit"
                    class="dark-soft-btn inline-flex items-center gap-1 rounded-md border border-amber-200 bg-white px-2 py-1 text-[10px] font-semibold text-amber-700 shadow-sm transition hover:border-amber-300 hover:bg-amber-50 hover:text-amber-800">
                Archive
            </button>
        </form>
        {% endif %}

        <button type="button" @click="addModalOpen = true; parentIdForModal = ''"
                class="dark-accent-btn inline-flex items-center gap-1 rounded-md bg-indigo-600 px-2.5 py-1 text-[10px] font-semibold text-white shadow-md shadow-indigo-600/20 transition hover:bg-indigo-700 active:scale-[0.98]">
            <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
            New
            <kbd class="hidden rounded border border-white/30 px-1 py-0.5 text-[9px] font-normal opacity-80 xl:inline">⌘K</kbd>
        </button>
        {% if not current_project and ui.top.import_export %}
        <button type="button" @click="importModalOpen = true"
                class="dark-soft-btn inline-flex items-center gap-1 rounded-md border border-slate-200 bg-white px-2 py-1 text-[10px] font-semibold text-slate-700 shadow-sm transition hover:border-indigo-300 hover:bg-indigo-50 hover:text-indigo-700">
            Import
        </button>
        <div class="relative" x-data="{ exportOpen: false }">
            <button type="button" @click="exportOpen = !exportOpen"
                    class="dark-soft-btn inline-flex items-center gap-1 rounded-md border border-emerald-200 bg-white px-2 py-1 text-[10px] font-semibold text-emerald-700 shadow-sm transition hover:border-emerald-300 hover:bg-emerald-50 hover:text-emerald-800">
                Export
                <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div x-show="exportOpen" x-cloak @click.outside="exportOpen = false"
                 class="absolute right-0 z-50 mt-2 w-36 overflow-hidden rounded-lg border border-slate-200 bg-white shadow-lg">
                <a href="{{ u.task_export }}" @click="exportOpen=false"
                   class="block px-3 py-2 text-[11px] font-medium text-slate-700 transition hover:bg-slate-50">CSV</a>
                {% if current_team %}
                <a href="{{ url('planner:mindmap_export_team', team_slug=current_team.slug) }}?format=pdf" @click="exportOpen=false"
                   class="block px-3 py-2 text-[11px] font-medium text-slate-700 transition hover:bg-slate-50">PDF</a>
                {% else %}
                <a href="{{ url('planner:mindmap_export_personal') }}?format=pdf" @click="exportOpen=false"
                   class="block px-3 py-2 text-[11px] font-medium text-slate-700 transition hover:bg-slate-50">PDF</a>
                {% endif %}
            </div>
        </div>
        {% endif %}
    </div>
    </header>

    {% if current_project is defined and current_project %}
    {% include 'partials/_tutorial_banner.jinja' %}
    {% endif %}

    {% if messages %}
<div class="border-b border-amber-100 bg-amber-50 px-5 py-2 text-xs text-amber-900">
    {% for message in messages %}
    <p>{{ message }}</p>
    {% endfor %}
</div>
{% endif %}
{% include 'partials/_invite_share.jinja' %}

<main class="relative flex-1 overflow-auto p-4 sm:p-5">
    <div id="board-hx-busy"
         class="pointer-events-none fixed bottom-5 right-5 z-[70] flex h-10 w-10 items-center justify-center rounded-full border border-indigo-200 bg-white/95 shadow-lg htmx-indicator opacity-0 transition-opacity duration-150">
        <span class="h-4 w-4 animate-spin rounded-full border-2 border-indigo-500 border-t-transparent" aria-hidden="true"></span>
        <span class="sr-only">Updating board…</span>
    </div>
    <div id="task-tree"
         hx-get="{{ u.tree_partial }}"
         hx-trigger="load, refreshTree from:body"
         hx-swap="innerHTML swap:0ms settle:0ms"
         class="min-h-[calc(100vh-8rem)] rounded-2xl border border-slate-200/80 bg-slate-100/70 p-4 shadow-inner dark:border-slate-700/80 dark:bg-slate-900/60">
        {% if task_layout == 'kanban' %}
            {% include 'partials/task_kanban.jinja' %}
        {% elif task_layout == 'cmap' %}
            {% include 'partials/task_cmap.jinja' %}
        {% elif task_layout in ['mindmap', 'mini', 'idea'] %}
            {% include 'partials/task_mindmap.jinja' %}
        {% else %}
            {% include 'partials/task_tree.jinja' %}
        {% endif %}
    </div>
</main>
{% endblock %}

{% block modals %}
<!-- Import tasks -->
<div x-cloak x-show="importModalOpen" x-transition.opacity
     class="fixed inset-0 z-[60] flex items-center justify-center bg-slate-900/40 backdrop-blur-sm p-4">
    <div @click.outside="importModalOpen = false"
         class="w-full max-w-md rounded-2xl border border-slate-200 bg-white p-5 shadow-2xl">
        <div class="mb-4 flex items-start justify-between">
            <div>
                <h2 class="text-sm font-semibold text-slate-900">Import tasks</h2>
                <p class="mt-0.5 text-[11px] text-slate-500">Upload CSV or TXT. Supports tasks and subtasks.</p>
            </div>
            <button type="button" @click="importModalOpen = false" class="rounded-lg p-1 text-slate-400 hover:bg-slate-100">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>
        <form hx-post="{{ u.task_import }}" hx-target="#task-tree" hx-swap="innerHTML swap:0ms settle:0ms"
              hx-sync="#task-tree:queue" hx-indicator="#board-hx-busy"
              enctype="multipart/form-data"
              @htmx:after-request="if(event.detail.successful){ importModalOpen=false; $el.reset(); document.getElementById('import-err').textContent=''; } else { var x=event.detail.xhr; document.getElementById('import-err').textContent = (x && x.responseText) ? x.responseText.trim() : 'Import failed'; }">
            <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
            {{ task_import_form.file }}
            <p id="import-err" class="mt-2 min-h-[1rem] text-[11px] text-rose-600"></p>
            <p class="mt-2 text-[10px] text-slate-400">
                CSV: use columns <code>title,parent,due_date,assignee_username</code> or <code>task,subtask</code>. TXT: indentation creates subtasks.
                4-level samples:
                <a class="text-indigo-600 hover:underline" href="/static/samples/task_import_4_levels.csv" download>CSV</a>
                ·
                <a class="text-indigo-600 hover:underline" href="/static/samples/task_import_4_levels.txt" download>TXT</a>
            </p>
            <div class="mt-5 flex justify-end gap-2">
                <button type="button" @click="importModalOpen = false" class="rounded-lg px-3 py-2 text-xs font-medium text-slate-600 hover:bg-slate-100">Cancel</button>
                <button type="submit" class="rounded-lg bg-indigo-600 px-4 py-2 text-xs font-semibold text-white shadow-sm hover:bg-indigo-700">Import</button>
            </div>
        </form>
    </div>
</div>

<!-- New task -->
<div x-cloak x-show="addModalOpen" x-transition.opacity
     class="fixed inset-0 z-[60] flex items-center justify-center bg-slate-900/40 backdrop-blur-sm p-4">
    <div @click.outside="addModalOpen = false"
         class="w-full max-w-md rounded-2xl border border-slate-200 bg-white p-5 shadow-2xl">
        <div class="mb-4 flex items-start justify-between">
            <div>
                <h2 class="text-sm font-semibold text-slate-900" x-text="parentIdForModal ? 'Add subtask' : 'New root task'"></h2>
                <p class="mt-0.5 text-[11px] text-slate-500" x-text="parentIdForModal ? 'Nested under this card' : 'Top-level OKR'"></p>
            </div>
            <button type="button" @click="addModalOpen = false" class="rounded-lg p-1 text-slate-400 hover:bg-slate-100">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>
        <form hx-post="{{ u.tasks }}" hx-target="#task-tree" hx-swap="innerHTML swap:0ms settle:0ms"
              hx-sync="#task-tree:queue" hx-indicator="#board-hx-busy"
              @htmx:after-request="if(event.detail.successful){ addModalOpen=false; taskStarter=''; $el.reset(); }">
            <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
            <input type="hidden" name="parent_id" x-model="parentIdForModal">
            <div class="space-y-3">
                {# Starter options: no x-cloak here — x-cloak can hide forever if Alpine glitches #}
                <div x-show="!parentIdForModal">
                    <p class="mb-1.5 text-[11px] font-medium text-slate-600">Starter layout</p>
                    <div class="grid gap-2">
                        <label class="flex cursor-pointer items-start gap-2.5 rounded-lg border border-slate-200 bg-slate-50/80 px-3 py-2 transition hover:border-slate-300"
                               :class="(!taskStarter || taskStarter === '') && 'border-indigo-300 bg-indigo-50/60 ring-1 ring-indigo-200'">
                            <input type="radio" name="template" value="" class="mt-0.5" x-model="taskStarter">
                            <span>
                                <span class="block text-xs font-semibold text-slate-800">Blank root</span>
                                <span class="block text-[10px] text-slate-500">One empty top-level task</span>
                            </span>
                        </label>
                        <label class="flex cursor-pointer items-start gap-2.5 rounded-lg border border-amber-200 bg-amber-50/80 px-3 py-2 transition hover:border-amber-300"
                               :class="taskStarter === '99d' && 'border-amber-400 bg-amber-100/80 ring-1 ring-amber-300'">
                            <input type="radio" name="template" value="99d" class="mt-0.5" x-model="taskStarter">
                            <span>
                                <span class="block text-xs font-semibold text-amber-950">99D starter</span>
                                <span class="block text-[10px] leading-snug text-amber-900/80">1×99D → 3×33D → 3×11D each → 11×1D each — 4 levels; badges only</span>
                            </span>
                        </label>
                    </div>
                </div>
                <div>
                    <label class="mb-1 block text-[11px] font-medium text-slate-600">Title <span class="text-rose-500" x-show="taskStarter !== '99d' || parentIdForModal">*</span></label>
                    {{ task_create_form.title }}
                    <p x-show="taskStarter === '99d' && !parentIdForModal" class="mt-1 text-[10px] text-slate-500">Optional. Depth badges show 99D / 33D / 11D / 1D — titles stay blank until you name them.</p>
                </div>
                <div class="grid grid-cols-2 gap-3">
                    <div>
                        <label class="mb-1 block text-[11px] font-medium text-slate-600">Due</label>
                        {{ task_create_form.due_date }}
                    </div>
                    <div>
                        <label class="mb-1 block text-[11px] font-medium text-slate-600">Assignee</label>
                        <select name="assignee_username"
                                class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm">
                            <option value="">Unassigned</option>
                            {% if team_assignee_usernames %}
                                {% for uname in team_assignee_usernames %}
                                <option value="{{ uname }}">{% if uname == user.username %}Me ({{ uname }}){% else %}{{ uname }}{% endif %}</option>
                                {% endfor %}
                            {% else %}
                                <option value="{{ user.username }}">Me ({{ user.username }})</option>
                            {% endif %}
                        </select>
                    </div>
                </div>
                {% if team_assignee_usernames and team_assignee_usernames|length > 1 %}
                <div>
                    <p class="mb-1 block text-[11px] font-medium text-slate-600">Quick assign</p>
                    <div class="flex flex-wrap gap-1.5">
                        <button type="button"
                                @click="$el.closest('form').querySelector('[name=assignee_username]').value=''"
                                class="rounded-full border border-slate-200 bg-white px-2 py-0.5 text-[10px] font-semibold text-slate-600 transition hover:border-slate-300">
                            Clear
                        </button>
                        {% for uname in team_assignee_usernames %}
                        <button type="button"
                                @click="$el.closest('form').querySelector('[name=assignee_username]').value='{{ uname }}'"
                                class="rounded-full border border-slate-200 bg-slate-50 px-2 py-0.5 text-[10px] font-semibold text-slate-700 transition hover:border-indigo-200 hover:bg-indigo-50 hover:text-indigo-700">
                            {% if uname == user.username %}Me{% else %}{{ uname }}{% endif %}
                        </button>
                        {% endfor %}
                    </div>
                </div>
                {% endif %}
            </div>
            <div class="mt-5 flex justify-end gap-2">
                <button type="button" @click="addModalOpen = false" class="rounded-lg px-3 py-2 text-xs font-medium text-slate-600 hover:bg-slate-100">Cancel</button>
                <button type="submit" class="rounded-lg bg-indigo-600 px-4 py-2 text-xs font-semibold text-white shadow-sm hover:bg-indigo-700">Create</button>
            </div>
        </form>
    </div>
</div>

<!-- New team -->
<div x-cloak x-show="teamModalOpen" x-transition.opacity
     class="fixed inset-0 z-[60] flex items-center justify-center bg-slate-900/40 backdrop-blur-sm p-4">
    <div @click.outside="teamModalOpen = false"
         class="w-full max-w-md rounded-2xl border border-slate-200 bg-white p-5 shadow-2xl">
        <div class="mb-4 flex items-start justify-between">
            <div>
                <h2 class="text-sm font-semibold text-slate-900">Create team</h2>
                <p class="mt-0.5 text-[11px] text-slate-500">Shared board for your group — you’ll be the owner.</p>
            </div>
            <button type="button" @click="teamModalOpen = false" class="rounded-lg p-1 text-slate-400 hover:bg-slate-100">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>
        <form hx-post="{{ url('teams:create') }}"
              @htmx:after-request="if(event.detail.successful){ teamModalOpen=false; teamCreateError=''; $el.reset(); } else { var x=event.detail.xhr; teamCreateError = (x && x.responseText) ? x.responseText.trim() : 'Unable to create team'; }">
            <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
            <label class="mb-1 block text-[11px] font-medium text-slate-600">Team name</label>
            {{ team_create_form.name }}
            <label class="mb-1 mt-3 block text-[11px] font-medium text-slate-600">Sidebar color</label>
            {{ team_create_form.sidebar_color }}
            <p class="mt-2 min-h-[1rem] text-[11px] text-rose-600" x-text="teamCreateError"></p>
            <div class="mt-5 flex justify-end gap-2">
                <button type="button" @click="teamModalOpen = false" class="rounded-lg px-3 py-2 text-xs font-medium text-slate-600 hover:bg-slate-100">Cancel</button>
                <button type="submit" class="rounded-lg bg-violet-600 px-4 py-2 text-xs font-semibold text-white shadow-sm hover:bg-violet-700">Create team</button>
            </div>
        </form>
    </div>
</div>

<!-- Add member: project-only OR team workspace -->
{% if current_project and project_can_invite %}
<div x-cloak x-show="inviteModalOpen" x-transition.opacity
     class="fixed inset-0 z-[60] flex items-center justify-center bg-slate-900/40 backdrop-blur-sm p-4">
    <div @click.outside="inviteModalOpen = false"
         class="w-full max-w-sm rounded-2xl border border-slate-200 bg-white p-5 shadow-2xl">
        <div class="mb-3 flex items-start justify-between">
            <div>
                <h2 class="text-sm font-semibold text-slate-900">Add to this project</h2>
                <p class="mt-0.5 text-[11px] text-slate-500">They get access to <span class="font-medium text-slate-700">{{ current_project.name }}</span> only — not your other projects.</p>
            </div>
            <button type="button" @click="inviteModalOpen = false" class="rounded-lg p-1 text-slate-400 hover:bg-slate-100">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>
        <form hx-post="{{ url('projects:member_add', slug=current_project.slug) }}"
              hx-target="#member-add-err"
              hx-swap="innerHTML"
              @htmx:after-request="if(event.detail.successful){ inviteModalOpen=false; $el.reset(); document.getElementById('member-add-err').textContent=''; }">
            <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
            <input type="hidden" name="next" value="{{ request.path }}">
            <label class="mb-1 block text-[11px] font-medium text-slate-600">Username or email</label>
            <input type="text" name="who" required
                   placeholder="Username or email"
                   class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20"
                   autocomplete="off">
            <input type="hidden" name="role" value="member">
            <p id="member-add-err" class="mt-1 min-h-[1rem] text-[11px] text-rose-600"></p>
            <div class="mt-4 flex justify-end gap-2">
                <button type="button" @click="inviteModalOpen = false" class="rounded-lg px-3 py-2 text-xs font-medium text-slate-600 hover:bg-slate-100">Cancel</button>
                <button type="submit" class="rounded-lg bg-violet-600 px-4 py-2 text-xs font-semibold text-white shadow-sm hover:bg-violet-700">Add</button>
            </div>
        </form>
    </div>
</div>
{% elif current_team and team_can_invite %}
<div x-cloak x-show="inviteModalOpen" x-transition.opacity
     class="fixed inset-0 z-[60] flex items-center justify-center bg-slate-900/40 backdrop-blur-sm p-4">
    <div @click.outside="inviteModalOpen = false"
         class="w-full max-w-sm rounded-2xl border border-slate-200 bg-white p-5 shadow-2xl">
        <div class="mb-3 flex items-start justify-between">
            <div>
                <h2 class="text-sm font-semibold text-slate-900">Add to team workspace</h2>
                <p class="mt-0.5 text-[11px] text-slate-500">Username adds them now. Email sends a join link. Does not open your other projects.</p>
            </div>
            <button type="button" @click="inviteModalOpen = false" class="rounded-lg p-1 text-slate-400 hover:bg-slate-100">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>
        <form hx-post="{{ url('teams:member_add', team_slug=current_team.slug) }}"
              hx-target="#member-add-err"
              hx-swap="innerHTML"
              @htmx:after-request="if(event.detail.successful){ inviteModalOpen=false; $el.reset(); document.getElementById('member-add-err').textContent=''; }">
            <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
            <input type="hidden" name="next" value="{{ request.path }}">
            <label class="mb-1 block text-[11px] font-medium text-slate-600">Username or email</label>
            {{ team_invite_form.who }}
            <label class="mb-1 mt-2 block text-[11px] font-medium text-slate-600">Role</label>
            {{ team_invite_form.role }}
            <p id="member-add-err" class="mt-1 min-h-[1rem] text-[11px] text-rose-600"></p>
            <div class="mt-4 flex justify-end gap-2">
                <button type="button" @click="inviteModalOpen = false" class="rounded-lg px-3 py-2 text-xs font-medium text-slate-600 hover:bg-slate-100">Cancel</button>
                <button type="submit" class="rounded-lg bg-violet-600 px-4 py-2 text-xs font-semibold text-white shadow-sm hover:bg-violet-700">Add</button>
            </div>
        </form>
    </div>
</div>
{% endif %}
<script>
(function () {
  var _scroll = null;
  var ZOOM_MIN = 0.4;
  var ZOOM_MAX = 1.6;
  var ZOOM_STEP = 0.1;

  document.addEventListener('htmx:beforeSwap', function (e) {
    if (e.detail.target && e.detail.target.id === 'task-tree') {
      var el = document.getElementById('mm-scroll-area');
      _scroll = el ? { x: el.scrollLeft, y: el.scrollTop } : null;
    }
  });
  document.addEventListener('htmx:afterSettle', function (e) {
    if (e.detail.target && e.detail.target.id === 'task-tree' && _scroll) {
      var el = document.getElementById('mm-scroll-area');
      if (el) { el.scrollLeft = _scroll.x; el.scrollTop = _scroll.y; }
      _scroll = null;
    }
    bindBoardZoomWheel();
  });

  function currentZoom() {
    var z = parseFloat(getComputedStyle(document.documentElement).getPropertyValue('--board-zoom'));
    return Number.isFinite(z) && z > 0 ? z : 1;
  }

  function setZoom(next) {
    next = Math.round(Math.min(ZOOM_MAX, Math.max(ZOOM_MIN, next)) * 100) / 100;
    document.documentElement.style.setProperty('--board-zoom', String(next));
    try { localStorage.setItem('boardZoom', String(next)); } catch (err) {}
    try {
      if (window.Alpine && typeof Alpine.$data === 'function') {
        var d = Alpine.$data(document.body);
        if (d && typeof d.boardZoom !== 'undefined') d.boardZoom = next;
      }
    } catch (err) {}
  }

  function bindBoardZoomWheel() {
    ['mm-scroll-area', 'tree-zoom-outer', 'task-tree'].forEach(function (id) {
      var el = document.getElementById(id);
      if (!el || el.dataset.zoomWheelBound === '1') return;
      el.dataset.zoomWheelBound = '1';
      el.addEventListener('wheel', function (e) {
        if (!(e.ctrlKey || e.metaKey)) return;
        e.preventDefault();
        var cur = currentZoom();
        setZoom(e.deltaY < 0 ? cur + ZOOM_STEP : cur - ZOOM_STEP);
      }, { passive: false });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', bindBoardZoomWheel);
  } else {
    bindBoardZoomWheel();
  }
})();
</script>
{% endblock %}
