<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="{{ csrf_token }}">
    <title>{% if is_signup %}Sign up{% else %}Log in{% endif %} · MindMap Tasks</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>body { font-family: Inter, system-ui, sans-serif; }</style>
</head>
<body class="min-h-screen bg-gradient-to-br from-slate-100 via-indigo-50/40 to-violet-50 flex items-center justify-center p-4">
<div class="w-full max-w-md rounded-2xl border border-slate-200/80 bg-white p-8 shadow-xl shadow-slate-200/50">
    <div class="mb-6 text-center">
        <div class="mx-auto mb-3 flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-indigo-500 to-violet-500 text-white shadow-lg shadow-indigo-500/30">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
        </div>
        <h1 class="text-lg font-semibold text-slate-900">{% if is_signup %}Create account{% else %}Welcome back{% endif %}</h1>
        <p class="mt-1 text-sm text-slate-500">{% if is_signup %}Workspace, teams, and OKRs in one place.{% else %}Sign in to continue.{% endif %}</p>
    </div>

    {% if messages %}
    <div class="mb-4 rounded-lg border border-rose-100 bg-rose-50 px-3 py-2 text-sm text-rose-800">
        {% for message in messages %}{{ message }}{% endfor %}
    </div>
    {% endif %}

    {% if form.non_field_errors() %}
    <div class="mb-4 rounded-lg border border-rose-100 bg-rose-50 px-3 py-2 text-sm text-rose-800">
        {% for err in form.non_field_errors() %}{{ err }}{% endfor %}
    </div>
    {% endif %}

    <form method="post" class="space-y-4">
        <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
        {% if is_signup %}
        <div>
            <label class="mb-1 block text-xs font-medium text-slate-600">Username</label>
            {{ form.username }}
            {% if form.username.errors %}<p class="mt-1 text-xs text-rose-600">{{ form.username.errors[0] }}</p>{% endif %}
        </div>
        <div>
            <label class="mb-1 block text-xs font-medium text-slate-600">Password</label>
            {{ form.password1 }}
            {% if form.password1.errors %}<p class="mt-1 text-xs text-rose-600">{{ form.password1.errors[0] }}</p>{% endif %}
        </div>
        <div>
            <label class="mb-1 block text-xs font-medium text-slate-600">Confirm password</label>
            {{ form.password2 }}
            {% if form.password2.errors %}<p class="mt-1 text-xs text-rose-600">{{ form.password2.errors[0] }}</p>{% endif %}
        </div>
        {% else %}
        <div>
            <label class="mb-1 block text-xs font-medium text-slate-600">Username</label>
            {{ form.username }}
        </div>
        <div>
            <label class="mb-1 block text-xs font-medium text-slate-600">Password</label>
            {{ form.password }}
        </div>
        {% endif %}

        <button type="submit" class="w-full rounded-lg bg-indigo-600 py-2.5 text-sm font-semibold text-white shadow-md shadow-indigo-600/20 transition hover:bg-indigo-700">
            {% if is_signup %}Sign up{% else %}Log in{% endif %}
        </button>
    </form>

    <p class="mt-6 text-center text-xs text-slate-500">
        {% if is_signup %}
        Already have an account? <a href="{{ url('users:login') }}" class="font-medium text-indigo-600 hover:underline">Log in</a>
        {% else %}
        New here? <a href="{{ url('users:signup') }}" class="font-medium text-indigo-600 hover:underline">Create account</a>
        {% endif %}
    </p>
</div>
</body>
</html>
