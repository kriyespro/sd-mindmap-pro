<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="{{ csrf_token }}">
    <title>{% if is_signup %}Sign up{% else %}Log in{% endif %} · DCPMind</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="{{ static('css/tailwind.css') }}">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>body { font-family: Inter, system-ui, sans-serif; }</style>
</head>
<body class="min-h-screen bg-gradient-to-br from-slate-100 via-teal-50/50 to-slate-200 flex items-center justify-center p-4">
<div class="w-full max-w-md rounded-2xl border border-slate-200/80 bg-white p-8 shadow-xl shadow-slate-200/50">
    <div class="mb-6 text-center">
        <div class="mx-auto mb-3 flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-teal-600 to-slate-800 text-[11px] font-black tracking-tight text-white shadow-lg shadow-teal-700/25">
            DCP
        </div>
        <p class="text-[11px] font-semibold uppercase tracking-wider text-teal-800">DCPMind</p>
        <h1 class="mt-1 text-lg font-semibold text-slate-900">{% if is_signup %}Create account{% else %}Welcome back{% endif %}</h1>
        <p class="mt-1 text-sm text-slate-500">{% if is_signup %}Dream Conversion Process — map work and ship it.{% else %}Sign in to your mind tool.{% endif %}</p>
    </div>

    {% if messages %}
    <div class="mb-4 rounded-lg border border-rose-100 bg-rose-50 px-3 py-2 text-sm text-rose-800">
        {% for message in messages %}{{ message }}{% endfor %}
    </div>
    {% endif %}

    {% if form.non_field_errors() %}
    <div class="mb-4 rounded-lg border border-rose-100 bg-rose-50 px-3 py-2 text-sm text-rose-800">
        {% for err in form.non_field_errors() %}{{ err }}{% endfor %}
    </div>
    {% endif %}

    <form method="post" class="space-y-4">
        <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
        {% if request.GET.get('next') %}
        <input type="hidden" name="next" value="{{ request.GET.get('next') }}">
        {% endif %}
        {% if is_signup %}
        <div>
            <label class="mb-1 block text-xs font-medium text-slate-600">Username</label>
            {{ form.username }}
            {% if form.username.errors %}<p class="mt-1 text-xs text-rose-600">{{ form.username.errors[0] }}</p>{% endif %}
        </div>
        <div>
            <label class="mb-1 block text-xs font-medium text-slate-600">Email</label>
            {{ form.email }}
            {% if form.email.errors %}<p class="mt-1 text-xs text-rose-600">{{ form.email.errors[0] }}</p>{% endif %}
        </div>
        <div>
            <label class="mb-1 block text-xs font-medium text-slate-600">Password</label>
            {{ form.password1 }}
            {% if form.password1.errors %}<p class="mt-1 text-xs text-rose-600">{{ form.password1.errors[0] }}</p>{% endif %}
        </div>
        <div>
            <label class="mb-1 block text-xs font-medium text-slate-600">Confirm password</label>
            {{ form.password2 }}
            {% if form.password2.errors %}<p class="mt-1 text-xs text-rose-600">{{ form.password2.errors[0] }}</p>{% endif %}
        </div>
        {% else %}
        <div>
            <label class="mb-1 block text-xs font-medium text-slate-600">Username</label>
            {{ form.username }}
        </div>
        <div>
            <label class="mb-1 block text-xs font-medium text-slate-600">Password</label>
            {{ form.password }}
        </div>
        {% endif %}

        <button type="submit" class="w-full rounded-lg bg-indigo-600 py-2.5 text-sm font-semibold text-white shadow-md shadow-indigo-600/20 transition hover:bg-indigo-700">
            {% if is_signup %}Sign up{% else %}Log in{% endif %}
        </button>
    </form>

    <p class="mt-6 text-center text-xs text-slate-500">
        {% if is_signup %}
        Already have an account?
        <a href="{% if request.GET.get('next') %}{{ url('users:login') }}?next={{ request.GET.get('next') }}{% else %}{{ url('users:login') }}{% endif %}" class="font-medium text-indigo-600 hover:underline">Log in</a>
        {% else %}
        New here?
        <a href="{% if request.GET.get('next') %}{{ url('users:signup') }}?next={{ request.GET.get('next') }}{% else %}{{ url('users:signup') }}{% endif %}" class="font-medium text-indigo-600 hover:underline">Create account</a>
        {% endif %}
    </p>
</div>
</body>
</html>
