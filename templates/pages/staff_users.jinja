{% extends 'layouts/staff_shell.jinja' %}
{% block title %}People{% endblock %}

{% block main %}
<div class="border-b px-4 py-2" style="border-color: var(--mc-line); background: var(--mc-paper)">
    <h1 class="text-sm font-bold">People</h1>
    <p class="text-[11px]" style="color: var(--mc-muted)">Search · filter · open dossier · convert</p>
</div>

<div class="p-3">
    <div class="mb-2 flex flex-wrap gap-1">
        {% for value, label in filter_choices %}
        <a href="{{ url('staff_dashboard:users') }}?filter={{ value }}{% if q %}&q={{ q }}{% endif %}{% if plan_filter %}&plan={{ plan_filter }}{% endif %}"
           class="mc-chip {% if filter_key == value %}mc-chip-on{% endif %}">{{ label }}</a>
        {% endfor %}
    </div>

    <form class="mb-2 flex flex-wrap items-center gap-1.5"
          hx-get="{{ url('staff_dashboard:users_partial') }}"
          hx-target="#staff-user-rows"
          hx-trigger="keyup changed delay:300ms from:#user-q, change from:#user-plan"
          hx-indicator="#user-search-busy">
        <input type="hidden" name="filter" value="{{ filter_key }}">
        <input id="user-q" type="search" name="q" value="{{ q }}" placeholder="Search…"
               class="mc-input w-full sm:max-w-[14rem]" autocomplete="off">
        <select id="user-plan" name="plan" class="mc-input">
            <option value="">All plans</option>
            {% for value, label in plan_choices %}
            <option value="{{ value }}" {% if plan_filter == value %}selected{% endif %}>{{ label }}</option>
            {% endfor %}
        </select>
        <span id="user-search-busy" class="htmx-indicator text-[10px]" style="color: var(--mc-muted)">…</span>
    </form>

    <div class="mc-card overflow-hidden">
        <table class="mc-table w-full text-left text-[12px]">
            <thead style="background: #efe9dc">
                <tr>
                    <th class="px-2.5 py-1.5">User</th>
                    <th class="px-2.5 py-1.5">Plan</th>
                    <th class="px-2.5 py-1.5">Tm</th>
                    <th class="px-2.5 py-1.5">$</th>
                    <th class="px-2.5 py-1.5">Login</th>
                    <th class="px-2.5 py-1.5 text-right">Act</th>
                </tr>
            </thead>
            <tbody id="staff-user-rows">
                {% include 'partials/_staff_user_rows.jinja' %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
