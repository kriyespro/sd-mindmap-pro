{% extends 'layouts/staff_shell.jinja' %}
{% block title %}@{{ target.username }}{% endblock %}

{% block main %}
<div class="border-b px-4 py-2" style="border-color: var(--mc-line); background: var(--mc-paper)">
    <a href="{{ url('staff_dashboard:users') }}" class="mc-link text-[10px]">← People</a>
    <div class="mt-1 flex flex-wrap items-start justify-between gap-2">
        <div>
            <h1 class="text-sm font-bold">@{{ target.username }}{% if target.is_staff %} <span class="text-[10px]" style="color: var(--mc-accent)">staff</span>{% endif %}</h1>
            <p class="text-[11px]" style="color: var(--mc-muted)">{{ target.email or 'No email' }} · {{ target.date_joined.strftime('%Y-%m-%d') }} · login {{ target.last_login.strftime('%Y-%m-%d') if target.last_login else 'never' }}</p>
        </div>
        <div class="flex flex-wrap gap-1 text-[10px] font-semibold">
            <span class="mc-chip mc-chip-on">{{ profile.plan }}</span>
            {% if profile.trial_active %}<span class="mc-chip" style="background: var(--mc-warn-soft); border-color: #e2cfa3; color: var(--mc-warn)">trial → {{ profile.trial_ends }}</span>{% endif %}
            <span class="mc-chip" style="background: #eef6f1; border-color: #b7d4c6; color: var(--mc-money)">{{ pay_total }} $</span>
            {% if target.is_active %}<span class="mc-chip">active</span>{% else %}<span class="mc-chip" style="color: var(--mc-danger)">off</span>{% endif %}
        </div>
    </div>
</div>

<div class="grid gap-3 p-3 lg:grid-cols-12">
    <section class="mc-card p-3 lg:col-span-5" style="border-color: #b7d4c6; background: #f0f7f3">
        <h2 class="text-[10px] font-semibold uppercase tracking-wider" style="color: var(--mc-money)">Convert · pay + grant</h2>
        <form action="{{ url('staff_dashboard:user_convert', user_id=target.id) }}" method="post" class="mt-2 space-y-1.5">
            <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
            <div class="grid grid-cols-3 gap-1.5">
                <div class="col-span-2">
                    <label class="text-[9px] font-semibold uppercase" style="color: var(--mc-muted)">Amount</label>
                    <input name="amount" type="number" step="0.01" min="0.01" required
                           value="{{ plan_price[profile.plan] if profile.plan in plan_price else plan_price.team }}"
                           class="mc-input mt-0.5 w-full">
                </div>
                <div>
                    <label class="text-[9px] font-semibold uppercase" style="color: var(--mc-muted)">Cur</label>
                    <input name="currency" value="INR" maxlength="8" class="mc-input mt-0.5 w-full">
                </div>
            </div>
            <div>
                <label class="text-[9px] font-semibold uppercase" style="color: var(--mc-muted)">Plan</label>
                {% set grant_default = profile.plan if profile.plan != 'solo' else 'team' %}
                <select name="plan" class="mc-input mt-0.5 w-full">
                    {% for value, label in plan_choices %}
                    <option value="{{ value }}" {% if value == grant_default %}selected{% endif %}>{{ label }} · ₹{{ plan_price[value] }}</option>
                    {% endfor %}
                </select>
            </div>
            <div>
                <label class="text-[9px] font-semibold uppercase" style="color: var(--mc-muted)">Note</label>
                <input name="description" placeholder="UPI / bank ref…" class="mc-input mt-0.5 w-full">
            </div>
            <button type="submit" class="mc-btn mc-btn-money w-full !py-2 text-[12px]">Record payment + set plan</button>
        </form>
    </section>

    <section class="space-y-2 lg:col-span-7">
        <div class="mc-card p-3">
            <h2 class="text-[10px] font-semibold uppercase tracking-wider" style="color: var(--mc-muted)">Controls</h2>
            <div class="mt-2 flex flex-wrap gap-1.5">
                <form action="{{ url('staff_dashboard:user_plan', user_id=target.id) }}" method="post" class="inline-flex items-center gap-1">
                    <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
                    <input type="hidden" name="next" value="{{ request.path }}">
                    <select name="plan" class="mc-input">
                        {% for value, label in plan_choices %}
                        <option value="{{ value }}" {% if profile.plan == value %}selected{% endif %}>{{ label }}</option>
                        {% endfor %}
                    </select>
                    <button type="submit" class="mc-btn mc-btn-primary">Set plan</button>
                </form>
                <form action="{{ url('staff_dashboard:user_trial', user_id=target.id) }}" method="post">
                    <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
                    <input type="hidden" name="next" value="{{ request.path }}">
                    <input type="hidden" name="action" value="extend">
                    <input type="hidden" name="days" value="7">
                    <button type="submit" class="mc-btn mc-btn-ghost" style="color: var(--mc-warn)">+7d trial</button>
                </form>
                <form action="{{ url('staff_dashboard:user_trial', user_id=target.id) }}" method="post">
                    <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
                    <input type="hidden" name="next" value="{{ request.path }}">
                    <input type="hidden" name="action" value="end">
                    <button type="submit" class="mc-btn mc-btn-ghost">End trial</button>
                </form>
                {% if not target.is_superuser %}
                <form action="{{ url('staff_dashboard:user_active', user_id=target.id) }}" method="post">
                    <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
                    <input type="hidden" name="next" value="{{ request.path }}">
                    <input type="hidden" name="is_active" value="{{ 'false' if target.is_active else 'true' }}">
                    <button type="submit" class="mc-btn mc-btn-ghost" style="color: {% if target.is_active %}var(--mc-danger){% else %}var(--mc-money){% endif %}">
                        {% if target.is_active %}Deactivate{% else %}Reactivate{% endif %}
                    </button>
                </form>
                {% endif %}
            </div>
        </div>

        <div class="grid grid-cols-3 gap-1.5">
            <div class="mc-kpi !py-1.5">
                <p class="text-[9px] uppercase" style="color: var(--mc-muted)">Teams</p>
                <p class="text-sm font-bold">{{ memberships|length }} <span class="text-[10px] font-normal" style="color: var(--mc-muted)">/ {{ seat_limit }} seats</span></p>
            </div>
            <div class="mc-kpi !py-1.5">
                <p class="text-[9px] uppercase" style="color: var(--mc-muted)">Tasks</p>
                <p class="text-sm font-bold">{{ task_count }}</p>
            </div>
            <div class="mc-kpi !py-1.5">
                <p class="text-[9px] uppercase" style="color: var(--mc-muted)">Projects</p>
                <p class="text-sm font-bold">{{ project_count }}</p>
            </div>
        </div>

        <div class="mc-card p-3">
            <h2 class="text-[10px] font-semibold uppercase tracking-wider" style="color: var(--mc-muted)">Teams</h2>
            <ul class="mt-1.5 space-y-1">
                {% for m in memberships %}
                <li class="flex justify-between rounded border px-2 py-1 text-[11px]" style="border-color: var(--mc-line); background: #fff">
                    <span class="font-medium">{{ m.team.name }}</span>
                    <span style="color: var(--mc-muted)">{% if m.is_owner %}owner{% else %}member{% endif %}</span>
                </li>
                {% else %}
                <li class="text-[11px]" style="color: var(--mc-muted)">None</li>
                {% endfor %}
            </ul>
        </div>
    </section>

    <section class="mc-card overflow-hidden lg:col-span-12">
        <div class="border-b px-2.5 py-1.5" style="border-color: var(--mc-line)">
            <h2 class="text-[10px] font-semibold uppercase tracking-wider" style="color: var(--mc-muted)">Payments</h2>
        </div>
        <table class="mc-table w-full text-left text-[12px]">
            <thead>
                <tr>
                    <th class="px-2.5 py-1">When</th>
                    <th class="px-2.5 py-1">Amount</th>
                    <th class="px-2.5 py-1">Note</th>
                </tr>
            </thead>
            <tbody>
                {% for p in payments %}
                <tr class="border-t" style="border-color: var(--mc-line)">
                    <td class="px-2.5 py-1 font-mono text-[10px]" style="color: var(--mc-muted)">{{ p.created_at.strftime('%Y-%m-%d %H:%M') }}</td>
                    <td class="px-2.5 py-1 font-semibold tabular-nums" style="color: var(--mc-money)">{{ p.currency }} {{ p.amount }}</td>
                    <td class="px-2.5 py-1 text-[11px]" style="color: var(--mc-muted)">{{ p.description or '—' }}</td>
                </tr>
                {% else %}
                <tr><td colspan="3" class="px-2.5 py-4 text-center text-[11px]" style="color: var(--mc-muted)">No payments — convert above</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </section>
</div>
{% endblock %}
