{% extends 'layouts/staff_shell.jinja' %}
{% block title %}Command center{% endblock %}

{% block main %}
<div class="border-b border-slate-800 bg-slate-900/50 px-6 py-5 sm:px-8">
    <div class="flex flex-wrap items-end justify-between gap-3">
        <div>
            <h1 class="text-xl font-bold text-white">Command center</h1>
            <p class="mt-1 text-sm text-slate-400">Money, conversion, growth, and who needs a call today.</p>
        </div>
        <p class="text-[11px] text-slate-500">Updated {{ as_of.strftime('%H:%M') }} · auto-refresh 60s</p>
    </div>
</div>

<div class="space-y-8 p-6 sm:p-8"
     hx-get="{{ url('staff_dashboard:stats') }}"
     hx-trigger="every 60s"
     hx-target="#ceo-kpi-strip"
     hx-swap="innerHTML">

    <div id="ceo-kpi-strip">
        {% include 'partials/_staff_kpi_strip.jinja' %}
    </div>

    <div class="grid gap-6 lg:grid-cols-12">
        <section class="rounded-xl border border-slate-800 bg-slate-900/50 p-5 lg:col-span-5">
            <h2 class="text-xs font-semibold uppercase tracking-wider text-slate-500">Plan mix · MRR ₹{{ mrr_inr }}</h2>
            <div class="mt-4 space-y-3">
                {% set total_plans = (plan_counts.solo or 0) + (plan_counts.team or 0) + (plan_counts.team_20 or 0) %}
                {% if total_plans == 0 %}{% set total_plans = 1 %}{% endif %}
                <div>
                    <div class="mb-1 flex justify-between text-xs">
                        <span class="text-slate-400">Starter · ₹{{ plan_price.solo }}</span>
                        <span class="font-semibold tabular-nums text-white">{{ plan_counts.solo }}</span>
                    </div>
                    <div class="h-2 overflow-hidden rounded-full bg-slate-800">
                        <div class="h-full rounded-full bg-slate-400" style="width:{{ (plan_counts.solo / total_plans * 100)|round|int }}%"></div>
                    </div>
                </div>
                <div>
                    <div class="mb-1 flex justify-between text-xs">
                        <span class="text-slate-400">Team · ₹{{ plan_price.team }}</span>
                        <span class="font-semibold tabular-nums text-indigo-300">{{ plan_counts.team }}</span>
                    </div>
                    <div class="h-2 overflow-hidden rounded-full bg-slate-800">
                        <div class="h-full rounded-full bg-indigo-500" style="width:{{ (plan_counts.team / total_plans * 100)|round|int }}%"></div>
                    </div>
                </div>
                <div>
                    <div class="mb-1 flex justify-between text-xs">
                        <span class="text-slate-400">Pro · ₹{{ plan_price.team_20 }}</span>
                        <span class="font-semibold tabular-nums text-fuchsia-300">{{ plan_counts.team_20 }}</span>
                    </div>
                    <div class="h-2 overflow-hidden rounded-full bg-slate-800">
                        <div class="h-full rounded-full bg-fuchsia-500" style="width:{{ (plan_counts.team_20 / total_plans * 100)|round|int }}%"></div>
                    </div>
                </div>
            </div>
            <p class="mt-4 text-[11px] text-slate-500">MRR = seats on plan × list price (manual billing).</p>

            <div class="mt-6 grid gap-4 sm:grid-cols-2">
                <div>
                    <h3 class="text-xs font-semibold uppercase tracking-wider text-slate-500">Signups · 14d</h3>
                    <div class="mt-3 flex h-14 items-end gap-1">
                        {% for s in sparkline %}
                        {% set h = ((s.count / spark_max) * 100)|round|int %}
                        <div class="flex-1 rounded-t bg-indigo-500/80" style="height:{{ h if h >= 8 else (4 if s.count == 0 else 8) }}%" title="{{ s.date.isoformat() }}: {{ s.count }}"></div>
                        {% endfor %}
                    </div>
                </div>
                <div>
                    <h3 class="text-xs font-semibold uppercase tracking-wider text-slate-500">Cash · 14d</h3>
                    <div class="mt-3 flex h-14 items-end gap-1">
                        {% for s in cash_spark %}
                        {% set h = ((s.count / cash_spark_max) * 100)|round|int %}
                        <div class="flex-1 rounded-t bg-emerald-500/80" style="height:{{ h if h >= 8 else (4 if s.count == 0 else 8) }}%" title="{{ s.date.isoformat() }}: {{ s.amount }}"></div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </section>

        <section class="rounded-xl border border-amber-900/40 bg-amber-950/20 p-5 lg:col-span-7">
            <h2 class="text-xs font-semibold uppercase tracking-wider text-amber-400/90">Needs your attention</h2>
            <div class="mt-4 grid gap-4 sm:grid-cols-2">
                <div>
                    <div class="flex items-center justify-between">
                        <p class="text-[11px] font-semibold text-slate-400">Trials ending ≤ 3 days</p>
                        <a href="{{ url('staff_dashboard:users') }}?filter=trial_soon" class="text-[10px] font-semibold text-indigo-400 hover:underline">View all</a>
                    </div>
                    <ul class="mt-2 space-y-2">
                        {% for p in trials_ending_soon %}
                        <li>
                            <a href="{{ url('staff_dashboard:user_detail', user_id=p.user.id) }}"
                               class="flex items-center justify-between gap-2 rounded-lg border border-slate-800 bg-slate-900/60 px-3 py-2 text-xs hover:border-indigo-700">
                                <span class="font-medium text-white">@{{ p.user.username }}</span>
                                <span class="tabular-nums text-amber-300">{{ p.trial_ends }}</span>
                            </a>
                        </li>
                        {% else %}
                        <li class="text-xs text-slate-500">None — clear runway.</li>
                        {% endfor %}
                    </ul>
                </div>
                <div>
                    <div class="flex items-center justify-between">
                        <p class="text-[11px] font-semibold text-slate-400">Paid plan · no payment logged</p>
                        <a href="{{ url('staff_dashboard:users') }}?filter=unpaid" class="text-[10px] font-semibold text-indigo-400 hover:underline">View all</a>
                    </div>
                    <ul class="mt-2 space-y-2">
                        {% for u in unpaid_paid %}
                        <li>
                            <a href="{{ url('staff_dashboard:user_detail', user_id=u.id) }}"
                               class="block rounded-lg border border-rose-900/40 bg-rose-950/20 px-3 py-2 text-xs hover:border-rose-700">
                                <p class="font-medium text-white">@{{ u.username }}</p>
                                <p class="text-rose-300/80">{{ u.profile.plan }} · record cash or downgrade</p>
                            </a>
                        </li>
                        {% else %}
                        <li class="text-xs text-slate-500">Books match plans.</li>
                        {% endfor %}
                    </ul>
                </div>
                <div>
                    <p class="text-[11px] font-semibold text-slate-400">Teams near seat limit</p>
                    <ul class="mt-2 space-y-2">
                        {% for row in attention_seats %}
                        <li class="rounded-lg border border-slate-800 bg-slate-900/60 px-3 py-2 text-xs">
                            <p class="font-medium text-white">{{ row.team.name }}</p>
                            <p class="text-slate-400">
                                <a href="{{ url('staff_dashboard:user_detail', user_id=row.owner.id) }}" class="text-indigo-400 hover:underline">@{{ row.owner.username }}</a>
                                · {{ row.filled }}/{{ row.limit }} · {{ row.plan }}
                            </p>
                        </li>
                        {% else %}
                        <li class="text-xs text-slate-500">No teams at capacity.</li>
                        {% endfor %}
                    </ul>
                </div>
                <div>
                    <div class="flex items-center justify-between">
                        <p class="text-[11px] font-semibold text-slate-400">Dormant (no login 14d)</p>
                        <a href="{{ url('staff_dashboard:users') }}?filter=dormant" class="text-[10px] font-semibold text-indigo-400 hover:underline">View all</a>
                    </div>
                    <ul class="mt-2 space-y-2">
                        {% for u in dormant_users %}
                        <li>
                            <a href="{{ url('staff_dashboard:user_detail', user_id=u.id) }}"
                               class="flex items-center justify-between gap-2 rounded-lg border border-slate-800 bg-slate-900/60 px-3 py-2 text-xs hover:border-indigo-700">
                                <span class="font-medium text-white">@{{ u.username }}</span>
                                <span class="text-slate-500">{{ u.last_login.strftime('%b %d') if u.last_login else 'never' }}</span>
                            </a>
                        </li>
                        {% else %}
                        <li class="text-xs text-slate-500">Everyone active recently.</li>
                        {% endfor %}
                    </ul>
                </div>
            </div>
            <div class="mt-4 flex flex-wrap gap-2">
                <a href="{{ url('staff_dashboard:users') }}?filter=trial_soon"
                   class="rounded-lg bg-amber-600 px-3 py-2 text-xs font-bold text-white hover:bg-amber-500">Convert trials</a>
                <a href="{{ url('staff_dashboard:users') }}"
                   class="rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-xs font-semibold text-slate-200 hover:bg-slate-800">People directory</a>
            </div>
        </section>
    </div>

    <div class="grid gap-6 lg:grid-cols-2">
        <section class="overflow-hidden rounded-xl border border-slate-800 bg-slate-900/40">
            <div class="flex items-center justify-between border-b border-slate-800 px-4 py-3">
                <h2 class="text-xs font-semibold uppercase tracking-wider text-slate-500">Recent signups</h2>
                <a href="{{ url('staff_dashboard:users') }}" class="text-[11px] font-semibold text-indigo-400 hover:underline">All people</a>
            </div>
            <table class="w-full text-left text-sm">
                <thead class="text-[10px] uppercase tracking-wide text-slate-500">
                    <tr>
                        <th class="px-4 py-2">User</th>
                        <th class="px-4 py-2">Plan</th>
                        <th class="px-4 py-2">Joined</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-800">
                    {% for u in recent_signups %}
                    <tr class="text-slate-300 hover:bg-slate-900/80">
                        <td class="px-4 py-2.5">
                            <a href="{{ url('staff_dashboard:user_detail', user_id=u.id) }}" class="block">
                                <p class="font-medium text-white hover:text-indigo-300">@{{ u.username }}</p>
                                <p class="text-[10px] text-slate-500">{{ u.email or '—' }}</p>
                            </a>
                        </td>
                        <td class="px-4 py-2.5 text-xs">
                            {% if u.profile %}
                            <span class="rounded bg-slate-800 px-1.5 py-0.5 font-semibold text-slate-200">{{ u.profile.plan }}</span>
                            {% if u.profile.trial_active %}<span class="ml-1 text-amber-400">trial</span>{% endif %}
                            {% else %}—{% endif %}
                        </td>
                        <td class="px-4 py-2.5 font-mono text-[11px] text-slate-500">{{ u.date_joined.strftime('%b %d') }}</td>
                    </tr>
                    {% else %}
                    <tr><td colspan="3" class="px-4 py-6 text-center text-slate-500">No users yet.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </section>

        <section class="overflow-hidden rounded-xl border border-slate-800 bg-slate-900/40">
            <div class="flex items-center justify-between border-b border-slate-800 px-4 py-3">
                <h2 class="text-xs font-semibold uppercase tracking-wider text-slate-500">Cash · recent payments</h2>
                <a href="{{ url('admin:billing_payment_changelist') }}" class="text-[11px] font-semibold text-indigo-400 hover:underline">All payments</a>
            </div>
            <table class="w-full text-left text-sm">
                <thead class="text-[10px] uppercase tracking-wide text-slate-500">
                    <tr>
                        <th class="px-4 py-2">When</th>
                        <th class="px-4 py-2">Amount</th>
                        <th class="px-4 py-2">User</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-800">
                    {% for p in recent_payments %}
                    <tr class="text-slate-300">
                        <td class="px-4 py-2.5 font-mono text-[11px] text-slate-500">{{ p.created_at.strftime('%b %d %H:%M') }}</td>
                        <td class="px-4 py-2.5 font-semibold tabular-nums text-emerald-400">{{ p.currency }} {{ p.amount }}</td>
                        <td class="px-4 py-2.5 text-xs">
                            {% if p.user %}
                            <a href="{{ url('staff_dashboard:user_detail', user_id=p.user.id) }}" class="text-indigo-400 hover:underline">@{{ p.user.username }}</a>
                            {% else %}—{% endif %}
                        </td>
                    </tr>
                    {% else %}
                    <tr><td colspan="3" class="px-4 py-6 text-center text-slate-500">No payments yet. Convert a user from their dossier.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </section>
    </div>
</div>
{% endblock %}
