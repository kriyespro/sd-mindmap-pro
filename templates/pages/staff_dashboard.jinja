{% extends 'layouts/staff_shell.jinja' %}
{% block title %}Command{% endblock %}

{% block main %}
<div class="flex items-center justify-between border-b px-4 py-2" style="border-color: var(--mc-line); background: var(--mc-paper)">
    <div>
        <h1 class="text-sm font-bold" style="color: var(--mc-ink)">Command</h1>
        <p class="text-[11px]" style="color: var(--mc-muted)">Cash · convert · who needs you</p>
    </div>
    <p class="text-[10px]" style="color: var(--mc-muted)">{{ as_of.strftime('%H:%M') }} · 60s</p>
</div>

<div class="space-y-3 p-3"
     hx-get="{{ url('staff_dashboard:stats') }}"
     hx-trigger="every 60s"
     hx-target="#ceo-kpi-strip"
     hx-swap="innerHTML">

    <div id="ceo-kpi-strip">{% include 'partials/_staff_kpi_strip.jinja' %}</div>

    <div class="grid gap-3 lg:grid-cols-12">
        <section class="mc-card p-3 lg:col-span-4">
            <h2 class="text-[10px] font-semibold uppercase tracking-wider" style="color: var(--mc-muted)">Plans · MRR ₹{{ mrr_inr }}</h2>
            {% set total_plans = (plan_counts.solo or 0) + (plan_counts.team or 0) + (plan_counts.team_20 or 0) %}
            {% if total_plans == 0 %}{% set total_plans = 1 %}{% endif %}
            <div class="mt-2 space-y-1.5">
                <div>
                    <div class="mb-0.5 flex justify-between text-[11px]">
                        <span style="color: var(--mc-muted)">Starter ₹{{ plan_price.solo }}</span>
                        <span class="font-semibold tabular-nums">{{ plan_counts.solo }}</span>
                    </div>
                    <div class="mc-bar-track"><div class="h-full rounded-full bg-stone-400" style="width:{{ (plan_counts.solo / total_plans * 100)|round|int }}%"></div></div>
                </div>
                <div>
                    <div class="mb-0.5 flex justify-between text-[11px]">
                        <span style="color: var(--mc-muted)">Team ₹{{ plan_price.team }}</span>
                        <span class="font-semibold tabular-nums" style="color: var(--mc-accent)">{{ plan_counts.team }}</span>
                    </div>
                    <div class="mc-bar-track"><div class="h-full rounded-full" style="width:{{ (plan_counts.team / total_plans * 100)|round|int }}%; background: var(--mc-accent)"></div></div>
                </div>
                <div>
                    <div class="mb-0.5 flex justify-between text-[11px]">
                        <span style="color: var(--mc-muted)">Pro ₹{{ plan_price.team_20 }}</span>
                        <span class="font-semibold tabular-nums">{{ plan_counts.team_20 }}</span>
                    </div>
                    <div class="mc-bar-track"><div class="h-full rounded-full bg-stone-600" style="width:{{ (plan_counts.team_20 / total_plans * 100)|round|int }}%"></div></div>
                </div>
            </div>
            <div class="mt-3 grid grid-cols-2 gap-2">
                <div>
                    <p class="text-[9px] font-semibold uppercase" style="color: var(--mc-muted)">Signups 14d</p>
                    <div class="mt-1 flex h-10 items-end gap-px">
                        {% for s in sparkline %}
                        {% set h = ((s.count / spark_max) * 100)|round|int %}
                        <div class="flex-1 rounded-t" style="height:{{ h if h >= 8 else (3 if s.count == 0 else 8) }}%; background: var(--mc-accent); opacity:.85" title="{{ s.date.isoformat() }}: {{ s.count }}"></div>
                        {% endfor %}
                    </div>
                </div>
                <div>
                    <p class="text-[9px] font-semibold uppercase" style="color: var(--mc-muted)">Cash 14d</p>
                    <div class="mt-1 flex h-10 items-end gap-px">
                        {% for s in cash_spark %}
                        {% set h = ((s.count / cash_spark_max) * 100)|round|int %}
                        <div class="flex-1 rounded-t" style="height:{{ h if h >= 8 else (3 if s.count == 0 else 8) }}%; background: var(--mc-money); opacity:.85" title="{{ s.date.isoformat() }}: {{ s.amount }}"></div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </section>

        <section class="mc-card p-3 lg:col-span-8" style="border-color: #e2cfa3; background: var(--mc-warn-soft)">
            <div class="flex flex-wrap items-center justify-between gap-2">
                <h2 class="text-[10px] font-semibold uppercase tracking-wider" style="color: var(--mc-warn)">Attention</h2>
                <div class="flex gap-1.5">
                    <a href="{{ url('staff_dashboard:users') }}?filter=trial_soon" class="mc-btn mc-btn-primary">Convert trials</a>
                    <a href="{{ url('staff_dashboard:users') }}" class="mc-btn mc-btn-ghost">People</a>
                </div>
            </div>
            <div class="mt-2 grid gap-2 sm:grid-cols-2 xl:grid-cols-4">
                <div>
                    <div class="mb-1 flex justify-between">
                        <p class="text-[10px] font-semibold" style="color: var(--mc-muted)">Trial ≤3d</p>
                        <a href="{{ url('staff_dashboard:users') }}?filter=trial_soon" class="mc-link text-[10px]">all</a>
                    </div>
                    <ul class="space-y-1">
                        {% for p in trials_ending_soon[:5] %}
                        <li>
                            <a href="{{ url('staff_dashboard:user_detail', user_id=p.user.id) }}"
                               class="flex justify-between rounded border px-2 py-1 text-[11px] hover:opacity-90"
                               style="border-color: var(--mc-line); background: var(--mc-paper)">
                                <span class="font-medium">@{{ p.user.username }}</span>
                                <span class="tabular-nums" style="color: var(--mc-warn)">{{ p.trial_ends }}</span>
                            </a>
                        </li>
                        {% else %}
                        <li class="text-[11px]" style="color: var(--mc-muted)">Clear</li>
                        {% endfor %}
                    </ul>
                </div>
                <div>
                    <div class="mb-1 flex justify-between">
                        <p class="text-[10px] font-semibold" style="color: var(--mc-muted)">Paid · no $</p>
                        <a href="{{ url('staff_dashboard:users') }}?filter=unpaid" class="mc-link text-[10px]">all</a>
                    </div>
                    <ul class="space-y-1">
                        {% for u in unpaid_paid[:5] %}
                        <li>
                            <a href="{{ url('staff_dashboard:user_detail', user_id=u.id) }}"
                               class="block rounded border px-2 py-1 text-[11px]"
                               style="border-color: #e0b8b2; background: var(--mc-danger-soft)">
                                <span class="font-medium">@{{ u.username }}</span>
                                <span style="color: var(--mc-danger)"> · {{ u.profile.plan }}</span>
                            </a>
                        </li>
                        {% else %}
                        <li class="text-[11px]" style="color: var(--mc-muted)">Matched</li>
                        {% endfor %}
                    </ul>
                </div>
                <div>
                    <p class="mb-1 text-[10px] font-semibold" style="color: var(--mc-muted)">Near seat cap</p>
                    <ul class="space-y-1">
                        {% for row in attention_seats[:5] %}
                        <li class="rounded border px-2 py-1 text-[11px]" style="border-color: var(--mc-line); background: var(--mc-paper)">
                            <p class="font-medium truncate">{{ row.team.name }}</p>
                            <p style="color: var(--mc-muted)">
                                <a href="{{ url('staff_dashboard:user_detail', user_id=row.owner.id) }}" class="mc-link">@{{ row.owner.username }}</a>
                                · {{ row.filled }}/{{ row.limit }}
                            </p>
                        </li>
                        {% else %}
                        <li class="text-[11px]" style="color: var(--mc-muted)">None</li>
                        {% endfor %}
                    </ul>
                </div>
                <div>
                    <div class="mb-1 flex justify-between">
                        <p class="text-[10px] font-semibold" style="color: var(--mc-muted)">Dormant 14d</p>
                        <a href="{{ url('staff_dashboard:users') }}?filter=dormant" class="mc-link text-[10px]">all</a>
                    </div>
                    <ul class="space-y-1">
                        {% for u in dormant_users[:5] %}
                        <li>
                            <a href="{{ url('staff_dashboard:user_detail', user_id=u.id) }}"
                               class="flex justify-between rounded border px-2 py-1 text-[11px]"
                               style="border-color: var(--mc-line); background: var(--mc-paper)">
                                <span class="font-medium">@{{ u.username }}</span>
                                <span style="color: var(--mc-muted)">{{ u.last_login.strftime('%b %d') if u.last_login else '—' }}</span>
                            </a>
                        </li>
                        {% else %}
                        <li class="text-[11px]" style="color: var(--mc-muted)">Active</li>
                        {% endfor %}
                    </ul>
                </div>
            </div>
        </section>
    </div>

    <div class="grid gap-3 lg:grid-cols-2">
        <section class="mc-card overflow-hidden">
            <div class="flex items-center justify-between border-b px-2.5 py-1.5" style="border-color: var(--mc-line)">
                <h2 class="text-[10px] font-semibold uppercase tracking-wider" style="color: var(--mc-muted)">Signups</h2>
                <a href="{{ url('staff_dashboard:users') }}" class="mc-link text-[10px]">all</a>
            </div>
            <table class="mc-table w-full text-left text-[12px]">
                <thead>
                    <tr>
                        <th class="px-2.5 py-1">User</th>
                        <th class="px-2.5 py-1">Plan</th>
                        <th class="px-2.5 py-1">Joined</th>
                    </tr>
                </thead>
                <tbody>
                    {% for u in recent_signups[:8] %}
                    <tr class="border-t" style="border-color: var(--mc-line)">
                        <td class="px-2.5 py-1">
                            <a href="{{ url('staff_dashboard:user_detail', user_id=u.id) }}" class="font-medium mc-link">@{{ u.username }}</a>
                            <p class="text-[10px]" style="color: var(--mc-muted)">{{ u.email or '—' }}</p>
                        </td>
                        <td class="px-2.5 py-1 text-[11px]">
                            {% if u.profile %}{{ u.profile.plan }}{% if u.profile.trial_active %} · trial{% endif %}{% else %}—{% endif %}
                        </td>
                        <td class="px-2.5 py-1 font-mono text-[10px]" style="color: var(--mc-muted)">{{ u.date_joined.strftime('%b %d') }}</td>
                    </tr>
                    {% else %}
                    <tr><td colspan="3" class="px-2.5 py-4 text-center text-[11px]" style="color: var(--mc-muted)">None</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </section>

        <section class="mc-card overflow-hidden">
            <div class="flex items-center justify-between border-b px-2.5 py-1.5" style="border-color: var(--mc-line)">
                <h2 class="text-[10px] font-semibold uppercase tracking-wider" style="color: var(--mc-muted)">Payments</h2>
                <a href="{{ url('admin:billing_payment_changelist') }}" class="mc-link text-[10px]">all</a>
            </div>
            <table class="mc-table w-full text-left text-[12px]">
                <thead>
                    <tr>
                        <th class="px-2.5 py-1">When</th>
                        <th class="px-2.5 py-1">Amount</th>
                        <th class="px-2.5 py-1">User</th>
                    </tr>
                </thead>
                <tbody>
                    {% for p in recent_payments[:8] %}
                    <tr class="border-t" style="border-color: var(--mc-line)">
                        <td class="px-2.5 py-1 font-mono text-[10px]" style="color: var(--mc-muted)">{{ p.created_at.strftime('%b %d %H:%M') }}</td>
                        <td class="px-2.5 py-1 font-semibold tabular-nums" style="color: var(--mc-money)">{{ p.currency }} {{ p.amount }}</td>
                        <td class="px-2.5 py-1 text-[11px]">
                            {% if p.user %}<a href="{{ url('staff_dashboard:user_detail', user_id=p.user.id) }}" class="mc-link">@{{ p.user.username }}</a>{% else %}—{% endif %}
                        </td>
                    </tr>
                    {% else %}
                    <tr><td colspan="3" class="px-2.5 py-4 text-center text-[11px]" style="color: var(--mc-muted)">Convert from a dossier</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </section>
    </div>
</div>
{% endblock %}
