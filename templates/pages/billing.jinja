{% extends 'layouts/app.jinja' %}
{% block title %}Billing · MindMap{% endblock %}

{% block main %}
<header class="border-b border-slate-200/80 bg-white px-5 py-4">
    <h1 class="text-lg font-semibold text-slate-900">Billing</h1>
    <p class="mt-1 text-sm text-slate-500">7-day free trial, then simple monthly pricing.</p>
</header>
<div class="mx-auto max-w-3xl space-y-6 p-5">
    <section class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
        <h2 class="text-sm font-semibold text-slate-800">Plans</h2>
        <div class="mt-3 grid gap-3 sm:grid-cols-2">
            <div class="rounded-lg border p-4 {% if plan_code == 'solo' %}border-indigo-300 bg-indigo-50/50{% else %}border-slate-200 bg-slate-50{% endif %}">
                <p class="text-xs font-semibold text-slate-700">Solo</p>
                <p class="mt-1 text-2xl font-bold text-slate-900">₹{{ solo_price_inr }}<span class="text-sm font-medium text-slate-500">/month</span></p>
                <p class="mt-1 text-xs text-slate-500">For individual usage.</p>
                <div class="mt-3">
                    {% if plan_code == 'solo' %}
                    <span class="inline-flex rounded-md bg-slate-200 px-2 py-1 text-[10px] font-semibold text-slate-700">Current plan</span>
                    {% else %}
                    <form action="{{ url('billing:plan_change') }}" method="post">
                        <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
                        <input type="hidden" name="plan" value="solo">
                        <button type="submit" class="rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-[11px] font-semibold text-slate-700 hover:bg-slate-100">
                            Switch to Solo
                        </button>
                    </form>
                    {% endif %}
                </div>
            </div>
            <div class="rounded-lg border p-4 {% if plan_code == 'team' %}border-indigo-300 bg-indigo-50/50{% else %}border-slate-200 bg-slate-50{% endif %}">
                <p class="text-xs font-semibold text-slate-700">Team</p>
                <p class="mt-1 text-2xl font-bold text-slate-900">₹{{ team_price_inr }}<span class="text-sm font-medium text-slate-500">/month</span></p>
                <p class="mt-1 text-xs text-slate-500">Up to {{ team_user_limit }} users in one team.</p>
                <div class="mt-3">
                    {% if plan_code == 'team' %}
                    <span class="inline-flex rounded-md bg-slate-200 px-2 py-1 text-[10px] font-semibold text-slate-700">Current plan</span>
                    {% else %}
                    <form action="{{ url('billing:plan_change') }}" method="post">
                        <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
                        <input type="hidden" name="plan" value="team">
                        <button type="submit" class="rounded-lg bg-indigo-600 px-3 py-1.5 text-[11px] font-semibold text-white hover:bg-indigo-700">
                            Upgrade to Team
                        </button>
                    </form>
                    {% endif %}
                </div>
            </div>
        </div>
        <p class="mt-3 text-xs text-slate-500">Current plan: <span class="font-semibold text-slate-700">{{ plan_name }}</span></p>
    </section>

    <section class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
        <h2 class="text-sm font-semibold text-slate-800">Account</h2>
        {% if is_trial %}
        <p class="mt-2 text-sm text-amber-800">
            You are on a <span class="font-semibold">7-day free trial</span>
            {% if trial_ends %} until <span class="font-mono">{{ trial_ends.isoformat() }}</span>{% endif %}.
            {% if trial_days_left is not none %}<span class="ml-1">({{ trial_days_left }} day(s) left)</span>{% endif %}
        </p>
        {% else %}
        <p class="mt-2 text-sm text-slate-600">Trial ended. Billing applies based on your current plan.</p>
        {% endif %}
        <p class="mt-3 text-xs text-slate-400">Staff can manage plan and trial in <code class="rounded bg-slate-100 px-1">/sd/</code> → Users.</p>
    </section>
    <section class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
        <h2 class="text-sm font-semibold text-slate-800">Your payments recorded</h2>
        <p class="mt-1 text-2xl font-bold tabular-nums text-emerald-700">
            ${{ my_payment_total_display }}
        </p>
        {% if my_payments %}
        <ul class="mt-4 divide-y divide-slate-100 text-sm">
            {% for p in my_payments %}
            <li class="flex justify-between py-2 text-slate-700">
                <span>{{ p.description or 'Payment' }}</span>
                <span class="font-medium tabular-nums">{{ p.currency }} {{ p.amount }}</span>
            </li>
            {% endfor %}
        </ul>
        {% else %}
        <p class="mt-3 text-sm text-slate-500">No payments linked to your user yet.</p>
        {% endif %}
    </section>
</div>
{% endblock %}
