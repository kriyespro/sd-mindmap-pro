{% extends 'layouts/app.jinja' %}
{% block title %}Billing · MindMap{% endblock %}

{% block main %}
<header class="border-b border-slate-200/80 bg-white px-4 py-3">
    <h1 class="text-lg font-semibold text-slate-900">Billing & Plan</h1>
    <p class="mt-0.5 text-xs text-slate-500">Compact billing view for plan, trial, seats, and team access.</p>
</header>
<div class="mx-auto max-w-6xl space-y-3 p-3">
    <section class="grid gap-2 sm:grid-cols-2 xl:grid-cols-5">
        <div class="rounded-lg border border-emerald-100 bg-emerald-50/50 p-3 shadow-sm">
            <p class="text-[11px] font-semibold uppercase tracking-wide text-slate-500">Payment history</p>
            <p class="mt-0.5 text-base font-semibold tabular-nums text-emerald-700">${{ my_payment_total_display }}</p>
            <p class="mt-0.5 text-[11px] text-slate-500">Total recorded</p>
        </div>
        <div class="rounded-lg border border-indigo-100 bg-indigo-50/50 p-3 shadow-sm">
            <p class="text-[11px] font-semibold uppercase tracking-wide text-slate-500">Current plan</p>
            <p class="mt-0.5 text-base font-semibold text-slate-900">{{ plan_name }}</p>
        </div>
        <div class="rounded-lg border border-violet-100 bg-violet-50/50 p-3 shadow-sm">
            <p class="text-[11px] font-semibold uppercase tracking-wide text-slate-500">Monthly price</p>
            <p class="mt-0.5 text-base font-semibold text-slate-900">
                {% if plan_code == 'team_20' %}₹{{ team_20_price_inr }}{% elif plan_code == 'team' %}₹{{ team_price_inr }}{% else %}₹{{ solo_price_inr }}{% endif %}
                <span class="text-xs font-medium text-slate-500">/month</span>
            </p>
        </div>
        <div class="rounded-lg border border-emerald-100 bg-emerald-50/50 p-3 shadow-sm">
            <p class="text-[11px] font-semibold uppercase tracking-wide text-slate-500">Seats</p>
            <p class="mt-0.5 text-base font-semibold text-slate-900">
                {% if owner_team %}{{ owner_team_member_count }}/{{ owner_team_seat_limit }}{% else %}1/1{% endif %}
            </p>
            <p class="mt-0.5 text-[11px] text-slate-500">
                {% if owner_team %}{{ owner_team_seat_left }} free seat(s) left{% else %}Create a team to add users{% endif %}
            </p>
        </div>
        <div class="rounded-lg border border-amber-100 bg-amber-50/60 p-3 shadow-sm">
            <p class="text-[11px] font-semibold uppercase tracking-wide text-slate-500">Account trial</p>
            {% if is_trial %}
            <p class="mt-0.5 text-base font-semibold text-amber-800">Active</p>
            <p class="mt-0.5 text-[11px] text-amber-700">
                {% if trial_days_left is not none %}{{ trial_days_left }} day(s) left{% endif %}
                {% if trial_ends %}· {{ trial_ends.isoformat() }}{% endif %}
            </p>
            {% else %}
            <p class="mt-0.5 text-base font-semibold text-slate-700">Ended</p>
            <p class="mt-0.5 text-[11px] text-slate-500">Billing active on current plan</p>
            {% endif %}
        </div>
    </section>

    <section class="grid gap-3 lg:grid-cols-12">
        <div class="space-y-3 lg:col-span-7">
            <section class="rounded-lg border border-slate-200 bg-white p-3 shadow-sm">
                <div class="flex flex-wrap items-center justify-between gap-2">
                    <div>
                        <h2 class="text-sm font-semibold text-slate-800">Smart plan chooser</h2>
                        <p class="text-[11px] text-slate-500">Use Solo for personal work, Team for shared workspace with invites.</p>
                    </div>
                    <span class="inline-flex rounded-md bg-slate-100 px-2 py-1 text-[10px] font-semibold text-slate-700">Current: {{ plan_name }}</span>
                </div>
                <div class="mt-2 grid gap-2 sm:grid-cols-3">
                    <div class="rounded-lg border p-2 {% if plan_code == 'solo' %}border-indigo-300 bg-indigo-50/50{% else %}border-slate-200 bg-slate-50{% endif %}">
                        <p class="text-xs font-semibold text-slate-700">Solo</p>
                        <p class="text-lg font-bold text-slate-900">₹{{ solo_price_inr }}<span class="text-xs font-medium text-slate-500">/month</span></p>
                        <ul class="mt-0.5 space-y-0 text-[11px] text-slate-600">
                            <li>Personal workspace</li>
                            <li>Best for individual execution</li>
                        </ul>
                        <div class="mt-1.5">
                            {% if plan_code == 'solo' %}
                            <span class="inline-flex rounded-md bg-slate-200 px-2 py-1 text-[10px] font-semibold text-slate-700">Current plan</span>
                            {% else %}
                            <form action="{{ url('billing:plan_change') }}" method="post">
                                <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
                                <input type="hidden" name="plan" value="solo">
                                <button type="submit" class="rounded-lg border border-slate-300 bg-white px-3 py-1 text-[11px] font-semibold text-slate-700 hover:bg-slate-100">
                                    Switch to Solo
                                </button>
                            </form>
                            {% endif %}
                        </div>
                    </div>
                    <div class="rounded-lg border p-2 {% if plan_code == 'team' %}border-violet-300 bg-violet-50/50{% else %}border-slate-200 bg-slate-50{% endif %}">
                        <p class="text-xs font-semibold text-slate-700">Team</p>
                        <p class="text-lg font-bold text-slate-900">₹{{ team_price_inr }}<span class="text-xs font-medium text-slate-500">/month</span></p>
                        <ul class="mt-0.5 space-y-0 text-[11px] text-slate-600">
                            <li>Up to {{ team_user_limit }} users</li>
                            <li>Username invites + join links</li>
                        </ul>
                        <div class="mt-1.5">
                            {% if plan_code == 'team' %}
                            <span class="inline-flex rounded-md bg-slate-200 px-2 py-1 text-[10px] font-semibold text-slate-700">Current plan</span>
                            {% else %}
                            <form action="{{ url('billing:plan_change') }}" method="post">
                                <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
                                <input type="hidden" name="plan" value="team">
                                <button type="submit" class="rounded-lg bg-indigo-600 px-3 py-1 text-[11px] font-semibold text-white hover:bg-indigo-700">
                                    Upgrade to Team
                                </button>
                            </form>
                            {% endif %}
                        </div>
                    </div>
                    <div class="rounded-lg border p-2 {% if plan_code == 'team_20' %}border-fuchsia-300 bg-fuchsia-50/50{% else %}border-slate-200 bg-slate-50{% endif %}">
                        <p class="text-xs font-semibold text-slate-700">Team Pro</p>
                        <p class="text-lg font-bold text-slate-900">₹{{ team_20_price_inr }}<span class="text-xs font-medium text-slate-500">/month</span></p>
                        <ul class="mt-0.5 space-y-0 text-[11px] text-slate-600">
                            <li>Up to {{ team_20_user_limit }} users</li>
                            <li>For larger active teams</li>
                        </ul>
                        <div class="mt-1.5">
                            {% if plan_code == 'team_20' %}
                            <span class="inline-flex rounded-md bg-slate-200 px-2 py-1 text-[10px] font-semibold text-slate-700">Current plan</span>
                            {% else %}
                            <form action="{{ url('billing:plan_change') }}" method="post">
                                <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
                                <input type="hidden" name="plan" value="team_20">
                                <button type="submit" class="rounded-lg bg-fuchsia-600 px-3 py-1 text-[11px] font-semibold text-white hover:bg-fuchsia-700">
                                    Upgrade to Team Pro
                                </button>
                            </form>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </section>

            <section class="rounded-lg border border-slate-200 bg-white p-3 shadow-sm">
                <h2 class="text-sm font-semibold text-slate-800">Payment history details</h2>
                {% if my_payments %}
                <ul class="mt-2 max-h-32 divide-y divide-slate-100 overflow-y-auto text-sm">
                    {% for p in my_payments %}
                    <li class="flex justify-between py-1.5 text-slate-700">
                        <span>{{ p.description or 'Payment' }}</span>
                        <span class="font-medium tabular-nums">{{ p.currency }} {{ p.amount }}</span>
                    </li>
                    {% endfor %}
                </ul>
                {% else %}
                <p class="mt-1.5 text-sm text-slate-500">No payments linked to your user yet.</p>
                {% endif %}
            </section>
        </div>

        <div class="space-y-3 lg:col-span-5">
            <section class="rounded-lg border border-slate-200 bg-white p-3 shadow-sm">
                <h2 class="text-sm font-semibold text-slate-800">Team access</h2>
        {% if owner_team %}
        <p class="mt-1 text-xs text-slate-600">Team <span class="font-semibold text-slate-800">{{ owner_team.name }}</span> · Seats <span class="font-semibold">{{ owner_team_member_count }}/{{ owner_team_seat_limit }}</span> ({{ owner_team_seat_left }} left)</p>
        {% if owner_team_seat_left == 0 %}
        <div class="mt-2 rounded-lg border border-amber-200 bg-amber-50 px-2.5 py-1.5 text-xs text-amber-800">
            Free seats are full. Upgrade capacity before inviting more members.
        </div>
        {% endif %}
        <div class="mt-2 rounded-lg border border-slate-200 bg-slate-50/70 p-2.5">
            <div class="flex items-center justify-between gap-2">
                <p class="text-xs font-semibold text-slate-700">Team member control</p>
                {% if billing_is_owner %}
                <span class="rounded bg-emerald-100 px-2 py-0.5 text-[10px] font-semibold text-emerald-700">Owner controls enabled</span>
                {% endif %}
            </div>
            {% if billing_is_owner %}
            <form action="{{ url('teams:member_add', team_slug=owner_team.slug) }}" method="post" class="mt-2 grid gap-2 md:grid-cols-[1fr_auto_auto]">
                <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
                <input type="text" name="username" required placeholder="username to add"
                       class="w-full rounded-lg border border-slate-200 px-3 py-2 text-xs focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20">
                <select name="role"
                        class="rounded-lg border border-slate-200 px-3 py-2 text-xs focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20">
                    {% for role_value, role_label in team_member_role_choices %}
                    <option value="{{ role_value }}" {% if role_value == 'member' %}selected{% endif %}>{{ role_label }}</option>
                    {% endfor %}
                </select>
                <button type="submit" class="rounded-lg bg-indigo-600 px-3 py-2 text-xs font-semibold text-white hover:bg-indigo-700">Assign</button>
            </form>
            {% endif %}
            {% if owner_team_members %}
            <div class="mt-2 overflow-x-auto">
                <table class="min-w-full text-left text-[11px] text-slate-600">
                    <thead class="bg-white text-[10px] uppercase tracking-wide text-slate-500">
                        <tr>
                            <th class="px-2 py-1.5">User</th>
                            <th class="px-2 py-1.5">Team</th>
                            <th class="px-2 py-1.5">Active</th>
                            <th class="px-2 py-1.5">Role</th>
                            {% if billing_is_owner %}<th class="px-2 py-1.5 text-right">Action</th>{% endif %}
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-200">
                        {% for member in owner_team_members %}
                        <tr>
                            <td class="px-2 py-1.5">
                                <p class="font-medium text-slate-800">@{{ member.user.username }}</p>
                                <p class="text-[10px] text-slate-500">{{ member.user.email or '— no email —' }}</p>
                            </td>
                            <td class="px-2 py-1.5">{{ owner_team.name }}</td>
                            <td class="px-2 py-1.5">
                                {% if member.is_active %}
                                <span class="rounded bg-emerald-100 px-1.5 py-0.5 text-[10px] font-semibold text-emerald-700">Yes</span>
                                {% else %}
                                <span class="rounded bg-slate-200 px-1.5 py-0.5 text-[10px] font-semibold text-slate-600">No</span>
                                {% endif %}
                            </td>
                            <td class="px-2 py-1.5">
                                {% if member.is_owner %}Owner{% elif member.role == 'admin' %}Admin{% else %}Member{% endif %}
                            </td>
                            {% if billing_is_owner %}
                            <td class="px-2 py-1.5 text-right">
                                {% if not member.is_owner %}
                                <form action="{{ url('teams:member_status', team_slug=owner_team.slug, membership_id=member.id) }}" method="post">
                                    <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
                                    <input type="hidden" name="is_active" value="{{ 'false' if member.is_active else 'true' }}">
                                    {% if member.is_active %}
                                    <button type="submit" class="rounded border border-amber-200 bg-amber-50 px-2 py-1 text-[10px] font-semibold text-amber-700 hover:bg-amber-100">Deactivate</button>
                                    {% else %}
                                    <button type="submit" class="rounded border border-emerald-200 bg-emerald-50 px-2 py-1 text-[10px] font-semibold text-emerald-700 hover:bg-emerald-100">Activate</button>
                                    {% endif %}
                                </form>
                                {% else %}
                                <span class="text-[10px] text-slate-400">—</span>
                                {% endif %}
                            </td>
                            {% endif %}
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            <p class="mt-1 text-[10px] text-slate-500">Deactivate removes team access only. User account/dashboard stays intact and can be reactivated later.</p>
            {% else %}
            <p class="mt-1 text-[11px] text-slate-500">No members loaded.</p>
            {% endif %}
        </div>
        {% if billing_can_invite %}
        <div class="mt-2 rounded-lg border border-violet-100 bg-violet-50/50 p-2.5">
            <div class="flex items-center justify-between gap-2">
                <p class="text-xs font-semibold text-violet-900">Team join link</p>
                {% if team_join_url %}
                <a href="{{ team_join_url }}" target="_blank" rel="noopener" class="text-[11px] font-medium text-violet-700 hover:underline">Open</a>
                {% endif %}
            </div>
            {% if team_join_url %}
            <p class="mt-1 break-all rounded bg-white px-2 py-1.5 text-[11px] text-slate-700">{{ team_join_url }}</p>
            {% else %}
            <p class="mt-1 text-[11px] text-slate-600">No active link yet. Generate one below.</p>
            {% endif %}
        </div>
        <div class="mt-2 grid gap-2 md:grid-cols-2">
            <form action="{{ url('teams:invite', team_slug=owner_team.slug) }}" method="post" class="rounded-lg border border-indigo-100 bg-indigo-50/40 p-2.5">
                <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
                <h3 class="text-xs font-semibold text-slate-700">Invite by username</h3>
                <p class="mt-0.5 text-[10px] text-slate-500">They log in as that user and open the link you send (or their notification).</p>
                <label class="mt-1.5 block text-[11px] text-slate-500">Username</label>
                {{ team_invite_form.username }}
                <label class="mt-1.5 block text-[11px] text-slate-500">Role</label>
                {{ team_invite_form.role }}
                <button type="submit" class="mt-2 rounded-lg bg-indigo-600 px-3 py-1 text-[11px] font-semibold text-white hover:bg-indigo-700">
                    Send invite
                </button>
            </form>
            <form action="{{ url('teams:invite_link', team_slug=owner_team.slug) }}" method="post" class="rounded-lg border border-violet-100 bg-violet-50/40 p-2.5">
                <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
                <h3 class="text-xs font-semibold text-slate-700">Generate join link</h3>
                <label class="mt-1.5 block text-[11px] text-slate-500">Role for joiners</label>
                {{ team_join_link_form.role }}
                <button type="submit" class="mt-2 rounded-lg bg-violet-600 px-3 py-1 text-[11px] font-semibold text-white hover:bg-violet-700">
                    Generate link
                </button>
            </form>
        </div>
        {% if owner_team_invites %}
        <h3 class="mt-2 text-xs font-semibold text-slate-700">Recent invites</h3>
        <ul class="mt-1.5 divide-y divide-slate-100 text-xs">
            {% for inv in owner_team_invites %}
            <li class="flex items-center justify-between gap-2 py-1.5 text-slate-600">
                <span class="truncate">
                    {% if inv.invited_username %}@{{ inv.invited_username }}{% elif inv.email %}{{ inv.email }}{% else %}Public join link{% endif %}
                    · {% if inv.role == 'admin' %}Admin{% else %}Member{% endif %}
                </span>
                <span class="rounded px-2 py-0.5 text-[10px] {% if inv.is_revoked %}bg-rose-100 text-rose-700{% elif inv.is_usable %}bg-emerald-100 text-emerald-700{% else %}bg-slate-200 text-slate-700{% endif %}">
                    {% if inv.is_revoked %}revoked{% elif inv.is_usable %}active{% else %}expired/used{% endif %}
                </span>
            </li>
            {% endfor %}
        </ul>
        {% endif %}
        {% endif %}
        {% else %}
        <p class="mt-1.5 text-sm text-slate-500">Create a team first, then billing owner can invite users and generate join links here.</p>
        {% endif %}
            </section>
            <section class="rounded-lg border border-amber-200 bg-amber-50/70 p-3 shadow-sm">
                <h2 class="text-sm font-semibold text-amber-900">Archived team mindmaps</h2>
                <p class="mt-1 text-xs text-amber-800">Archived teams are hidden from the sidebar until restored.</p>
                {% if archived_team_memberships %}
                <div class="mt-2 space-y-2">
                    {% for archived_membership in archived_team_memberships %}
                    <div class="flex items-center justify-between rounded-lg border border-amber-200 bg-white px-3 py-2">
                        <div>
                            <p class="text-xs font-semibold text-slate-800">{{ archived_membership.team.name }}</p>
                            <p class="text-[11px] text-slate-500">Team workspace archived</p>
                        </div>
                        {% if archived_membership.can_manage_invites %}
                        <form method="post" action="{{ url('planner:unarchive_team_mindmap', team_slug=archived_membership.team.slug) }}">
                            <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
                            <button type="submit" class="rounded-lg border border-emerald-200 bg-emerald-50 px-3 py-1.5 text-[11px] font-semibold text-emerald-700 hover:bg-emerald-100">
                                Unarchive
                            </button>
                        </form>
                        {% else %}
                        <span class="text-[10px] text-slate-400">Ask owner/admin</span>
                        {% endif %}
                    </div>
                    {% endfor %}
                </div>
                {% else %}
                <p class="mt-2 text-xs text-amber-800">No archived team mindmap yet.</p>
                {% endif %}
            </section>
        </div>
    </section>
</div>
{% endblock %}
