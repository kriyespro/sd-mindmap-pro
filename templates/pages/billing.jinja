{% extends 'layouts/app.jinja' %}
{% block title %}Billing · DCPMind{% endblock %}

{% block main %}
{% include 'partials/_invite_share.jinja' %}
<header class="border-b border-slate-200/80 bg-white px-4 py-3">
    <h1 class="text-lg font-semibold text-slate-900">Billing & Plan</h1>
    <p class="mt-0.5 text-xs text-slate-500">Compact billing view for plan, trial, seats, and team access.</p>
</header>
<div id="billing-page" class="mx-auto max-w-6xl space-y-3 p-3">
    <section class="grid gap-2 sm:grid-cols-2 xl:grid-cols-5">
        <div class="rounded-lg border border-emerald-100 bg-emerald-50/50 p-3 shadow-sm">
            <p class="text-[11px] font-semibold uppercase tracking-wide text-slate-500">Payment history</p>
            <p class="mt-0.5 text-base font-semibold tabular-nums text-emerald-700">${{ my_payment_total_display }}</p>
            <p class="mt-0.5 text-[11px] text-slate-500">Total recorded</p>
        </div>
        <div class="rounded-lg border border-indigo-100 bg-indigo-50/50 p-3 shadow-sm">
            <p class="text-[11px] font-semibold uppercase tracking-wide text-slate-500">Current plan</p>
            <p class="mt-0.5 text-base font-semibold text-slate-900">{{ plan_name }}</p>
        </div>
        <div class="rounded-lg border border-violet-100 bg-violet-50/50 p-3 shadow-sm">
            <p class="text-[11px] font-semibold uppercase tracking-wide text-slate-500">Monthly price</p>
            <p class="mt-0.5 text-base font-semibold text-slate-900">
                {% if plan_code == 'team_20' %}₹{{ team_20_price_inr }}{% elif plan_code == 'team' %}₹{{ team_price_inr }}{% else %}₹{{ solo_price_inr }}{% endif %}
                <span class="text-xs font-medium text-slate-500">/month</span>
            </p>
        </div>
        <div class="rounded-lg border border-emerald-100 bg-emerald-50/50 p-3 shadow-sm">
            <p class="text-[11px] font-semibold uppercase tracking-wide text-slate-500">Seats</p>
            <p class="mt-0.5 text-base font-semibold text-slate-900">
                {% if owner_team %}{{ owner_team_member_count }}/{{ owner_team_seat_limit }}{% else %}1/1{% endif %}
            </p>
            <p class="mt-0.5 text-[11px] text-slate-500">
                {% if owner_team %}{{ owner_team_seat_left }} free seat(s) left{% else %}Create a team to add users{% endif %}
            </p>
        </div>
        <div class="rounded-lg border border-amber-100 bg-amber-50/60 p-3 shadow-sm">
            <p class="text-[11px] font-semibold uppercase tracking-wide text-slate-500">Account trial</p>
            {% if is_trial %}
            <p class="mt-0.5 text-base font-semibold text-amber-800">Active</p>
            <p class="mt-0.5 text-[11px] text-amber-700">
                {% if trial_days_left is not none %}{{ trial_days_left }} day(s) left{% endif %}
                {% if trial_ends %}· {{ trial_ends.isoformat() }}{% endif %}
            </p>
            {% else %}
            <p class="mt-0.5 text-base font-semibold text-slate-700">Ended</p>
            <p class="mt-0.5 text-[11px] text-slate-500">Billing active on current plan</p>
            {% endif %}
        </div>
    </section>

    <section class="rounded-lg border border-violet-200 bg-violet-50/40 p-3 shadow-sm">
        <div class="flex flex-wrap items-center justify-between gap-2">
            <div>
                <h2 class="text-sm font-semibold text-slate-800">Display mode</h2>
                <p class="text-[11px] text-slate-500">Choose how much of the app you see in the sidebar and board toolbar.</p>
            </div>
            <span class="inline-flex rounded-md bg-violet-100 px-2 py-1 text-[10px] font-semibold text-violet-800">Current: {{ ui.label }}</span>
        </div>
        <div class="mt-2 grid gap-2 sm:grid-cols-3">
            <div class="rounded-lg border p-2 {% if ui_mode == 'minimal' %}border-violet-400 bg-white{% else %}border-slate-200 bg-white/80{% endif %}">
                <p class="text-xs font-semibold text-slate-800">Minimal</p>
                <p class="mt-0.5 text-[11px] text-slate-600">Tree &amp; Map only. Workspace sidebar — no projects or PM tools.</p>
                <ul class="mt-1 space-y-0 text-[10px] text-slate-500">
                    <li>Top: Tree, Map</li>
                    <li>Sidebar: Personal + teams</li>
                </ul>
                <div class="mt-2">
                    {% if ui_mode == 'minimal' %}
                    <span class="inline-flex rounded-md bg-violet-100 px-2 py-1 text-[10px] font-semibold text-violet-800">Active</span>
                    {% else %}
                    <form action="{{ url('billing:ui_mode_change') }}" method="post">
                        <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
                        <input type="hidden" name="ui_mode" value="minimal">
                        <button type="submit" class="rounded-lg border border-slate-300 bg-white px-3 py-1 text-[11px] font-semibold text-slate-700 hover:bg-slate-100">Use Minimal</button>
                    </form>
                    {% endif %}
                </div>
            </div>
            <div class="rounded-lg border p-2 {% if ui_mode == 'express' %}border-violet-400 bg-white{% else %}border-slate-200 bg-white/80{% endif %}">
                <p class="text-xs font-semibold text-slate-800">Express</p>
                <p class="mt-0.5 text-[11px] text-slate-600">Tree, Map &amp; Kanban plus Projects and Gantt in the sidebar.</p>
                <ul class="mt-1 space-y-0 text-[10px] text-slate-500">
                    <li>Top: Tree, Map, Kanban</li>
                    <li>Sidebar: + Projects, Gantt</li>
                </ul>
                <div class="mt-2">
                    {% if ui_mode == 'express' %}
                    <span class="inline-flex rounded-md bg-violet-100 px-2 py-1 text-[10px] font-semibold text-violet-800">Active</span>
                    {% else %}
                    <form action="{{ url('billing:ui_mode_change') }}" method="post">
                        <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
                        <input type="hidden" name="ui_mode" value="express">
                        <button type="submit" class="rounded-lg border border-slate-300 bg-white px-3 py-1 text-[11px] font-semibold text-slate-700 hover:bg-slate-100">Use Express</button>
                    </form>
                    {% endif %}
                </div>
            </div>
            <div class="rounded-lg border p-2 {% if ui_mode == 'pro' %}border-violet-400 bg-white{% else %}border-slate-200 bg-white/80{% endif %}">
                <p class="text-xs font-semibold text-slate-800">Pro</p>
                <p class="mt-0.5 text-[11px] text-slate-600">All board views and full sidebar: milestones, calendar, time, reports, resources.</p>
                <ul class="mt-1 space-y-0 text-[10px] text-slate-500">
                    <li>Top: all 5 views + Gantt</li>
                    <li>Sidebar: everything</li>
                </ul>
                <div class="mt-2">
                    {% if ui_mode == 'pro' %}
                    <span class="inline-flex rounded-md bg-violet-100 px-2 py-1 text-[10px] font-semibold text-violet-800">Active</span>
                    {% else %}
                    <form action="{{ url('billing:ui_mode_change') }}" method="post">
                        <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
                        <input type="hidden" name="ui_mode" value="pro">
                        <button type="submit" class="rounded-lg border border-slate-300 bg-white px-3 py-1 text-[11px] font-semibold text-slate-700 hover:bg-slate-100">Use Pro</button>
                    </form>
                    {% endif %}
                </div>
            </div>
        </div>
    </section>

    <section class="grid gap-3 lg:grid-cols-12">
        <div class="space-y-3 lg:col-span-7">
            <section class="rounded-lg border border-slate-200 bg-white p-3 shadow-sm">
                <div class="flex flex-wrap items-center justify-between gap-2">
                    <div>
                        <h2 class="text-sm font-semibold text-slate-800">Smart plan chooser</h2>
                        <p class="text-[11px] text-slate-500">Use Solo for personal work, Team for shared workspace with invites.</p>
                    </div>
                    <span class="inline-flex rounded-md bg-slate-100 px-2 py-1 text-[10px] font-semibold text-slate-700">Current: {{ plan_name }}</span>
                </div>
                <div class="mt-2 grid gap-2 sm:grid-cols-3">
                    <div class="rounded-lg border p-2 {% if plan_code == 'solo' %}border-indigo-300 bg-indigo-50/50{% else %}border-slate-200 bg-slate-50{% endif %}">
                        <p class="text-xs font-semibold text-slate-700">Solo</p>
                        <p class="text-lg font-bold text-slate-900">₹{{ solo_price_inr }}<span class="text-xs font-medium text-slate-500">/month</span></p>
                        <ul class="mt-0.5 space-y-0 text-[11px] text-slate-600">
                            <li>Personal workspace</li>
                            <li>Best for individual execution</li>
                        </ul>
                        <div class="mt-1.5">
                            {% if plan_code == 'solo' %}
                            <span class="inline-flex rounded-md bg-slate-200 px-2 py-1 text-[10px] font-semibold text-slate-700">Current plan</span>
                            {% else %}
                            <form action="{{ url('billing:plan_change') }}" method="post">
                                <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
                                <input type="hidden" name="plan" value="solo">
                                <button type="submit" class="rounded-lg border border-slate-300 bg-white px-3 py-1 text-[11px] font-semibold text-slate-700 hover:bg-slate-100">
                                    Switch to Solo
                                </button>
                            </form>
                            {% endif %}
                        </div>
                    </div>
                    <div class="rounded-lg border p-2 {% if plan_code == 'team' %}border-violet-300 bg-violet-50/50{% else %}border-slate-200 bg-slate-50{% endif %}">
                        <p class="text-xs font-semibold text-slate-700">Team</p>
                        <p class="text-lg font-bold text-slate-900">₹{{ team_price_inr }}<span class="text-xs font-medium text-slate-500">/month</span></p>
                        <ul class="mt-0.5 space-y-0 text-[11px] text-slate-600">
                            <li>Up to {{ team_user_limit }} users</li>
                            <li>Username invites + join links</li>
                        </ul>
                        <div class="mt-1.5">
                            {% if plan_code == 'team' %}
                            <span class="inline-flex rounded-md bg-slate-200 px-2 py-1 text-[10px] font-semibold text-slate-700">Current plan</span>
                            {% else %}
                            <form action="{{ url('billing:plan_change') }}" method="post">
                                <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
                                <input type="hidden" name="plan" value="team">
                                <button type="submit" class="rounded-lg bg-indigo-600 px-3 py-1 text-[11px] font-semibold text-white hover:bg-indigo-700">
                                    Upgrade to Team
                                </button>
                            </form>
                            {% endif %}
                        </div>
                    </div>
                    <div class="rounded-lg border p-2 {% if plan_code == 'team_20' %}border-fuchsia-300 bg-fuchsia-50/50{% else %}border-slate-200 bg-slate-50{% endif %}">
                        <p class="text-xs font-semibold text-slate-700">Team Pro</p>
                        <p class="text-lg font-bold text-slate-900">₹{{ team_20_price_inr }}<span class="text-xs font-medium text-slate-500">/month</span></p>
                        <ul class="mt-0.5 space-y-0 text-[11px] text-slate-600">
                            <li>Up to {{ team_20_user_limit }} users</li>
                            <li>For larger active teams</li>
                        </ul>
                        <div class="mt-1.5">
                            {% if plan_code == 'team_20' %}
                            <span class="inline-flex rounded-md bg-slate-200 px-2 py-1 text-[10px] font-semibold text-slate-700">Current plan</span>
                            {% else %}
                            <form action="{{ url('billing:plan_change') }}" method="post">
                                <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
                                <input type="hidden" name="plan" value="team_20">
                                <button type="submit" class="rounded-lg bg-fuchsia-600 px-3 py-1 text-[11px] font-semibold text-white hover:bg-fuchsia-700">
                                    Upgrade to Team Pro
                                </button>
                            </form>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </section>

            <section class="rounded-lg border border-slate-200 bg-white p-3 shadow-sm">
                <h2 class="text-sm font-semibold text-slate-800">Payment history details</h2>
                {% if my_payments %}
                <ul class="mt-2 max-h-32 divide-y divide-slate-100 overflow-y-auto text-sm">
                    {% for p in my_payments %}
                    <li class="flex justify-between py-1.5 text-slate-700">
                        <span>{{ p.description or 'Payment' }}</span>
                        <span class="font-medium tabular-nums">{{ p.currency }} {{ p.amount }}</span>
                    </li>
                    {% endfor %}
                </ul>
                {% else %}
                <p class="mt-1.5 text-sm text-slate-500">No payments linked to your user yet.</p>
                {% endif %}
            </section>
        </div>

        <div class="space-y-3 lg:col-span-5">
            <section class="rounded-lg border border-slate-200 bg-white p-3 shadow-sm" x-data="{ copied: false }">
                <div class="flex items-start justify-between gap-2">
                    <div>
                        <h2 class="text-sm font-semibold text-slate-800">Team access</h2>
                        {% if owner_team %}
                        <p class="mt-0.5 text-xs text-slate-500">
                            <span class="font-medium text-slate-700">{{ owner_team.name }}</span>
                            · {{ owner_team_member_count }}/{{ owner_team_seat_limit }} seats
                        </p>
                        {% endif %}
                    </div>
                </div>

                {% if owner_team %}
                {% if owner_team_seat_left == 0 %}
                <div class="mt-2 rounded-lg border border-amber-200 bg-amber-50 px-2.5 py-1.5 text-xs text-amber-800">
                    Seats full — free a seat or upgrade before adding more people.
                </div>
                {% endif %}

                {% if billing_can_invite and owner_team_seat_left > 0 %}
                <form action="{{ url('teams:member_add_any') }}" method="post" class="mt-3 space-y-2">
                    <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
                    <input type="hidden" name="next" value="{{ request.path }}">
                    {% if owned_teams|length > 1 %}
                    <select name="team_slug"
                            class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20">
                        {% for owned_team in owned_teams %}
                        <option value="{{ owned_team.slug }}" {% if owned_team.id == owner_team.id %}selected{% endif %}>{{ owned_team.name }}</option>
                        {% endfor %}
                    </select>
                    {% else %}
                    <input type="hidden" name="team_slug" value="{{ owner_team.slug }}">
                    {% endif %}
                    <div class="flex flex-col gap-2 sm:flex-row sm:items-stretch">
                        <div class="min-w-0 flex-1">
                            {{ team_invite_form.who }}
                        </div>
                        <div class="sm:w-28">
                            {{ team_invite_form.role }}
                        </div>
                        <button type="submit"
                                class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-700 sm:shrink-0">
                            Add
                        </button>
                    </div>
                    <p class="text-[11px] text-slate-500">
                        Username → added to this <span class="font-medium">team workspace</span> now.
                        Email → copyable join link. For one project only, open that project → Add member.
                    </p>
                </form>
                {% elif billing_can_invite %}
                <p class="mt-2 text-xs text-slate-500">No free seats — deactivate someone or upgrade to add more.</p>
                {% endif %}

                <ul class="mt-3 divide-y divide-slate-100 rounded-lg border border-slate-100">
                    {% for member in owner_team_members %}
                    <li class="flex items-center justify-between gap-2 px-2.5 py-2 {% if not member.is_active %}opacity-50{% endif %}">
                        <div class="min-w-0">
                            <p class="truncate text-sm font-medium text-slate-800">@{{ member.user.username }}</p>
                            <p class="truncate text-[11px] text-slate-500">
                                {% if member.is_owner %}Owner{% elif member.role == 'admin' %}Admin{% else %}Member{% endif %}
                                {% if not member.is_active %} · off{% endif %}
                                {% if member.user.email %} · {{ member.user.email }}{% endif %}
                            </p>
                        </div>
                        {% if billing_is_owner and not member.is_owner %}
                        <form action="{{ url('teams:member_status', team_slug=owner_team.slug, membership_id=member.id) }}" method="post" class="shrink-0">
                            <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
                            <input type="hidden" name="is_active" value="{{ 'false' if member.is_active else 'true' }}">
                            {% if member.is_active %}
                            <button type="submit" class="rounded border border-slate-200 bg-white px-2 py-1 text-[11px] font-medium text-slate-600 hover:bg-slate-50">Remove</button>
                            {% else %}
                            <button type="submit" class="rounded border border-emerald-200 bg-emerald-50 px-2 py-1 text-[11px] font-medium text-emerald-700 hover:bg-emerald-100">Restore</button>
                            {% endif %}
                        </form>
                        {% endif %}
                    </li>
                    {% else %}
                    <li class="px-2.5 py-3 text-xs text-slate-500">No members yet.</li>
                    {% endfor %}
                </ul>

                {% if billing_can_invite %}
                <div class="mt-3 rounded-lg border border-slate-100 bg-slate-50/80 p-2.5">
                    <p class="text-xs font-semibold text-slate-700">Share join link</p>
                    <p class="mt-0.5 text-[11px] text-slate-500">Anyone with the link can join (while seats last).</p>
                    {% if team_join_url %}
                    <div class="mt-2 flex gap-2">
                        <input type="text" readonly value="{{ team_join_url }}"
                               class="min-w-0 flex-1 rounded-lg border border-slate-200 bg-white px-2.5 py-1.5 text-[11px] text-slate-700"
                               id="team-join-url-input">
                        <button type="button"
                                class="shrink-0 rounded-lg border border-slate-200 bg-white px-3 py-1.5 text-[11px] font-semibold text-slate-700 hover:bg-slate-50"
                                @click="navigator.clipboard.writeText(document.getElementById('team-join-url-input').value); copied = true; setTimeout(() => copied = false, 1500)"
                                x-text="copied ? 'Copied' : 'Copy'"></button>
                    </div>
                    {% endif %}
                    <form action="{{ url('teams:invite_link', team_slug=owner_team.slug) }}" method="post" class="mt-2 flex items-center gap-2">
                        <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
                        <input type="hidden" name="role" value="member">
                        <button type="submit" class="rounded-lg bg-slate-800 px-3 py-1.5 text-[11px] font-semibold text-white hover:bg-slate-900">
                            {% if team_join_url %}Refresh link{% else %}Create link{% endif %}
                        </button>
                    </form>
                </div>

                {% if pending_email_invites %}
                <div class="mt-3">
                    <p class="text-xs font-semibold text-slate-700">Waiting to join</p>
                    <ul class="mt-1 space-y-1">
                        {% for inv in pending_email_invites[:5] %}
                        <li class="flex items-center justify-between gap-2 rounded border border-slate-100 px-2 py-1.5 text-[11px] text-slate-600">
                            <span class="truncate">{{ inv.email }}</span>
                            <span class="shrink-0 rounded bg-amber-100 px-1.5 py-0.5 text-[10px] font-medium text-amber-800">pending</span>
                        </li>
                        {% endfor %}
                    </ul>
                </div>
                {% endif %}
                {% endif %}

                {% else %}
                <p class="mt-2 text-sm text-slate-500">Create a team first, then add people here with a username or email.</p>
                {% endif %}
            </section>
            <section class="archived-mindmap-panel rounded-lg border border-amber-200 bg-amber-50/70 p-3 shadow-sm">
                <h2 class="text-sm font-semibold text-amber-900">Active team mindmaps</h2>
                <p class="mt-1 text-xs text-amber-800">Archive any team you manage (owner/admin).</p>
                {% if manageable_active_team_memberships %}
                <div class="mt-2 space-y-2">
                    {% for active_membership in manageable_active_team_memberships %}
                    <div class="flex items-center justify-between rounded-lg border border-amber-200 bg-white px-3 py-2">
                        <div>
                            <p class="text-xs font-semibold text-slate-800">{{ active_membership.team.name }}</p>
                            <p class="text-[11px] text-slate-500">Active team workspace</p>
                        </div>
                        <form method="post" action="{{ url('planner:archive_team_mindmap', team_slug=active_membership.team.slug) }}"
                              onsubmit="return window.confirm('Archive all tasks in this team mindmap?')">
                            <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
                            <button type="submit" class="rounded-lg border border-amber-200 bg-amber-50 px-3 py-1.5 text-[11px] font-semibold text-amber-700 hover:bg-amber-100">
                                Archive
                            </button>
                        </form>
                    </div>
                    {% endfor %}
                </div>
                {% else %}
                <p class="mt-2 text-xs text-amber-800">No manageable active team mindmap.</p>
                {% endif %}

                <h2 class="mt-4 text-sm font-semibold text-amber-900">Archived team mindmaps</h2>
                <p class="mt-1 text-xs text-amber-800">Archived teams are hidden from the sidebar until restored.</p>
                {% if archived_team_memberships %}
                <div class="mt-2 space-y-2">
                    {% for archived_membership in archived_team_memberships %}
                    <div class="flex items-center justify-between rounded-lg border border-amber-200 bg-white px-3 py-2">
                        <div>
                            <p class="text-xs font-semibold text-slate-800">{{ archived_membership.team.name }}</p>
                            <p class="text-[11px] text-slate-500">Team workspace archived</p>
                        </div>
                        <form method="post" action="{{ url('planner:unarchive_team_mindmap', team_slug=archived_membership.team.slug) }}">
                            <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
                            <button type="submit" class="rounded-lg border border-emerald-200 bg-emerald-50 px-3 py-1.5 text-[11px] font-semibold text-emerald-700 hover:bg-emerald-100">
                                Unarchive
                            </button>
                        </form>
                    </div>
                    {% endfor %}
                </div>
                {% else %}
                <p class="mt-2 text-xs text-amber-800">No archived team mindmap yet.</p>
                {% endif %}
            </section>
        </div>
    </section>
</div>
{% endblock %}
