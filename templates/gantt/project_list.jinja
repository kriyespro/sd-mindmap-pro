{% extends 'layouts/app.jinja' %}
{% block title %}Gantt Charts{% endblock %}

{% block main %}
<div class="flex min-h-full flex-col">
    <header class="sticky top-0 z-20 flex items-center gap-3 border-b border-slate-200/80 bg-white/90 px-6 py-3 backdrop-blur-md">
        <button type="button" @click="toggleSidebar()"
                data-sidebar-toggle
                class="inline-flex h-7 w-7 items-center justify-center rounded-md border border-slate-200 text-slate-500 transition hover:text-indigo-600">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
        <h1 class="text-sm font-semibold text-slate-900">Gantt Charts</h1>
    </header>

    <div class="flex-1 p-6">
        {% if projects %}
        <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
            {% for project in projects %}
            <a href="{{ url('gantt:gantt', slug=project.slug) }}"
               class="flex items-center gap-3 rounded-xl border border-slate-200 bg-white p-4 shadow-sm transition hover:shadow-md hover:border-indigo-300 group">
                <div class="h-10 w-10 rounded-lg shrink-0" style="background-color: {{ project.color }};"></div>
                <div class="min-w-0 flex-1">
                    <p class="truncate text-sm font-semibold text-slate-900 group-hover:text-indigo-700 transition">{{ project.name }}</p>
                    <p class="text-[10px] text-slate-500">{{ project.get_status_display() }} · {{ project.progress }}%</p>
                </div>
                <svg class="h-4 w-4 text-slate-400 group-hover:text-indigo-500 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
            {% endfor %}
        </div>
        {% else %}
        <div class="flex flex-col items-center justify-center py-20 text-center">
            <p class="text-sm text-slate-500">No projects yet. <a href="{{ url('projects:list') }}" class="text-indigo-600 hover:underline">Create one →</a></p>
        </div>
        {% endif %}
    </div>
</div>
{% endblock %}
