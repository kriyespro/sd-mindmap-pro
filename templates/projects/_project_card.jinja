<div class="group relative flex flex-col gap-3 rounded-xl border border-slate-200 bg-white p-4 shadow-sm transition hover:shadow-md hover:border-slate-300"
     style="border-left: 4px solid {{ project.color }};">
    <div class="flex items-start justify-between gap-2">
        <div class="min-w-0 flex-1">
            <a href="{{ url('projects:detail', slug=project.slug) }}"
               class="block truncate text-sm font-semibold text-slate-900 hover:text-indigo-600 transition">
                {{ project.name }}
            </a>
            {% if project.client_name %}
            <p class="mt-0.5 truncate text-xs text-slate-500">{{ project.client_name }}</p>
            {% endif %}
        </div>
        <div class="flex shrink-0 items-center gap-1.5">
            <span class="inline-flex items-center rounded-full px-2 py-0.5 text-[10px] font-semibold
                {% if project.status == 'active' %}bg-green-100 text-green-700
                {% elif project.status == 'planning' %}bg-blue-100 text-blue-700
                {% elif project.status == 'on_hold' %}bg-yellow-100 text-yellow-700
                {% elif project.status == 'completed' %}bg-emerald-100 text-emerald-700
                {% else %}bg-red-100 text-red-700{% endif %}">
                {{ project.get_status_display() }}
            </span>
            <span class="inline-flex items-center rounded-full px-2 py-0.5 text-[10px] font-semibold
                {% if project.priority == 'critical' %}bg-red-100 text-red-700
                {% elif project.priority == 'high' %}bg-orange-100 text-orange-700
                {% elif project.priority == 'medium' %}bg-blue-100 text-blue-700
                {% else %}bg-slate-100 text-slate-600{% endif %}">
                {{ project.priority|title }}
            </span>
        </div>
    </div>

    {% if project.description %}
    <p class="line-clamp-2 text-xs text-slate-500">{{ project.description }}</p>
    {% endif %}

    <!-- Progress bar -->
    <div>
        <div class="mb-1 flex items-center justify-between">
            <span class="text-[10px] text-slate-500">Progress</span>
            <span class="text-[10px] font-semibold text-slate-700">{{ project.progress }}%</span>
        </div>
        <div class="h-1.5 w-full overflow-hidden rounded-full bg-slate-100">
            <div class="h-full rounded-full transition-all"
                 style="width: {{ project.progress }}%; background-color: {{ project.color }};"></div>
        </div>
    </div>

    <div class="flex items-center justify-between">
        <div class="flex items-center gap-2 text-[10px] text-slate-500">
            {% if project.end_date %}
            <span>Due {{ project.end_date.strftime('%b %d, %Y') }}</span>
            {% endif %}
            <span>·</span>
            <span class="inline-flex items-center gap-0.5
                {% if project.health == 'on_track' %}text-green-600
                {% elif project.health == 'at_risk' %}text-yellow-600
                {% else %}text-red-600{% endif %}">
                <span class="h-1.5 w-1.5 rounded-full
                    {% if project.health == 'on_track' %}bg-green-500
                    {% elif project.health == 'at_risk' %}bg-yellow-500
                    {% else %}bg-red-500{% endif %}"></span>
                {{ project.get_health_display() }}
            </span>
        </div>
        <div class="flex items-center gap-1.5 text-[10px] text-slate-500">
            <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0"/></svg>
            {{ project.members.count() }}
        </div>
    </div>
</div>
