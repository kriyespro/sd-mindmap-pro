{% extends 'layouts/app.jinja' %}
{% block title %}Archived Projects{% endblock %}

{% block main %}
<div class="flex min-h-full flex-col">
    <header class="sticky top-0 z-20 flex items-center gap-3 border-b border-slate-200/80 bg-white/90 px-6 py-3 backdrop-blur-md">
        <button type="button" @click="sidebarOpen = !sidebarOpen"
                class="inline-flex h-7 w-7 items-center justify-center rounded-md border border-slate-200 text-slate-500 transition hover:text-indigo-600">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
        <nav class="flex items-center gap-1.5 text-xs text-slate-500">
            <a href="{{ url('projects:list') }}" class="hover:text-slate-800 transition">Projects</a>
            <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            <span class="font-semibold text-slate-900">Archived</span>
        </nav>
    </header>

    <div class="flex-1 overflow-auto p-6">
        {% if projects %}
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
            {% for project in projects %}
            <div class="relative opacity-70">
                {% include 'projects/_project_card.jinja' %}
                <div class="absolute inset-0 flex items-end justify-end rounded-xl p-3">
                    <form action="{{ url('projects:unarchive', slug=project.slug) }}" method="post">
                        {{ csrf_input }}
                        <button type="submit"
                                class="rounded-lg bg-white border border-slate-300 px-2.5 py-1 text-xs font-medium text-slate-700 hover:bg-slate-50 shadow-sm transition">
                            Restore
                        </button>
                    </form>
                </div>
            </div>
            {% endfor %}
        </div>
        {% else %}
        <div class="flex flex-col items-center justify-center py-20 text-center">
            <p class="text-sm text-slate-500">No archived projects.</p>
            <a href="{{ url('projects:list') }}" class="mt-3 text-xs text-indigo-600 hover:underline">Back to Projects</a>
        </div>
        {% endif %}
    </div>
</div>
{% endblock %}
