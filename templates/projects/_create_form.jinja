<form hx-post="{{ url('projects:create') }}"
      hx-target="#create-form-slot"
      hx-swap="innerHTML"
      class="space-y-4">
    {{ csrf_input }}

    {% if form.non_field_errors() %}
    <div class="rounded-lg border border-rose-200 bg-rose-50 px-3 py-2 text-xs text-rose-800">
        {% for err in form.non_field_errors() %}{{ err }}{% endfor %}
    </div>
    {% endif %}

    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
        <div class="sm:col-span-2">
            <label class="block text-xs font-medium text-slate-700 mb-1">Project Name *</label>
            <input type="text" name="name" required
                   value="{{ form.name.value()|default('') }}"
                   class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500"
                   placeholder="e.g. Website Redesign">
            {% if form.name.errors %}
            <p class="mt-1 text-xs text-red-500">{{ form.name.errors|join(', ') }}</p>
            {% endif %}
        </div>

        <div>
            <label class="block text-xs font-medium text-slate-700 mb-1">Status</label>
            <select name="status" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500">
                {% for val, label in form.fields['status'].choices %}
                <option value="{{ val }}" {% if form.status.value() == val %}selected{% endif %}>{{ label }}</option>
                {% endfor %}
            </select>
        </div>

        <div>
            <label class="block text-xs font-medium text-slate-700 mb-1">Priority</label>
            <select name="priority" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500">
                {% for val, label in form.fields['priority'].choices %}
                <option value="{{ val }}" {% if form.priority.value() == val %}selected{% endif %}>{{ label }}</option>
                {% endfor %}
            </select>
        </div>

        <div>
            <label class="block text-xs font-medium text-slate-700 mb-1">Start Date</label>
            <input type="date" name="start_date"
                   value="{{ form.start_date.value()|default('') }}"
                   class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500">
        </div>

        <div>
            <label class="block text-xs font-medium text-slate-700 mb-1">End Date</label>
            <input type="date" name="end_date"
                   value="{{ form.end_date.value()|default('') }}"
                   class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500">
        </div>

        <div>
            <label class="block text-xs font-medium text-slate-700 mb-1">Client</label>
            <input type="text" name="client_name"
                   value="{{ form.client_name.value()|default('') }}"
                   class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500"
                   placeholder="Client name (optional)">
        </div>

        <div>
            <label class="block text-xs font-medium text-slate-700 mb-1">Budget</label>
            <input type="number" name="budget" step="0.01" min="0"
                   value="{{ form.budget.value()|default('') }}"
                   class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500"
                   placeholder="0.00">
        </div>

        <div>
            <label class="block text-xs font-medium text-slate-700 mb-1">Color</label>
            <input type="color" name="color"
                   value="{{ form.color.value()|default('#6366f1') }}"
                   class="h-9 w-full rounded-lg border border-slate-300 px-1 py-1 text-sm focus:outline-none">
        </div>

        <div class="sm:col-span-2">
            <label class="block text-xs font-medium text-slate-700 mb-1">Description</label>
            <textarea name="description" rows="2"
                      class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500"
                      placeholder="Brief project description...">{{ form.description.value()|default('') }}</textarea>
        </div>
    </div>

    <div class="flex items-center justify-end gap-2 border-t border-slate-100 pt-3">
        <button type="button"
                @click="createOpen = false"
                class="rounded-lg border border-slate-300 px-3 py-1.5 text-xs font-medium text-slate-700 hover:bg-slate-50 transition">
            Cancel
        </button>
        <button type="submit"
                class="rounded-lg bg-indigo-600 px-4 py-1.5 text-xs font-semibold text-white hover:bg-indigo-700 transition">
            Create Project
        </button>
    </div>
</form>
